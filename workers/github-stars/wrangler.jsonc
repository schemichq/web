{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "github-stars",
  "main": "src/index.ts",
  "compatibility_date": "2024-09-23",
  "observability": {
    "enabled": true
  },
  "vars": {
    // The repo to read stars from. Override per-environment or via the
    // dashboard. GITHUB_TOKEN (optional) is a SECRET — set with
    // `wrangler secret put GITHUB_TOKEN`, never put it here.
    "GITHUB_REPO": "schemichq/schemic"
  }
}
