---
import { getCollection, render } from "astro:content";
import DocsLayout from "@schemic/ui/docs/DocsLayout.astro";
import PrevNext from "@schemic/ui/docs/PrevNext.astro";
import {
  crumbFor,
  prevNextFor,
  sidebarNav,
  topActiveFor,
  topNav,
} from "../../config/docs-nav";

// Components registered for MDX so authors use them without importing.
import Callout from "@schemic/ui/docs/Callout.astro";
import CodeBlock from "@schemic/ui/docs/CodeBlock.astro";
import CommandRef from "@schemic/ui/docs/CommandRef.astro";
import CommandTabs from "@schemic/ui/docs/CommandTabs.astro";
import CompatBadges from "@schemic/ui/docs/CompatBadges.astro";
import DocHero from "@schemic/ui/docs/DocHero.astro";
import MappingTable from "@schemic/ui/docs/MappingTable.astro";
import NextSteps from "@schemic/ui/docs/NextSteps.astro";
import PageHeader from "@schemic/ui/docs/PageHeader.astro";
import PillarCard from "@schemic/ui/docs/PillarCard.astro";
import PillarGrid from "@schemic/ui/docs/PillarGrid.astro";
import SigTable from "@schemic/ui/docs/SigTable.astro";
import StartCard from "@schemic/ui/docs/StartCard.astro";
import StartGrid from "@schemic/ui/docs/StartGrid.astro";
import Step from "@schemic/ui/docs/Step.astro";
import Terminal from "@schemic/ui/docs/Terminal.astro";

export async function getStaticPaths() {
  const entries = await getCollection("docs");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const href = `/docs/${entry.id}`;
const toc = headings
  .filter((h) => h.depth === 2)
  .map((h) => ({ id: h.slug, text: h.text }));
const { prev, next } = prevNextFor(href);

const mdxComponents = {
  Callout,
  CodeBlock,
  CommandRef,
  CommandTabs,
  CompatBadges,
  DocHero,
  MappingTable,
  NextSteps,
  PageHeader,
  PillarCard,
  PillarGrid,
  SigTable,
  StartCard,
  StartGrid,
  Step,
  Terminal,
};
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  sidebarNav={sidebarNav}
  topNav={topNav}
  activeHref={href}
  topActive={topActiveFor(href)}
  headings={toc}
>
  <nav class="crumb" aria-label="Breadcrumb">{crumbFor(href)}</nav>
  <h1 class="page-h1" id="_top">{entry.data.title}</h1>
  <div class="doc-prose">
    <Content components={mdxComponents} />
  </div>
  <PrevNext prev={prev} next={next} />
</DocsLayout>

<style>
  .crumb {
    font-size: 0.78rem;
    color: var(--color-ink-3);
  }
  .page-h1 {
    margin: 0.4rem 0 1.5rem;
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    scroll-margin-top: 5rem;
  }
</style>
