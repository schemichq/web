---
/**
 * Terminal - a shell session: one or more `$ command` lines plus optional
 * output. Copy grabs ONLY the command(s), never the output, so readers can
 * paste a runnable command without the result text.
 *
 * Usage (MDX): <Terminal command="sc gen" output={`diff: 1 new table, 5 fields
 * wrote migrations/0001_init.surql`} />
 *
 * Shell text is flush-left, so plain string props are safe (the MDX
 * indentation-stripping only bites indented code samples).
 */
interface Props {
  command: string;
  output?: string;
  /** Small left-hand label in the title bar. Default "shell". */
  label?: string;
}
const { command, output, label = "shell" } = Astro.props;
const cmdLines = command.split("\n").filter((l) => l.trim() !== "");
const outLines = output ? output.split("\n") : [];
---

<div class="terminal" data-terminal>
  <div class="t-bar">
    <span class="t-label">{label}</span>
    <button type="button" class="t-copy" data-copy data-command={command} aria-label="Copy command">
      <span data-copy-label>Copy</span>
    </button>
  </div>
  <div class="t-body">
    {
      cmdLines.map((line) => (
        <div class="t-line">
          <span class="t-prompt" aria-hidden="true">
            $
          </span>
          <span class="t-cmd">{line}</span>
        </div>
      ))
    }
    {
      outLines.map((line) => (
        <div class="t-out">{line === "" ? " " : line}</div>
      ))
    }
  </div>
</div>

<style>
  .terminal {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: clip;
    background: var(--color-code-bg);
    margin: 1.25rem 0;
  }
  .t-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.5rem 0.875rem;
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .t-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    color: var(--color-ink-3);
  }
  .t-copy {
    border: 1px solid var(--color-border-subtle);
    border-radius: 6px;
    background: transparent;
    color: var(--color-ink-3);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.25rem 0.55rem;
    cursor: pointer;
    transition:
      color 0.12s ease,
      border-color 0.12s ease;
  }
  .t-copy:hover {
    color: var(--color-ink);
    border-color: var(--color-border);
  }
  .t-copy.is-copied {
    color: var(--color-success);
    border-color: color-mix(in oklab, var(--color-success) 50%, transparent);
  }
  .t-body {
    padding: 0.875rem 1rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.55;
  }
  .t-line {
    display: flex;
    gap: 0.6rem;
  }
  .t-prompt {
    color: var(--color-soft);
    flex-shrink: 0;
    user-select: none;
  }
  .t-cmd {
    color: var(--color-code-plain);
    white-space: pre-wrap;
  }
  .t-out {
    color: var(--color-ink-3);
    white-space: pre-wrap;
    padding-left: 1.2rem;
  }
</style>

<script>
  document
    .querySelectorAll<HTMLElement>("[data-terminal]")
    .forEach((root) => {
      const copyBtn = root.querySelector<HTMLButtonElement>("[data-copy]");
      const copyLabel = root.querySelector<HTMLElement>("[data-copy-label]");
      copyBtn?.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(copyBtn.dataset.command ?? "");
          if (copyLabel) copyLabel.textContent = "Copied";
          copyBtn.classList.add("is-copied");
          setTimeout(() => {
            if (copyLabel) copyLabel.textContent = "Copy";
            copyBtn.classList.remove("is-copied");
          }, 1400);
        } catch {
          /* clipboard unavailable */
        }
      });
    });
</script>
