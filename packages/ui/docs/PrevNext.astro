---
/** PrevNext - page footer navigation (previous on the left, next on the right). */
interface Link {
  label: string;
  href: string;
}
interface Props {
  prev?: Link;
  next?: Link;
}
const { prev, next } = Astro.props;
---

<nav class="prevnext" aria-label="Pagination" data-pagefind-ignore>
  {
    prev ? (
      <a class="pn prev" href={prev.href}>
        <span class="dir">Previous</span>
        <span class="label">{prev.label}</span>
      </a>
    ) : (
      <span />
    )
  }
  {
    next && (
      <a class="pn next" href={next.href}>
        <span class="dir">Next</span>
        <span class="label">{next.label}</span>
      </a>
    )
  }
</nav>

<style>
  .prevnext {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border-subtle);
  }
  .pn {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 12px 16px;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    text-decoration: none;
    min-width: 180px;
    transition: border-color 0.15s ease;
  }
  .pn:hover {
    border-color: var(--color-soft);
  }
  .pn.next {
    text-align: right;
  }
  .dir {
    font-size: 0.72rem;
    color: var(--color-ink-3);
  }
  .label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-soft);
  }
</style>
