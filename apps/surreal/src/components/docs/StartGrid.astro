---
/** StartGrid - two-column wrapper for StartCard. */
---

<div class="start-grid"><slot /></div>

<style>
  .start-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-block: 1rem 1.5rem;
  }
  @media (max-width: 40rem) {
    .start-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
