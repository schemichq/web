---
// Shared database-roster dropdown — the listbox both the hero headline picker
// and the sticky nav picker render. Each option carries the driver's slug, brand
// color + target theme palette as data-* attributes; config/picker.ts reads them
// off the DOM to drive the select/theme/redirect behavior. Kept as a single
// component so the roster markup + data hooks live in ONE place.
import { driverTheme, driverUrl, isAvailable } from "../config/drivers";
import type { Driver } from "../config/drivers";

interface Props {
  /** The roster to render (the shared `drivers` list). */
  drivers: Driver[];
  /** Slug of the currently-selected driver, or null on the agnostic hub. */
  selectedSlug?: string | null;
  /** "Suggest a database" destination. */
  suggestHref: string;
  /** Menu alignment relative to the trigger. */
  align?: "center" | "right";
}

const {
  drivers: driverList,
  selectedSlug = null,
  suggestHref,
  align = "center",
} = Astro.props;

const options = driverList.map((d) => ({
  slug: d.slug,
  name: d.name,
  selected: selectedSlug != null && d.slug === selectedSlug,
  available: isAvailable(d),
  status: isAvailable(d) ? "Available" : "Coming soon",
  // Navigable when the driver ships its OWN subdomain (`site`), regardless of
  // availability — PostgreSQL ships a site while still coming-soon.
  site: d.site,
  href: d.site ? driverUrl(d.slug) : "",
  color: d.color,
  color2: d.color2 ?? d.color,
  theme: driverTheme(d.slug),
}));
---

<div
  data-db-menu
  role="listbox"
  aria-label="Databases"
  hidden
  class:list={[
    "absolute top-full z-30 mt-3 w-72 rounded-2xl border border-border bg-canvas-2/95 p-1.5 text-left font-sans tracking-normal shadow-2xl backdrop-blur",
    align === "right" ? "right-0" : "left-1/2 -translate-x-1/2",
  ]}
>
  {
    options.map((d) => (
      <div
        role="option"
        aria-selected={d.selected}
        tabindex={d.selected ? 0 : -1}
        data-driver={d.name}
        data-slug={d.slug}
        data-available={d.available ? "true" : "false"}
        data-site={d.site ? "true" : "false"}
        data-href={d.href}
        data-accent={d.color}
        data-theme-accent={d.theme.accent}
        data-theme-accent2={d.theme.accent2}
        data-theme-canvas={d.theme.canvas}
        data-theme-canvas2={d.theme.canvas2}
        data-theme-surface={d.theme.surface}
        data-theme-ink={d.theme.ink}
        class="flex cursor-pointer items-center justify-between rounded-xl px-3 py-2 font-sans text-sm text-ink-2 outline-none transition-colors hover:bg-white/[0.05] focus-visible:bg-white/[0.07] aria-selected:text-ink"
      >
        <span class="flex items-center gap-2.5">
          <span
            class="size-2.5 rounded-full"
            style={
              d.available
                ? `background:linear-gradient(135deg, ${d.color}, ${d.color2})`
                : `background:${d.color}`
            }
            aria-hidden="true"
          />
          <span class="font-medium">{d.name}</span>
        </span>
        <span
          class:list={[
            "rounded-full px-2 py-0.5 font-mono text-[10px] tracking-wide",
            d.available
              ? "bg-success/15 text-success"
              : "bg-surface-2 text-ink-3",
          ]}
        >
          {d.status}
        </span>
      </div>
    ))
  }

  <div class="mx-1 my-1 h-px bg-border/60" aria-hidden="true"></div>
  <a
    data-db-suggest
    href={suggestHref}
    target="_blank"
    rel="noopener noreferrer"
    tabindex="-1"
    class="group/suggest flex items-center justify-between gap-2 rounded-xl px-3 py-2 font-sans text-[13px] font-medium tracking-normal text-ink-2 outline-none transition-colors hover:bg-white/[0.05] hover:text-ink focus-visible:bg-white/[0.07] focus-visible:text-ink"
  >
    <span>Don't see your database? Vote or request</span>
    <span
      class="text-accent-soft transition-transform group-hover/suggest:translate-x-0.5"
      aria-hidden="true">&rarr;</span
    >
  </a>
</div>
