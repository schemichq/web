---
/** CompatBadges - small pills (accent dot + label) for version compatibility. */
interface Props {
  items: string[];
}
const { items } = Astro.props;
---

<div class="badges">
  {
    items.map((item) => (
      <span class="badge">
        <span class="dot" aria-hidden="true" />
        {item}
      </span>
    ))
  }
</div>

<style>
  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border-radius: 20px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-ink-2);
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-soft);
  }
</style>
