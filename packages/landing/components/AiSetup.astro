---
import { driverUrl, flagshipDriver } from "../config/drivers";

interface Props {
  /** Slug of the driver this site represents; null = agnostic hub. */
  activeDriver?: string | null;
}
const { activeDriver = null } = Astro.props;

// The short, ready-to-paste agent prompt. Display + copy come from the SAME
// string (rendered as text + carried on data-prompt), so they never drift; the
// Copy button writes the EXACT raw string — backticks and all — to the
// clipboard. Kept verbatim from marketing copy.
const PROMPT = `Set up Schemic for my SurrealDB project as code: read https://surrealdb.schemic.dev/llms-full.txt for the current API, install \`@schemic/cli @schemic/surrealdb zod\`, run \`npx schemic init\`, then ask me which tables I need and wire up migrations plus typed rows.`;

// The flagship driver's docs quickstart (the hub has no driver of its own).
const quickstartUrl = `${driverUrl(flagshipDriver.slug)}/docs/quickstart`;
const arrow = '<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>';
const spark =
  '<path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3z"/>';
---

<section class="border-t border-border-subtle bg-canvas-2 px-6 py-24 sm:py-28">
  <div class="mx-auto flex max-w-[820px] flex-col items-center text-center">
    <p class="font-mono text-xs uppercase tracking-[0.08em] text-accent-2">
      // set up with ai
    </p>
    <h2
      class="mt-3 font-display text-4xl font-semibold leading-[1.06] tracking-tight text-ink sm:text-[42px]"
    >
      Let your agent wire it up.
    </h2>
    <p class="mx-auto mt-3 max-w-[600px] text-[17px] leading-[1.5] text-ink-2">
      Paste this into Claude Code, Cursor, or any coding agent — it installs
      Schemic, scaffolds your schema, and sets up migrations, asking about your
      tables as it goes.
    </p>

    <!-- copy-prompt card -->
    <div
      class="mt-9 w-full overflow-hidden rounded-[14px] border border-border bg-code-bg text-left shadow-[0_30px_60px_0_#00000040]"
      data-aiprompt
    >
      <div
        class="flex items-center justify-between gap-3 border-b border-border-subtle bg-surface px-4 py-2.5"
      >
        <span class="inline-flex items-center gap-2 font-mono text-[11px] tracking-[0.04em] text-ink-3">
          <svg
            class="size-3.5 text-accent-soft"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            set:html={spark}
          />
          prompt
        </span>
        <button
          type="button"
          data-copy
          data-prompt={PROMPT}
          aria-label="Copy prompt"
          class="ap-copy rounded-md border border-border-subtle px-2.5 py-1 text-[11px] font-semibold text-ink-3 transition-colors hover:border-border hover:text-ink"
        >
          <span data-copy-label>Copy</span>
        </button>
      </div>
      <p
        class="whitespace-pre-wrap px-4.5 py-4 font-mono text-[13px] leading-[1.7] text-code-plain [overflow-wrap:anywhere]"
      >
        {PROMPT}
      </p>
    </div>

    <a
      href={quickstartUrl}
      class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-ink-2 transition-colors hover:text-ink"
    >
      Read the full guide
      <svg
        class="size-3.5 text-accent-2"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        set:html={arrow}
      />
    </a>
  </div>
</section>

<style>
  .ap-copy.is-copied {
    color: var(--color-success);
    border-color: color-mix(in oklab, var(--color-success) 55%, transparent);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>("[data-aiprompt]").forEach((root) => {
    const copyBtn = root.querySelector<HTMLButtonElement>("[data-copy]");
    const copyLabel = root.querySelector<HTMLElement>("[data-copy-label]");
    copyBtn?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(copyBtn.dataset.prompt ?? "");
        if (copyLabel) copyLabel.textContent = "Copied!";
        copyBtn.classList.add("is-copied");
        setTimeout(() => {
          if (copyLabel) copyLabel.textContent = "Copy";
          copyBtn.classList.remove("is-copied");
        }, 2000);
      } catch {
        /* clipboard unavailable */
      }
    });
  });
</script>
