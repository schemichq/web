---
import {
  isAvailable,
  flagshipDriver,
  findDriver,
  ctaFor,
} from "../config/drivers";
import { examplesFor } from "../config/examples";
import SelectOverlay from "./SelectOverlay.astro";

interface Props {
  /** Slug of the driver this site represents; null = agnostic hub. */
  activeDriver?: string | null;
}

const { activeDriver = null } = Astro.props;

// The agnostic hub (no driver selected): the schema INPUT shows a neutral
// @schemic/core example, while every generated/OUTPUT region is rendered behind
// a "Select a database" blur overlay.
const isHub = activeDriver == null;

// Seed the schema -> DDL panel from the site's driver. A coming-soon driver
// also seeds the overlay shown over the generated-DDL pane. The hero's picker
// can still change all of this client-side via the `schemic:driver` event.
const selected = findDriver(activeDriver) ?? flagshipDriver;
const selectedAvailable = isAvailable(selected);
// All code blocks in this Demo (schema input + generated DDL + map note,
// migrations terminal, end-to-end types, live round-trip) come from the
// centralized example set, selected by the active driver — null on the hub,
// which yields the neutral @schemic/core schema. See config/examples.ts.
const ex = examplesFor(activeDriver);
const initialDialect = { lang: ex.lang, file: ex.file };
// Driver-aware coming-soon overlay copy + action (Postgres-centric on the
// postgres site; never pushes the flagship for a coming-soon driver).
const cta = ctaFor(activeDriver);

const tsLines = ex.schema.input;
const outputLines = ex.schema.output;
const mapNote = ex.schema.mapNote;
const migrationsLines = ex.migrations;
const typesLines = ex.types.query;
const typeMembers = ex.types.members;
const driftLines = ex.live;
// The live array is a header row (`ON TABLE …`) + N diff lines, each opening
// with a `+`/`~`/`-` marker token. Count only the marker lines so the footer
// reflects the active driver's real change count (surreal: 3, postgres: 2).
const driftCount = driftLines.filter((line) =>
  ["+", "~", "-"].includes(line.tokens[0]?.t.trim() ?? ""),
).length;

const icons: Record<string, string> = {
  file: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/>',
  terminal: '<path d="m4 17 6-6-6-6"/><path d="M12 19h8"/>',
  braces: '<path d="M8 3H7a2 2 0 0 0-2 2v5a2 2 0 0 1-2 2 2 2 0 0 1 2 2v5a2 2 0 0 0 2 2h1"/><path d="M16 3h1a2 2 0 0 1 2 2v5a2 2 0 0 1 2 2 2 2 0 0 1-2 2v5a2 2 0 0 1-2 2h-1"/>',
  repeat: '<path d="m17 2 4 4-4 4"/><path d="M3 11v-1a4 4 0 0 1 4-4h14"/><path d="m7 22-4-4 4-4"/><path d="M21 13v1a4 4 0 0 1-4 4H3"/>',
  flask: '<path d="M14 2v6a2 2 0 0 0 .245.96l5.51 10.08A2 2 0 0 1 18 22H6a2 2 0 0 1-1.755-2.96l5.51-10.08A2 2 0 0 0 10 8V2"/><path d="M6.453 15h11.094"/><path d="M8.5 2h7"/>',
  app: '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="M10 4v4"/><path d="M2 8h20"/><path d="M6 4v4"/>',
};

const rail = [
  { id: "schema", label: "Schema → DDL", icon: "file" },
  { id: "migrations", label: "Migrations (CLI)", icon: "terminal" },
  { id: "types", label: "End-to-end types", icon: "braces" },
  { id: "live", label: "Live round-trip", icon: "repeat" },
];

// Non-interactive "coming soon" capabilities (no panel, disabled)
const comingSoon = [
  { label: "Tests", icon: "flask" },
  { label: "Studio", icon: "app" },
];

const tabHead: Record<string, { l: string; lt: string; r?: string; rt?: string }> = {
  schema: { l: "schema.ts", lt: "TypeScript", r: ex.file, rt: ex.lang },
  migrations: { l: "terminal", lt: "sc migrate" },
  types: { l: "query.ts", lt: "TypeScript" },
  live: { l: "sc diff --live", lt: "drift" },
};
---

<section id="demo" class="relative px-6 py-24 sm:py-28">
  <div class="mx-auto max-w-7xl">
    <!-- header -->
    <div class="text-center">
      <p class="font-mono text-xs uppercase tracking-[0.22em] text-ink-3">
        // schema in, native ddl out
      </p>
      <h2
        class="mx-auto mt-4 max-w-2xl font-display text-3xl font-semibold tracking-tight text-balance text-ink-2 sm:text-4xl"
      >
        From <code class="font-mono text-accent-soft">s.*</code> schema to generated{" "}
        <span
          id="demo-dialect"
          class="bg-gradient-to-r from-accent to-accent-2 bg-clip-text text-transparent"
          >{initialDialect.lang}</span
        >.
      </h2>
    </div>

    <!-- demo: two separate panels (capabilities rail + editor window) -->
    <div data-demo class="mt-12">
      <!-- mobile capabilities pills (design addition: rail has no mobile treatment) -->
      <div
        class="mb-5 flex gap-2 overflow-x-auto pb-1 lg:hidden [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
      >
        {
          rail.map((item, i) => (
            <button
              type="button"
              data-demo-tab={item.id}
              data-active={i === 0 ? "true" : "false"}
              class="group flex shrink-0 items-center gap-2 rounded-full border border-border bg-surface px-3.5 py-2 text-sm text-ink-2 transition-colors data-[active=true]:bg-surface-2 data-[active=true]:font-semibold data-[active=true]:text-ink"
            >
              <svg
                class="size-4 shrink-0 text-ink-3 group-data-[active=true]:text-accent-2"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={icons[item.icon]}
              />
              {item.label}
            </button>
          ))
        }
        {
          comingSoon.map((item) => (
            <div
              aria-disabled="true"
              class="flex shrink-0 cursor-not-allowed select-none items-center gap-2 rounded-full border border-border-subtle bg-surface/50 px-3.5 py-2 text-sm text-ink-3 opacity-60"
            >
              <svg
                class="size-4 shrink-0 text-ink-3"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={icons[item.icon]}
              />
              {item.label}
              <span class="rounded-full border border-border-subtle bg-surface-2 px-1.5 py-0.5 font-mono text-[9px] uppercase tracking-wide text-ink-3">
                Soon
              </span>
            </div>
          ))
        }
      </div>

      <div class="flex flex-col gap-5 lg:flex-row">
        <!-- capabilities rail (desktop) -->
        <aside
          class="relative z-10 hidden w-[298px] shrink-0 self-start rounded-2xl border border-border bg-surface p-3 lg:block"
        >
          <p
            class="px-2 pt-1 font-mono text-[11px] uppercase tracking-[0.16em] text-ink-3"
          >
            Capabilities
          </p>
          <nav class="mt-3 flex flex-col gap-1.5">
            {
              rail.map((item, i) => (
                <button
                  type="button"
                  data-demo-tab={item.id}
                  data-active={i === 0 ? "true" : "false"}
                  class="group flex items-center gap-2.5 rounded-[10px] border border-transparent px-3 py-2.5 text-left text-sm text-ink-2 transition-colors hover:bg-white/[0.04] data-[active=true]:border-border data-[active=true]:bg-surface-2 data-[active=true]:font-semibold data-[active=true]:text-ink"
                >
                  <svg
                    class="size-[17px] shrink-0 text-ink-3 group-data-[active=true]:text-accent-2"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    set:html={icons[item.icon]}
                  />
                  {item.label}
                </button>
              ))
            }
            {
              comingSoon.map((item) => (
                <div
                  aria-disabled="true"
                  class="flex cursor-not-allowed select-none items-center gap-2.5 rounded-[10px] border border-transparent px-3 py-2.5 text-left text-sm text-ink-3 opacity-60"
                >
                  <svg
                    class="size-[17px] shrink-0 text-ink-3"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    set:html={icons[item.icon]}
                  />
                  {item.label}
                  <span class="ml-auto rounded-full border border-border-subtle bg-surface-2 px-1.5 py-0.5 font-mono text-[9px] uppercase tracking-wide text-ink-3">
                    Soon
                  </span>
                </div>
              ))
            }
          </nav>
        </aside>

        <!-- editor window -->
        <div class="min-w-0 flex-1 overflow-hidden rounded-2xl border border-border bg-code-bg shadow-[0_0_60px_color-mix(in_oklab,var(--color-accent)_13%,transparent),0_30px_60px_-10px_#00000066]">
          <!-- window header -->
          <div
            class="relative flex items-center border-b border-border-subtle bg-surface px-4 py-3"
          >
            <div class="flex items-center gap-2">
              <span class="size-3 rounded-full bg-[#ff5f57]"></span>
              <span class="size-3 rounded-full bg-[#febc2e]"></span>
              <span class="size-3 rounded-full bg-[#28c840]"></span>
            </div>
            <span
              class="absolute left-1/2 -translate-x-1/2 font-mono text-xs text-ink-3"
              >Schemic</span
            >
          </div>

          <!-- ============ STATE: schema -> DDL ============ -->
          <div data-demo-panel="schema">
            <!-- panes: side-by-side on desktop (continuous header bar; gutter only in the code area), stacked on mobile -->
            <div class="relative grid lg:grid-cols-2">
              <!-- left pane -->
              <div
                class="flex min-w-0 flex-col border-b border-border-subtle lg:border-b-0"
              >
                <div
                  class="flex items-center justify-between border-b border-border-subtle bg-white/[0.02] px-4 py-2.5"
                >
                  <span class="font-mono text-xs text-ink-2">{tabHead.schema.l}</span>
                  <span class="font-mono text-[10px] text-code-fn">{tabHead.schema.lt}</span>
                </div>
                <div
                  class="min-w-0 overflow-x-auto bg-code-bg py-4 font-mono text-[13px] leading-6 lg:pr-5"
                >
                  {
                    tsLines.map((line) => (
                      <div
                        class:list={[
                          "flex border-l-2 pr-4",
                          line.hl ? "border-accent bg-accent/10" : "border-transparent",
                        ]}
                      >
                        <span class="w-8 shrink-0 select-none pr-3 text-right text-ink-3">
                          {line.num}
                        </span>
                        <code class="whitespace-pre">{line.tokens.map((tk) => <span class={tk.c}>{tk.t}</span>)}</code>
                      </div>
                    ))
                  }
                </div>
              </div>
              <!-- right pane -->
              <div class="flex min-w-0 flex-col">
                <div
                  class="flex items-center justify-between border-b border-border-subtle bg-accent-2/[0.03] px-4 py-2.5"
                >
                  <span id="demo-file" class="font-mono text-xs text-ink-2">{initialDialect.file}</span>
                  <span id="demo-lang" class="font-mono text-[10px] text-accent-2">{initialDialect.lang}</span>
                </div>
                <div
                  class="relative min-w-0 overflow-x-auto bg-code-bg py-4 font-mono text-[13px] leading-6 lg:pl-5"
                >
                  <div
                    class="pointer-events-none absolute inset-0 bg-gradient-to-r from-transparent to-accent-2/[0.04]"
                  >
                  </div>
                  <!-- coming-soon overlay (shown when a not-yet-shipped driver is picked) -->
                  <div
                    id="demo-soon"
                    hidden={selectedAvailable}
                    class="absolute inset-0 z-20 flex flex-col items-center justify-center gap-4 bg-code-bg/90 px-6 text-center backdrop-blur-[2px]"
                  >
                    <span
                      class="size-2.5 rounded-full"
                      id="demo-soon-dot"
                      style={`background:${selected.color}`}
                      aria-hidden="true"></span>
                    <p id="demo-soon-text" class="max-w-xs font-sans text-sm text-ink-2">
                      {cta.overlay.text}
                    </p>
                    <a
                      id="demo-soon-cta"
                      href={cta.overlay.action.href}
                      class="rounded-full bg-gradient-to-r from-accent to-accent-2 px-4 py-2 font-sans text-xs font-semibold text-on-accent"
                      >{cta.overlay.action.label}</a
                    >
                  </div>
                  {/* agnostic hub: blur the generated DDL behind a picker prompt */}
                  {isHub && <SelectOverlay />}
                  {
                    outputLines.map((line) => (
                      <div
                        class:list={[
                          "relative flex border-l-2 pr-2",
                          line.hl ? "border-accent bg-accent/10" : "border-transparent",
                        ]}
                      >
                        <span class="w-8 shrink-0 select-none pr-3 text-right text-ink-3">
                          {line.num}
                        </span>
                        <code class="whitespace-pre">{line.tokens.map((tk) => <span class={tk.c}>{tk.t}</span>)}</code>
                      </div>
                    ))
                  }
                </div>
              </div>
              <!-- gradient seam arrow (desktop only) -->
              <div
                class="absolute left-1/2 top-5 hidden -translate-x-1/2 -translate-y-1/2 lg:block"
              >
                <svg
                  class="size-5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="url(#seamArrowGrad)"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <defs>
                    <linearGradient
                      id="seamArrowGrad"
                      x1="0"
                      y1="24"
                      x2="24"
                      y2="0"
                      gradientUnits="userSpaceOnUse"
                    >
                      <stop offset="0" stop-color="var(--color-accent)"></stop>
                      <stop offset="1" stop-color="var(--color-accent-2)"></stop>
                    </linearGradient>
                  </defs>
                  <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
                </svg>
              </div>
            </div>

            <!-- map note -->
            <div
              id="demo-mapnote"
              hidden={isHub || !selectedAvailable}
              class="flex items-center gap-2 border-t border-border-subtle bg-accent/10 px-4 py-2.5 text-xs text-ink-2"
            >
              <span class="size-1.5 shrink-0 rounded-full bg-gradient-to-r from-accent to-accent-2"></span>
              <span>{
                mapNote.map((seg) =>
                  seg.code ? (
                    <code class:list={["font-mono", seg.c]}>{seg.t}</code>
                  ) : (
                    <Fragment>{seg.t}</Fragment>
                  ),
                )
              }</span>
            </div>
          </div>

          <!-- ============ STATE: migrations ============ -->
          <div data-demo-panel="migrations" hidden>
            <div
              class="flex items-center justify-between border-b border-border-subtle px-4 py-2.5"
            >
              <span class="font-mono text-xs text-ink-2">{tabHead.migrations.l}</span>
              <span class="font-mono text-[11px] text-ink-3">{tabHead.migrations.lt}</span>
            </div>
            <div class="relative bg-code-bg px-4 py-4 font-mono text-[13px] leading-[1.7]">
              {isHub && <SelectOverlay />}
              {
                migrationsLines.map((l) => (
                  <div class="whitespace-pre"><span class={l.symC}>{l.sym}</span><span class={l.msgC}>{l.msg}</span></div>
                ))
              }
            </div>
            <div
              class="flex items-center gap-2 border-t border-border-subtle bg-accent/10 px-4 py-2.5 text-xs text-ink-2"
            >
              <span class="size-1.5 shrink-0 rounded-full bg-gradient-to-r from-accent to-accent-2"></span>
              <span>Every change is a reviewable up/down migration — applied in order, recorded by sha.</span>
            </div>
          </div>

          <!-- ============ STATE: end-to-end types ============ -->
          <div data-demo-panel="types" hidden>
            <div
              class="flex items-center justify-between border-b border-border-subtle px-4 py-2.5"
            >
              <span class="font-mono text-xs text-ink-2">{tabHead.types.l}</span>
              <span class="font-mono text-[10px] text-code-fn">{tabHead.types.lt}</span>
            </div>
            <div class="relative bg-code-bg px-4 py-4 font-mono text-[13px] leading-6">
              {isHub && <SelectOverlay />}
              {
                typesLines.map((line) => (
                  <div class="flex">
                    <span class="w-8 shrink-0 select-none pr-3 text-right text-ink-3">{line.num}</span>
                    <code class="whitespace-pre">{line.tokens.map((tk) => <span class={tk.c}>{tk.t}</span>)}</code>
                  </div>
                ))
              }
              <!-- autocomplete dropdown -->
              <div
                class="ml-[3.7rem] mt-1 w-fit overflow-hidden rounded-lg border border-border bg-surface-2 text-[12.5px] shadow-[0_16px_40px_-12px_rgba(0,0,0,0.7)]"
              >
                {
                  typeMembers.map((m, i) => (
                    <div
                      class:list={[
                        "flex items-center gap-3 px-3 py-1.5",
                        i === 0 && "bg-accent/15",
                      ]}
                    >
                      <span class="text-code-fn">{m.name}</span>
                      <span class="text-ink-3">:</span>
                      <span class="text-code-type">{m.type}</span>
                    </div>
                  ))
                }
              </div>
            </div>
            <div
              class="flex items-center gap-2 border-t border-border-subtle bg-accent/10 px-4 py-2.5 text-xs text-ink-2"
            >
              <span class="size-1.5 shrink-0 rounded-full bg-gradient-to-r from-accent to-accent-2"></span>
              <span>Decoded rows are fully typed — <code class="font-mono text-accent-soft">datetime → Date</code>, ids, optionals and all.</span>
            </div>
          </div>

          <!-- ============ STATE: live round-trip ============ -->
          <div data-demo-panel="live" hidden>
            <div
              class="flex items-center justify-between border-b border-border-subtle px-4 py-2.5"
            >
              <span class="font-mono text-xs text-ink-2">{tabHead.live.l}</span>
              <span class="font-mono text-[11px] text-ink-3">{tabHead.live.lt}</span>
            </div>
            <div class="relative bg-code-bg px-4 py-4 font-mono text-[13px] leading-[1.7]">
              {isHub && <SelectOverlay />}
              <div class="whitespace-pre text-ink-3"><span class="text-accent-2">$</span> sc diff --live</div>
              <div class="mb-2 whitespace-pre text-ink-3">~ comparing schema.ts ↔ running database</div>
              {
                driftLines.map((line) => (
                  <div class="whitespace-pre pl-2">{line.tokens.map((tk) => <span class={tk.c}>{tk.t}</span>)}</div>
                ))
              }
              <div class="mt-2 whitespace-pre text-ink-2">{driftCount} {driftCount === 1 ? "change" : "changes"} · run <span class="text-accent-soft">sc sync</span> to reconcile</div>
            </div>
            <div
              class="flex items-center gap-2 border-t border-border-subtle bg-accent/10 px-4 py-2.5 text-xs text-ink-2"
            >
              <span class="size-1.5 shrink-0 rounded-full bg-gradient-to-r from-accent to-accent-2"></span>
              <span>Diff your code against the live database — normalized by the driver, so there's no formatting noise.</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- caption row -->
    <div class="mt-6 flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="flex items-center gap-2 text-sm text-ink-3">
        <svg
          class="size-4 shrink-0 text-accent-2"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"
          ></path><path d="M20 3v4"></path><path d="M22 5h-4"></path><path
            d="M4 17v2"></path><path d="M5 18H3"></path>
        </svg>
        Define your tables and fields in TypeScript — the native DDL is
        generated for you.
      </p>
      <a
        href="/docs/quickstart"
        class="group inline-flex shrink-0 items-center gap-2 rounded-full border border-border bg-surface px-5 py-2.5 text-sm font-medium text-ink transition-colors hover:border-ink-3"
      >
        Open the playground
        <svg
          class="size-4 shrink-0 text-accent-2 transition-transform group-hover:translate-x-0.5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
        >
      </a>
    </div>
  </div>
</section>

<script>
  for (const root of document.querySelectorAll<HTMLElement>("[data-demo]")) {
    const tabs = root.querySelectorAll<HTMLElement>("[data-demo-tab]");
    const panels = root.querySelectorAll<HTMLElement>("[data-demo-panel]");
    for (const tab of tabs) {
      tab.addEventListener("click", () => {
        const id = tab.getAttribute("data-demo-tab");
        for (const t of tabs)
          t.setAttribute(
            "data-active",
            String(t.getAttribute("data-demo-tab") === id),
          );
        for (const p of panels)
          p.toggleAttribute("hidden", p.getAttribute("data-demo-panel") !== id);
      });
    }
  }

  // Reflect the hero's database picker in the schema -> DDL panel.
  const dialects: Record<string, { lang: string; file: string }> = {
    SurrealDB: { lang: "SurrealQL", file: "user.surql" },
    PostgreSQL: { lang: "PostgreSQL", file: "user.sql" },
  };
  const dialectEl = document.getElementById("demo-dialect");
  const fileEl = document.getElementById("demo-file");
  const langEl = document.getElementById("demo-lang");
  const mapNote = document.getElementById("demo-mapnote");
  const soon = document.getElementById("demo-soon");
  const soonText = document.getElementById("demo-soon-text");
  const soonDot = document.getElementById("demo-soon-dot");

  document.addEventListener("schemic:driver", (e) => {
    const { name, available, accent } = (e as CustomEvent).detail as {
      name: string;
      available: boolean;
      accent: string;
    };
    const d = dialects[name] ?? dialects.SurrealDB;
    if (dialectEl) dialectEl.textContent = d.lang;
    if (fileEl) fileEl.textContent = d.file;
    if (langEl) langEl.textContent = d.lang;
    if (mapNote) mapNote.hidden = !available;
    if (soon) soon.hidden = available;
    if (!available && soonText)
      soonText.textContent = `The ${name} driver is coming soon — follow progress on GitHub.`;
    if (!available && soonDot && accent)
      soonDot.style.background = accent;
  });
</script>
