---
import { paneStates, paneKeyFor } from "../config/drivers";
import { examplesFor } from "../config/examples";

interface Props {
  /** Slug of the driver this site represents; null = agnostic hub. */
  activeDriver?: string | null;
}
const { activeDriver = null } = Astro.props;

// Driver-aware terminal session (generated artifacts/dialect differ; the `sc`
// commands themselves are driver-agnostic). Every variant is rendered as a
// `[data-driver-pane]` and the picker toggles which is visible. The agnostic
// pane's blocks are neutral "select a database…" placeholders. See examples.ts.
const activeKey = paneKeyFor(activeDriver);
const states = paneStates.map((s) => ({
  key: s.key,
  hidden: s.key !== activeKey,
  blocks: examplesFor(s.slug).cli,
}));
---

<section
  id="cli"
  class="border-y border-border-subtle bg-canvas-2 px-6 py-24 sm:py-28"
>
  <div class="mx-auto flex max-w-[920px] flex-col items-center">
    <!-- head -->
    <div class="text-center">
      <p class="font-mono text-xs uppercase tracking-[0.08em] text-accent-2">
        // the cli
      </p>
      <h2
        class="mt-3 font-display text-4xl font-semibold leading-[1.06] tracking-tight text-ink sm:text-[42px]"
      >
        Migrations are first-class.
      </h2>
      <p class="mx-auto mt-3 max-w-[640px] text-[17px] leading-[1.5] text-ink-2">
        Write a migration from your schema, apply it, and check for drift against
        the live database — three commands, no DDL by hand.
      </p>
    </div>

    <!-- terminal — flex column so the body fills the window and any trailing
         explanation line sits flush at the bottom edge, never mid-window. -->
    <div
      class="mt-9 flex w-full flex-col overflow-hidden rounded-[14px] border border-border bg-code-bg shadow-[0_0_60px_0_color-mix(in_oklab,var(--color-accent)_13%,transparent),0_30px_60px_0_#00000066]"
    >
      <!-- title bar -->
      <div class="relative flex shrink-0 items-center bg-surface px-4.5 py-[13px]">
        <div class="flex items-center gap-2">
          <span class="size-3 rounded-full bg-[#ff5f57]"></span>
          <span class="size-3 rounded-full bg-[#febc2e]"></span>
          <span class="size-3 rounded-full bg-[#28c840]"></span>
        </div>
        <span
          class="absolute left-1/2 -translate-x-1/2 font-mono text-xs text-ink-3"
          >schemic — cli</span
        >
      </div>

      <!-- body -->
      <div
        class="relative flex flex-1 flex-col gap-1.5 overflow-x-auto px-[22px] pt-[18px] pb-[22px] font-mono text-[13px] leading-[1.6]"
      >
        {
          states.map((st) => (
            <div data-driver-pane={st.key} hidden={st.hidden} class="flex flex-col gap-1.5">
              {st.blocks.map((block, i) => (
                <Fragment>
                  {i > 0 && <div class="h-2"></div>}
                  <div class="flex items-center gap-2"><span class="text-accent-2">$</span><span class="min-w-0 break-words text-code-plain">{block.cmd}</span></div>
                  {block.outputs.map((o) => (
                    <div class:list={["whitespace-pre-wrap break-words", o.c]}>{o.t}</div>
                  ))}
                </Fragment>
              ))}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
