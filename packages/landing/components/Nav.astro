---
import {
  driverUrl,
  findDriver,
  hubUrl,
  paneKeyFor,
  paneStates,
} from "../config/drivers";
import BrandMark from "./BrandMark.astro";
import NavDbPicker from "./NavDbPicker.astro";

interface Props {
  /** Slug of the driver this site represents; null = agnostic hub. */
  activeDriver?: string | null;
}
const { activeDriver = null } = Astro.props;

// Progressive-disclosure nav (Manuel's spec). The database picker is the primary
// control: on the agnostic hub (no driver) it sits CENTERED as a prominent
// "Select database" prompt and the Docs/Examples links are hidden. Once a driver
// is selected — on a driver route OR via a client-side switch — the picker
// SLIDES to the right beside Get started and the Docs/Examples links reveal. The
// resting state is SSR'd via [data-db-selected]; a FLIP (below) animates live
// transitions. The picker element is rendered into exactly one slot (center on
// the hub, right when selected) and reparented between them on switch.
const isHub = activeDriver == null;
const navDriver = findDriver(activeDriver);

// Driver-specific nav links resolve to the ACTIVE driver. Each is rendered as a
// `[data-driver-pane]` variant (like the hero CTAs) so the client-side picker
// switch keeps it pointed at the current driver with NO reload. On the agnostic
// hub the whole links row is hidden, so the hub variants never show — but we
// still render them so config/picker.ts's pane machinery stays uniform.
const activeKey = paneKeyFor(activeDriver);
const linkStates = paneStates.map((s) => ({
  key: s.key,
  hidden: s.key !== activeKey,
  docs: s.slug ? `${driverUrl(s.slug)}/docs/introduction` : null,
  start: s.slug ? driverUrl(s.slug) : null,
  // Examples live on the hub origin, one route per driver (+ the agnostic
  // /examples). Driver-aware like Docs/Get-started: a [data-driver-pane] variant
  // per pane so the client-side switch keeps it on the current driver — from the
  // hub it's /examples, from /surrealdb it's /examples/surrealdb.
  examples: s.slug ? `${hubUrl}/examples/${s.slug}` : `${hubUrl}/examples`,
}));
---

<header
  data-db-selected={String(!isHub)}
  class="sticky top-0 z-50 bg-canvas/70 backdrop-blur-md"
>
  <nav
    class="mx-auto grid h-16 max-w-6xl grid-cols-[1fr_auto_1fr] items-center px-4 md:px-6"
    aria-label="Primary"
  >
    <!-- left: brand -->
    <a href="/" class="mr-3 flex items-center gap-2.5 justify-self-start sm:mr-0">
      <BrandMark class="size-8" />
      <span class="font-mono lowercase text-[15px] font-medium tracking-tight text-ink"
        >schemic</span
      >
    </a>

    <!-- center: the Docs/Examples links (revealed once a database is selected)
         sit beside the centered picker slot. The links row is desktop-only and
         hidden until selected; the center slot holds the picker on the hub. -->
    <div class="flex items-center justify-self-center">
      <div data-nav-links class="items-center gap-8">
        {/* Docs — resolves to the ACTIVE driver's docs. */}
        {
          linkStates.map((st) =>
            st.docs ? (
              <a
                href={st.docs}
                data-driver-pane={st.key}
                hidden={st.hidden}
                class="text-sm text-ink-2 transition-colors hover:text-ink"
              >
                Docs
              </a>
            ) : (
              <button
                type="button"
                data-open-picker
                data-driver-pane={st.key}
                hidden={st.hidden}
                class="text-sm text-ink-2 transition-colors hover:text-ink"
              >
                Docs
              </button>
            ),
          )
        }
        {/* The verified cookbook gallery — driver+section-aware. */}
        {
          linkStates.map((st) => (
            <a
              href={st.examples}
              data-driver-pane={st.key}
              hidden={st.hidden}
              class="text-sm text-ink-2 transition-colors hover:text-ink"
            >
              Examples
            </a>
          ))
        }
      </div>
      <!-- picker home: CENTERED here by default, and ALWAYS centered on mobile.
           On desktop, Nav's script slides it to the right slot once a database
           is selected. SSR always renders it here; an inline script below moves
           it right pre-paint on desktop+selected routes (no flash). -->
      <div data-picker-slot="center" class="flex items-center">
        <NavDbPicker navDriver={navDriver} isHub={isHub} />
      </div>
    </div>

    <!-- right: actions -->
    <div class="flex items-center gap-3 justify-self-end sm:gap-5">
      <!-- picker home once a database is selected (desktop only; the picker is
           reparented here by Nav's script). Stays empty on mobile, where the
           picker remains centered. -->
      <div data-picker-slot="right" class="flex items-center"></div>
      <!-- Get started — DESKTOP only; driver-dynamic (opens the picker on the
           hub). On mobile it lives in the hamburger menu below. -->
      <div class="hidden items-center md:flex">
        {
          linkStates.map((st) =>
            st.start ? (
              <a
                href={st.start}
                data-driver-pane={st.key}
                hidden={st.hidden}
                class="rounded-full bg-ink px-4 py-2 text-sm font-semibold text-canvas transition-colors hover:bg-white"
              >
                Get started
              </a>
            ) : (
              <button
                type="button"
                data-open-picker
                data-driver-pane={st.key}
                hidden={st.hidden}
                class="rounded-full bg-ink px-4 py-2 text-sm font-semibold text-canvas transition-colors hover:bg-white"
              >
                Get started
              </button>
            ),
          )
        }
      </div>
      <!-- Hamburger — MOBILE only; opens the menu with Docs/Examples/Get started. -->
      <button
        type="button"
        data-nav-toggle
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="grid size-9 place-items-center rounded-lg border border-border text-ink-2 transition-colors hover:border-accent/50 hover:text-ink md:hidden"
      >
        <svg
          class="size-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16"></path></svg
        >
      </button>
    </div>
  </nav>

  <!-- mobile menu — toggled by the hamburger; holds the links that are
       desktop-only in the bar. Driver-aware: real links once a database is
       chosen, otherwise they open the picker (like the bar's CTAs). Floats as an
       overlay (absolute, OUT of flow) so opening it never shifts the page; the
       backdrop scrim after </header> separates it from the content. -->
  <div
    id="mobile-menu"
    data-mobile-menu
    hidden
    class="absolute inset-x-0 top-full z-50 border-b border-border-subtle bg-canvas/95 shadow-2xl shadow-black/50 backdrop-blur-md md:hidden"
  >
    <div class="mx-auto flex max-w-6xl flex-col gap-1 px-4 py-3">
      {
        linkStates.map((st) =>
          st.docs ? (
            <a
              href={st.docs}
              data-driver-pane={st.key}
              hidden={st.hidden}
              class="rounded-lg px-3 py-2.5 text-sm text-ink-2 transition-colors hover:bg-white/[0.05] hover:text-ink"
            >
              Docs
            </a>
          ) : (
            <button
              type="button"
              data-open-picker
              data-driver-pane={st.key}
              hidden={st.hidden}
              class="rounded-lg px-3 py-2.5 text-left text-sm text-ink-2 transition-colors hover:bg-white/[0.05] hover:text-ink"
            >
              Docs
            </button>
          ),
        )
      }
      {
        linkStates.map((st) => (
          <a
            href={st.examples}
            data-driver-pane={st.key}
            hidden={st.hidden}
            class="rounded-lg px-3 py-2.5 text-sm text-ink-2 transition-colors hover:bg-white/[0.05] hover:text-ink"
          >
            Examples
          </a>
        ))
      }
      {
        linkStates.map((st) =>
          st.start ? (
            <a
              href={st.start}
              data-driver-pane={st.key}
              hidden={st.hidden}
              class="mt-1 rounded-full bg-ink px-4 py-2.5 text-center text-sm font-semibold text-canvas transition-colors hover:bg-white"
            >
              Get started
            </a>
          ) : (
            <button
              type="button"
              data-open-picker
              data-driver-pane={st.key}
              hidden={st.hidden}
              class="mt-1 rounded-full bg-ink px-4 py-2.5 text-center text-sm font-semibold text-canvas transition-colors hover:bg-white"
            >
              Get started
            </button>
          ),
        )
      }
    </div>
  </div>

  <!-- Pre-paint picker placement (no flash): the picker SSRs into the center
       slot; on a desktop + selected route move it to the right slot before the
       first paint. Mobile + the hub keep it centered. -->
  <script is:inline>
    (function () {
      var h = document.querySelector("header[data-db-selected]");
      if (!h) return;
      var picker = h.querySelector('[data-db-picker="nav"]');
      var center = h.querySelector('[data-picker-slot="center"]');
      var right = h.querySelector('[data-picker-slot="right"]');
      if (!picker || !center || !right) return;
      var target =
        window.matchMedia("(min-width: 768px)").matches &&
        h.dataset.dbSelected === "true"
          ? right
          : center;
      if (picker.parentElement !== target) target.appendChild(picker);
    })();
  </script>
</header>

<!-- Mobile-menu backdrop scrim — deliberately OUTSIDE <header>: the header's
     backdrop-blur establishes a containing block, so a `fixed` child would
     resolve to the header box, not the viewport. Placed here it covers the page
     below the bar (top-16) to separate the floating menu from the content; tap
     to close. Toggled with the menu by Nav's script. -->
<div
  data-nav-backdrop
  hidden
  class="fixed inset-x-0 bottom-0 top-16 z-40 bg-black/50 backdrop-blur-sm md:hidden"
>
</div>

<style is:global>
  /* The Docs/Examples links stay hidden until a database is selected, and only
     on desktop (md+). Driven by the header attribute so a client-side switch
     reveals/hides them with no reload. */
  [data-nav-links] {
    display: none;
  }
  @media (min-width: 768px) {
    header[data-db-selected="true"] [data-nav-links] {
      display: flex;
    }
  }

  /* Picker trigger appearance reacts to the selection state (SSR + live switch).
     Unselected = a dashed accent "Select database" prompt; selected = a compact
     solid pill. Mirrors the prior SSR-only Tailwind variants. */
  header[data-db-selected="false"] [data-db-trigger] {
    border-style: dashed;
    border-color: color-mix(in oklab, var(--color-accent) 60%, transparent);
    color: var(--color-accent-soft);
  }
  header[data-db-selected="false"] [data-db-trigger]:hover {
    border-color: var(--color-accent);
    color: var(--color-ink);
  }
  header[data-db-selected="true"] [data-db-trigger] {
    border-style: solid;
    border-color: var(--color-border);
    color: var(--color-ink-2);
  }
  header[data-db-selected="true"] [data-db-trigger]:hover {
    border-color: color-mix(in oklab, var(--color-accent) 50%, transparent);
    color: var(--color-ink);
  }
</style>

<script>
  // Progressive-disclosure FLIP: when the active database changes, slide the nav
  // picker between its centered (hub) slot and its right-hand (selected) slot,
  // and reveal/hide the Docs/Examples links. The single source of truth is the
  // `schemic:driverswitch` CustomEvent that config/picker.ts dispatches on BOTH
  // an in-page select AND back/forward (popstate) — so this one listener covers
  // every transition. The SSR'd first paint already matches the route, so we
  // animate ONLY on events, never on load.
  import { HUB_PANE } from "../config/drivers";

  const header = document.querySelector<HTMLElement>("header[data-db-selected]");
  const picker = document.querySelector<HTMLElement>('[data-db-picker="nav"]');
  const centerSlot = document.querySelector<HTMLElement>(
    '[data-picker-slot="center"]',
  );
  const rightSlot = document.querySelector<HTMLElement>(
    '[data-picker-slot="right"]',
  );
  const links = document.querySelector<HTMLElement>("[data-nav-links]");
  const desktop = window.matchMedia("(min-width: 768px)");

  if (header && picker && centerSlot && rightSlot) {
    const reduce = (): boolean =>
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isSelected = (): boolean => header.dataset.dbSelected === "true";

    // Place the picker in the slot for the current breakpoint + state: DESKTOP +
    // a selected database -> right slot (beside Get started); the hub, and ALL of
    // mobile -> centered. FLIP-animates the move when `animate` is set.
    const placePicker = (animate: boolean): void => {
      const target = desktop.matches && isSelected() ? rightSlot : centerSlot;
      if (picker.parentElement === target) return;
      const first = picker.getBoundingClientRect();
      target.appendChild(picker);
      const last = picker.getBoundingClientRect();
      const dx = first.left - last.left;
      const dy = first.top - last.top;
      if (animate && !reduce() && typeof picker.animate === "function" && (dx || dy)) {
        picker.animate(
          [{ transform: `translate(${dx}px, ${dy}px)` }, { transform: "none" }],
          { duration: 420, easing: "cubic-bezier(.4, 0, .2, 1)" },
        );
      }
    };

    // Live driver switch (in-page select OR back/forward): flip the state attr
    // (restyles the trigger + reveals/hides the desktop links) and re-place the
    // picker — animated on desktop, a no-op on mobile (it stays centered).
    document.addEventListener("schemic:driverswitch", (e) => {
      const key = (e as CustomEvent<{ key: string }>).detail?.key;
      if (typeof key !== "string") return;
      const selected = key !== HUB_PANE;
      header.dataset.dbSelected = String(selected);
      placePicker(true);
      if (
        selected &&
        desktop.matches &&
        links &&
        !reduce() &&
        typeof links.animate === "function"
      ) {
        links.animate([{ opacity: 0 }, { opacity: 1 }], {
          duration: 300,
          delay: 120,
          easing: "ease-out",
        });
      }
    });

    // Re-place (no animation) when crossing the md breakpoint, so the picker ends
    // up centered on mobile and right-when-selected on desktop.
    desktop.addEventListener("change", () => placePicker(false));
    // Idempotent reconcile on load (the inline pre-paint script normally already
    // placed it; this covers the no-inline-JS-timing edge).
    placePicker(false);
  }

  // Mobile menu (hamburger): toggle the panel; close on outside-click, Escape,
  // or any item activation.
  const navToggle = document.querySelector<HTMLElement>("[data-nav-toggle]");
  const navMenu = document.getElementById("mobile-menu");
  const navBackdrop =
    document.querySelector<HTMLElement>("[data-nav-backdrop]");
  if (navToggle && navMenu) {
    const setOpen = (open: boolean): void => {
      navMenu.hidden = !open;
      if (navBackdrop) navBackdrop.hidden = !open;
      navToggle.setAttribute("aria-expanded", String(open));
      // Lock page scroll behind the scrim while the menu is open.
      document.body.style.overflow = open ? "hidden" : "";
    };
    navToggle.addEventListener("click", (e) => {
      e.stopPropagation();
      setOpen(navMenu.hidden);
    });
    if (navBackdrop)
      navBackdrop.addEventListener("click", () => setOpen(false));
    document.addEventListener("click", (e) => {
      if (
        !navMenu.hidden &&
        e.target instanceof Node &&
        !navMenu.contains(e.target) &&
        !navToggle.contains(e.target)
      )
        setOpen(false);
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !navMenu.hidden) setOpen(false);
    });
    // Close on item activation. Capture phase, so a child handler that stops
    // propagation (hub links open the picker via data-open-picker) can't keep
    // the menu open.
    navMenu.addEventListener(
      "click",
      (e) => {
        if (e.target instanceof Element && e.target.closest("a, button"))
          setOpen(false);
      },
      true,
    );
  }
</script>

<script>
  // Single star-count island for the whole page. Fetches the cached worker once
  // on load and, ONLY if it returns a finite numeric `stars`, fills every
  // [data-gh-count] slot (Nav + Hero) and reveals their [data-gh-star-count]
  // chips. On any failure (network, non-OK, null, non-numeric) it does nothing —
  // the buttons stay plain "GitHub" with no count and no reserved gap. SSR-safe
  // and no-JS-safe: the markup is a plain repo link until this runs.
  import { GITHUB_STARS_ENDPOINT } from "../config/github";

  const formatStars = (n: number): string => {
    if (n < 1000) return String(n);
    const k = n / 1000;
    const rounded = k >= 100 ? Math.round(k) : Math.round(k * 10) / 10;
    return `${rounded}k`;
  };

  const loadStars = async (): Promise<void> => {
    const slots = document.querySelectorAll<HTMLElement>("[data-gh-count]");
    if (slots.length === 0) return;
    try {
      const res = await fetch(GITHUB_STARS_ENDPOINT, {
        headers: { accept: "application/json" },
      });
      if (!res.ok) return;
      const data = (await res.json()) as { stars?: number | null };
      const stars = data?.stars;
      if (typeof stars !== "number" || !Number.isFinite(stars)) return;

      const text = formatStars(stars);
      slots.forEach((slot) => {
        slot.textContent = text;
      });
      document
        .querySelectorAll<HTMLElement>("[data-gh-star-count]")
        .forEach((chip) => {
          chip.hidden = false;
        });
    } catch {
      // Graceful: leave the buttons as plain GitHub links.
    }
  };

  void loadStars();
</script>
