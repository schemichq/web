---
import { getCollection } from "astro:content";
import BlogLayout from "@schemic/ui/blog/BlogLayout.astro";
import "../../styles/blog.css";

// The hub has no docs of its own, so its blog nav is just Blog + the picker.
const NAV = [
  { label: "Blog", href: "/blog" },
  { label: "Drivers", href: "/drivers" },
];

// The agnostic hub shows ONLY general articles (no driver-specific posts).
const ALLOWED = ["general"];

const posts = (await getCollection("blog"))
  .filter((p) => ALLOWED.includes(p.data.driver))
  .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));

// Featured = the entry flagged featured, else the newest.
const featured = posts.find((p) => p.data.featured) ?? posts[0];
const rest = posts.filter((p) => p.id !== featured?.id);
---

<BlogLayout title="Blog" navLinks={NAV}>
  <p class="kicker">THE SCHEMIC BLOG</p>
  <h1 class="headline">Notes from building schema-as-code.</h1>
  <p class="sub">Releases, deep dives and design decisions behind Schemic.</p>

  {posts.length === 0 && <p class="empty">No posts yet — check back soon.</p>}

  {
    featured && (
      <a class="featured" href={`/blog/${featured.id}`}>
        <div class="meta">
          <span class="date">{featured.data.date}</span>
          <span class="tag">{featured.data.tag}</span>
          <span class="flag">FEATURED</span>
        </div>
        <h2 class="ft">{featured.data.title}</h2>
        <p class="fx">{featured.data.excerpt}</p>
        <span class="read">Read the post &rarr;</span>
      </a>
    )
  }

  <div class="list">
    {
      rest.map((p) => (
        <a class="row" href={`/blog/${p.id}`}>
          <span class="rdate">{p.data.date}</span>
          <span class="rbody">
            <span class="rtag">{p.data.tag}</span>
            <span class="rtitle">{p.data.title}</span>
            <span class="rx">{p.data.excerpt}</span>
            <span class="rread">{p.data.readTime} read</span>
          </span>
        </a>
      ))
    }
  </div>
</BlogLayout>

<style>
  .kicker {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    color: var(--color-accent-soft);
  }
  .headline {
    margin: 1.25rem 0 0;
    font-size: clamp(2.25rem, 1.6rem + 2.4vw, 3rem);
    line-height: 1.08;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--color-ink);
  }
  .sub {
    margin: 1rem 0 0;
    font-size: 1.125rem;
    color: var(--color-ink-2);
  }
  .empty {
    margin: 2.25rem 0 0;
    font-size: 1rem;
    color: var(--color-ink-3);
  }
  .featured {
    display: block;
    margin-top: 2.25rem;
    padding: 28px;
    border-radius: 14px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: border-color 0.15s ease;
  }
  .featured:hover {
    border-color: var(--color-accent-soft);
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .date {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-ink-3);
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-accent-soft);
    background: color-mix(in oklab, var(--color-accent) 15%, transparent);
    padding: 3px 10px;
    border-radius: 20px;
  }
  .flag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-accent-2);
  }
  .ft {
    margin: 0.875rem 0 0;
    font-size: 1.875rem;
    line-height: 1.15;
    font-weight: 700;
    color: var(--color-ink);
  }
  .fx {
    margin: 0.75rem 0 0;
    font-size: 0.97rem;
    line-height: 1.6;
    color: var(--color-ink-2);
  }
  .read {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent-soft);
  }
  .list {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
  }
  .row {
    display: flex;
    gap: 28px;
    padding: 22px 0;
    border-bottom: 1px solid var(--color-border-subtle);
    text-decoration: none;
  }
  .rdate {
    flex-shrink: 0;
    width: 96px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-ink-3);
    padding-top: 2px;
  }
  .rbody {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .rtag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--color-accent-soft);
  }
  .rtitle {
    font-size: 1.375rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-ink);
  }
  .rx {
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-ink-2);
  }
  .rread {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-ink-3);
  }
  @media (max-width: 40rem) {
    .row {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
