{
  "name": "@schemic/web",
  "type": "module",
  "private": true,
  "version": "0.0.0",
  "description": "Schemic public web properties: schemic.dev hub + per-driver subdomain sites (surreal., postgres., ...).",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "bun run --cwd apps/surreal build",
    "dev:surreal": "bun run --cwd apps/surreal dev",
    "dev:schemic": "bun run --cwd apps/schemic dev",
    "dev:postgres": "bun run --cwd apps/postgres dev"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.3"
  }
}
