---
// The verified cookbook gallery — the body of /examples and /<driver>/examples.
//
// SINGLE-ORIGIN, NO RELOAD (mirrors the landing): every driver's example set is
// rendered up-front behind `[data-driver-pane="<key>"]` (key = a driver slug, or
// "hub" for the agnostic state); only the active pane is visible and the SHARED
// nav picker (config/picker.ts) toggles which — cross-fading the theme and
// pushState-ing /<driver>/examples client-side. There is NO standalone driver
// filter: the picker is the only control, kept in sync with the landing.
//
// Each example pairs a TS authoring source with the DDL it generates; both are
// highlighted at BUILD time with Astro's Shiki <Code> using the brand theme.
//
// The agnostic "hub" pane shows the FLAGSHIP driver's examples as reference
// content (unblurred — examples are reference, not teaser), while the picker
// keeps its "Database" prompt. Driver routes inline that driver's full theme via
// the Landing layout (activeDriver), so the first paint is flash-free.
//
// Data comes from the VENDORED verified manifest (config/examples-manifest.json,
// read via config/examples-catalog.ts) — 69 driver-verified cookbook entries
// copied from schemic main. Re-sync by replacing that JSON; this component is
// shape-stable across syncs.
import { Code } from "astro:components";
import { brandShikiTheme } from "@schemic/content/code-theme";
import Nav from "@schemic/landing/components/Nav.astro";
import Footer from "@schemic/landing/components/Footer.astro";
import {
  drivers,
  flagshipDriver,
  paneKeyFor,
} from "@schemic/landing/config/drivers";
import {
  examplesCatalog,
  type CatalogExample,
} from "../config/examples-catalog";
// Display-time DDL pretty-printer (whitespace-only) — reflows long single-line
// SurrealQL goldens across indented clause lines so the code column never scrolls
// horizontally. SQL passes through untouched. See config/format-ddl.ts.
import { formatDdl } from "../config/format-ddl";
// Hand-written SurrealQL TextMate grammar (source.surql) — passed to Astro's
// <Code> as a custom Shiki language so DDL highlights correctly with the brand
// theme (DEFINE/TYPE/ASSERT as keywords, record/datetime as types,
// string::is_email/time::now as functions, $value as a variable).
import surrealqlGrammar from "../shiki/surrealql.tmLanguage.json";

interface Props {
  /** Slug of the driver this route represents; null = the agnostic /examples. */
  activeDriver?: string | null;
}
const { activeDriver = null } = Astro.props;

// Only the drivers that actually have catalog examples, ordered by the roster.
const driverTabs = drivers.filter((d) =>
  examplesCatalog.some((e) => e.driver === d.slug),
);

// A stable URL/DOM slug for a category name, computed identically for the chip
// and its group section so the client filter can pair them by data-group-slug
// (also what `?group=` carries for shareable links).
function slugifyGroup(group: string): string {
  return group
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

// Group a driver's examples by `group`, preserving first-seen order.
function groupsFor(slug: string): { group: string; items: CatalogExample[] }[] {
  const out: { group: string; items: CatalogExample[] }[] = [];
  for (const ex of examplesCatalog) {
    if (ex.driver !== slug) continue;
    let g = out.find((x) => x.group === ex.group);
    if (!g) {
      g = { group: ex.group, items: [] };
      out.push(g);
    }
    g.items.push(ex);
  }
  return out;
}

// The up-front panes (same shape as the landing): the agnostic "hub" pane renders
// the FLAGSHIP driver's examples; then one pane per driver. The SSR'd page shows
// the pane matching its route — "hub" on /examples, the slug on /<driver>/examples.
const visibleKey = paneKeyFor(activeDriver);
const panes = [
  { key: "hub", slug: flagshipDriver.slug },
  ...driverTabs.map((d) => ({ key: d.slug, slug: d.slug })),
];

// Per-entry DDL language: SurrealQL DDL (lang:"surrealql") uses the vendored
// custom grammar; Postgres DDL (lang:"sql") uses Shiki's built-in `sql`. Astro's
// <Code> accepts a custom grammar object for `lang` (it highlights via
// grammar.name = "surrealql"), so DEFINE/ASSERT/record/etc. no longer mis-color
// as plain SQL. The TS authoring source always renders as "ts".
function ddlLang(lang: string): string | typeof surrealqlGrammar {
  return lang === "surrealql" ? surrealqlGrammar : "sql";
}
// Human-readable dialect label for the per-block badge (the manifest stores the
// lowercase grammar id).
function ddlLabel(lang: string): string {
  return lang === "surrealql" ? "SurrealQL" : "PostgreSQL";
}

// Shared <Code> options so TS + DDL blocks render with identical brand colors.
// `wrap` soft-wraps long lines instead of showing a horizontal scrollbar — paired
// with formatDdl()'s clause reflow, the code columns never scroll sideways.
const codeAttrs = { theme: brandShikiTheme, wrap: true } as const;
---

<Nav activeDriver={activeDriver} />
<main class="mx-auto max-w-6xl px-6 py-12 sm:py-16">
  <!-- header -->
  <header class="max-w-2xl">
    <p
      class="font-mono text-xs font-medium uppercase tracking-[0.18em] text-accent-soft"
    >
      Cookbook
    </p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight text-ink sm:text-5xl">
      Examples
    </h1>
    <p class="mt-4 text-lg leading-relaxed text-ink-2">
      Every example is generated and verified against the live driver — the
      TypeScript you author on the left, the native DDL Schemic emits on the
      right. Switch databases with the picker in the nav, and filter by category
      below.
    </p>
  </header>

  <!-- per-driver galleries — only the active pane is visible; the nav picker
       toggles which (config/picker.ts). Within a pane, the category chips filter
       by `group` (client-side, `?group=` for shareable links). The nav picker is
       still the only DRIVER control — no standalone driver filter. -->
  {
    panes.map((pane) => {
      const grps = groupsFor(pane.slug);
      return (
        <section
          data-driver-pane={pane.key}
          hidden={pane.key !== visibleKey}
          class="mt-12"
        >
          {grps.length > 1 && (
            <div
              data-cat-row
              class="flex flex-wrap gap-2"
              role="group"
              aria-label="Filter examples by category"
            >
              <button
                type="button"
                data-cat-chip
                data-group-slug=""
                aria-pressed="true"
                class="rounded-full border border-border px-3.5 py-1.5 font-mono text-[12px] tracking-tight text-ink-2 transition-colors hover:border-accent hover:text-ink aria-pressed:border-accent aria-pressed:bg-accent aria-pressed:text-on-accent"
              >
                All
              </button>
              {grps.map((grp) => (
                <button
                  type="button"
                  data-cat-chip
                  data-group-slug={slugifyGroup(grp.group)}
                  aria-pressed="false"
                  class="rounded-full border border-border px-3.5 py-1.5 font-mono text-[12px] tracking-tight text-ink-2 transition-colors hover:border-accent hover:text-ink aria-pressed:border-accent aria-pressed:bg-accent aria-pressed:text-on-accent"
                >
                  {grp.group}
                </button>
              ))}
            </div>
          )}
          <div class="mt-8 space-y-10">
            {grps.map((grp) => (
              <div data-group-section data-group-slug={slugifyGroup(grp.group)}>
                <h2 class="text-sm font-semibold uppercase tracking-[0.12em] text-ink-3">
                  {grp.group}
                </h2>
                <div class="mt-5 space-y-6">
              {grp.items.map((ex) => (
                <article class="overflow-hidden rounded-2xl border border-border bg-surface">
                  <div class="border-b border-border-subtle px-5 py-4">
                    <h3 class="text-base font-semibold text-ink">{ex.title}</h3>
                    {ex.note && (
                      <p class="mt-1 text-sm leading-relaxed text-ink-2">
                        {ex.note}
                      </p>
                    )}
                  </div>
                  <div class="grid grid-cols-1 divide-y divide-border-subtle md:grid-cols-2 md:divide-x md:divide-y-0">
                    {/* TS authoring source */}
                    <div class="min-w-0">
                      <div class="flex items-center gap-2 border-b border-border-subtle px-4 py-2.5">
                        <span class="font-mono text-[11px] font-medium uppercase tracking-wide text-ink-3">
                          schema.ts
                        </span>
                        <span class="rounded-full bg-canvas-2 px-2 py-0.5 font-mono text-[10px] text-ink-3">
                          TypeScript
                        </span>
                      </div>
                      <div class="overflow-x-auto p-4 text-sm [&_pre]:!bg-transparent">
                        <Code code={ex.code} lang="ts" {...codeAttrs} />
                      </div>
                    </div>
                    {/* generated DDL */}
                    <div class="min-w-0">
                      <div class="flex items-center gap-2 border-b border-border-subtle px-4 py-2.5">
                        <span class="font-mono text-[11px] font-medium uppercase tracking-wide text-ink-3">
                          Generated
                        </span>
                        <span class="rounded-full bg-canvas-2 px-2 py-0.5 font-mono text-[10px] text-accent-soft">
                          {ddlLabel(ex.lang)}
                        </span>
                      </div>
                      <div class="overflow-x-auto p-4 text-sm [&_pre]:!bg-transparent">
                        <Code code={formatDdl(ex.ddl, ex.lang)} lang={ddlLang(ex.lang)} {...codeAttrs} />
                      </div>
                    </div>
                  </div>
                </article>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>
      );
    })
  }
</main>
<Footer activeDriver={activeDriver} />

<script>
  // Wire the shared database picker (the nav picker is the only control on this
  // page — no Hero here, so initPickers() must run from the gallery). It toggles
  // the [data-driver-pane] galleries + nav links, cross-fades the theme, and
  // pushState-s /examples/<driver> — keeping the Examples section in sync with
  // the landing's switch.
  import { initPickers } from "@schemic/landing/config/picker";
  initPickers();

  // Category (group) filter — a per-pane chip row that filters the visible
  // driver pane's example sections by `group`. Client-side, URL-synced via
  // `?group=<slug>` for shareable deep links. This filters only WITHIN a pane;
  // the nav picker stays the only DRIVER control.
  (() => {
    const panes = Array.from(
      document.querySelectorAll<HTMLElement>("[data-driver-pane]"),
    );
    if (panes.length === 0) return;

    const currentGroup = (): string =>
      new URLSearchParams(location.search).get("group") || "";

    // Apply the active `?group=` to every pane independently: a pane honors the
    // slug only if it HAS that category, else it shows All. Chips reflect the
    // effective selection via aria-pressed; sections hide when filtered out.
    const reconcile = (): void => {
      const want = currentGroup();
      for (const pane of panes) {
        const chips = Array.from(
          pane.querySelectorAll<HTMLElement>("[data-cat-chip]"),
        );
        const eff = chips.some((c) => (c.dataset.groupSlug || "") === want)
          ? want
          : "";
        for (const c of chips)
          c.setAttribute(
            "aria-pressed",
            String((c.dataset.groupSlug || "") === eff),
          );
        for (const sec of pane.querySelectorAll<HTMLElement>(
          "[data-group-section]",
        ))
          sec.hidden = eff !== "" && (sec.dataset.groupSlug || "") !== eff;
      }
    };

    // Chip click: set (or clear) `?group=` WITHOUT a history entry, then re-sync.
    for (const chip of document.querySelectorAll<HTMLElement>(
      "[data-cat-chip]",
    )) {
      chip.addEventListener("click", () => {
        const slug = chip.dataset.groupSlug || "";
        const params = new URLSearchParams(location.search);
        if (slug) params.set("group", slug);
        else params.delete("group");
        const qs = params.toString();
        history.replaceState(
          history.state,
          "",
          location.pathname + (qs ? `?${qs}` : ""),
        );
        reconcile();
      });
    }

    // Re-sync when the active driver pane changes — the nav picker pushState's a
    // new path which strips `?group=`, so the new pane defaults to All — and on
    // back/forward (which restores the pane + any `?group=`).
    document.addEventListener("schemic:driverswitch", reconcile);
    window.addEventListener("popstate", reconcile);

    reconcile(); // honor a deep-linked `?group=` on first paint
  })();
</script>
