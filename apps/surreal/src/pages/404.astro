---
import "@fontsource-variable/geist";
import "@fontsource-variable/jetbrains-mono";
import "../styles/docs.css";
const repo = "https://github.com/schemichq/schemic";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>Page not found | Schemic</title>
    <meta name="robots" content="noindex" />
  </head>
  <body>
    <header class="nav">
      <a class="logo" href="/">Schemic</a>
      <a href={repo} aria-label="GitHub" class="gh">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49l-.01-1.9c-2.78.62-3.37-1.22-3.37-1.22-.46-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.57 2.34 1.12 2.91.85.09-.66.35-1.12.63-1.38-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05a9.4 9.4 0 0 1 2.5-.34c.85 0 1.71.12 2.5.34 1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9l-.01 2.82c0 .27.18.6.69.49A10.26 10.26 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"></path></svg>
      </a>
    </header>

    <main class="stage">
      <p class="code">404</p>
      <h1 class="title">Page not found</h1>
      <p class="desc">
        The page you are looking for does not exist or has moved. Try the docs,
        or head back home.
      </p>
      <div class="actions">
        <a class="btn ghost" href="/introduction">Browse the docs</a>
        <a class="btn primary" href="/">Back home &rarr;</a>
      </div>
    </main>
  </body>
</html>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 28px;
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .logo {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-ink);
    text-decoration: none;
  }
  .gh {
    color: var(--color-ink-2);
    display: inline-flex;
  }
  .gh svg {
    width: 18px;
    height: 18px;
  }
  .stage {
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 16px;
    padding: 40px 24px;
    background:
      radial-gradient(
        55% 50% at 50% 35%,
        color-mix(in oklab, var(--color-purple) 12%, transparent),
        transparent 70%
      );
  }
  .code {
    margin: 0;
    font-size: clamp(4.5rem, 3rem + 8vw, 7rem);
    font-weight: 700;
    line-height: 1;
    color: var(--color-soft);
  }
  .title {
    margin: 0;
    font-size: 1.625rem;
    font-weight: 700;
    color: var(--color-ink);
  }
  .desc {
    margin: 0;
    max-width: 38ch;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-ink-2);
  }
  .actions {
    display: flex;
    gap: 12px;
    margin-top: 8px;
  }
  .btn {
    padding: 9px 16px;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
  }
  .btn.ghost {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-ink-2);
  }
  .btn.primary {
    background: linear-gradient(90deg, var(--color-purple), var(--color-pink));
    color: #fff;
  }
</style>
