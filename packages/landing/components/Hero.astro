---
// schemic.dev hub hero. The database word in the headline is the SOLE database
// picker (a dropdown). It is CROSS-SUBDOMAIN: choosing an AVAILABLE driver
// navigates to that driver's subdomain; a COMING-SOON driver stays in-page and
// surfaces the demo's coming-soon overlay. Per-driver dots use the FIXED brand
// color (independent of the page's active theme); the picker label + glow use
// the theme accent (the hub wears Amber).
import {
  drivers as driverList,
  driverUrl,
  driverTheme,
  isAvailable,
  flagshipDriver,
  findDriver,
  ctaFor,
  SUGGEST_DRIVER_URL,
} from "../config/drivers";

interface Props {
  /** Slug of the driver this site represents; null = agnostic hub. */
  activeDriver?: string | null;
}

const { activeDriver = null } = Astro.props;

// The picker's initially-selected driver: the site's own driver when it
// represents one, otherwise the flagship available driver (the hub default).
const selected = findDriver(activeDriver) ?? flagshipDriver;

const meta = ["TypeScript-first", "Zod-compatible", "MIT"];

const options = driverList.map((d) => ({
  slug: d.slug,
  name: d.name,
  selected: d.slug === selected.slug,
  available: isAvailable(d),
  status: isAvailable(d) ? "Available" : "Coming soon",
  // A driver is navigable when it has its OWN subdomain (`site`), regardless of
  // its availability status — PostgreSQL ships a site while still coming-soon.
  site: d.site,
  href: d.site ? driverUrl(d.slug) : "",
  color: d.color,
  color2: d.color2 ?? d.color,
  // Concrete target palette the island cross-fades :root toward on select.
  theme: driverTheme(d.slug),
}));

// Primary CTA — driver-aware: derived from the site's active driver (flagship
// on the hub). Available drivers get "Start with <name>"; coming-soon drivers
// get an honest, driver-centric CTA pointing at their own subdomain.
const cta = ctaFor(activeDriver);
const chevron = '<path d="m6 9 6 6 6-6"/>';
---

<section class="relative overflow-hidden">
  <!-- ambient glow -->
  <div
    class="pointer-events-none absolute inset-x-0 -top-40 mx-auto h-[640px] max-w-5xl opacity-70 blur-3xl"
    style="background: radial-gradient(closest-side, color-mix(in oklab, var(--color-accent) 26%, transparent), transparent 70%);"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative mx-auto flex max-w-4xl flex-col items-center px-6 pt-24 pb-20 text-center sm:pt-32 sm:pb-28"
  >
    <!-- eyebrow pill -->
    <a
      href="https://github.com/schemichq/schemic"
      class="group inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3.5 py-[7px] font-mono text-xs text-ink-2 backdrop-blur transition-colors hover:border-accent/50 hover:text-ink"
    >
      <span class="size-[7px] rounded-full bg-accent-2" aria-hidden="true"></span>
      Schema as code · any database
    </a>

    <!-- headline (the database name is a dropdown picker) -->
    <h1
      class="mt-7 font-display text-5xl font-semibold leading-[1.12] tracking-tight text-balance text-ink sm:text-6xl lg:text-[4rem]"
    >
      <span class="block">
        Your <span class="relative inline-block align-middle">
          <button
            type="button"
            id="db-picker"
            aria-haspopup="listbox"
            aria-expanded="false"
            aria-label="Choose your database"
            class="group inline-flex items-center gap-2 rounded-2xl border border-accent/40 bg-surface/70 px-3 py-0.5 align-middle shadow-[0_0_24px_-6px_var(--color-accent)] transition-colors hover:border-accent/70"
          >
            <span
              id="db-label"
              class="bg-gradient-to-r from-accent to-accent-2 bg-clip-text text-transparent"
              >{selected.name}</span
            >
            <svg
              class="size-[0.6em] text-accent-soft transition-transform group-aria-expanded:rotate-180"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={chevron}
            />
          </button>

          <!-- roster menu (hidden until PASS 2 JS) -->
          <div
            id="db-menu"
            role="listbox"
            aria-label="Databases"
            hidden
            class="absolute left-1/2 top-full z-30 mt-3 w-72 -translate-x-1/2 rounded-2xl border border-border bg-canvas-2/95 p-1.5 text-left shadow-2xl backdrop-blur"
          >
            {
              options.map((d) => (
                <div
                  role="option"
                  aria-selected={d.selected}
                  tabindex={d.selected ? 0 : -1}
                  data-driver={d.name}
                  data-slug={d.slug}
                  data-available={d.available ? "true" : "false"}
                  data-site={d.site ? "true" : "false"}
                  data-href={d.href}
                  data-accent={d.color}
                  data-theme-accent={d.theme.accent}
                  data-theme-accent2={d.theme.accent2}
                  data-theme-canvas={d.theme.canvas}
                  data-theme-canvas2={d.theme.canvas2}
                  data-theme-surface={d.theme.surface}
                  data-theme-ink={d.theme.ink}
                  class="flex cursor-pointer items-center justify-between rounded-xl px-3 py-2 font-sans text-sm text-ink-2 outline-none transition-colors hover:bg-white/[0.05] focus-visible:bg-white/[0.07] aria-selected:text-ink"
                >
                  <span class="flex items-center gap-2.5">
                    {/* per-driver dot uses the FIXED brand color, not the theme accent */}
                    <span
                      class="size-2.5 rounded-full"
                      style={
                        d.available
                          ? `background:linear-gradient(135deg, ${d.color}, ${d.color2})`
                          : `background:${d.color}`
                      }
                      aria-hidden="true"
                    />
                    <span class="font-medium">{d.name}</span>
                  </span>
                  <span
                    class:list={[
                      "rounded-full px-2 py-0.5 font-mono text-[10px] tracking-wide",
                      d.available
                        ? "bg-success/15 text-success"
                        : "bg-surface-2 text-ink-3",
                    ]}
                  >
                    {d.status}
                  </span>
                </div>
              ))
            }

            <!-- suggest a database (community demand tracking) -->
            <div class="mx-1 my-1 h-px bg-border/60" aria-hidden="true"></div>
            <a
              id="db-suggest"
              href={SUGGEST_DRIVER_URL}
              target="_blank"
              rel="noopener noreferrer"
              tabindex="-1"
              class="group/suggest flex items-center justify-between gap-2 rounded-xl px-3 py-2 font-sans text-[13px] font-medium text-ink-2 outline-none transition-colors hover:bg-white/[0.05] hover:text-ink focus-visible:bg-white/[0.07] focus-visible:text-ink"
            >
              <span>Don't see your database? Suggest one</span>
              <span
                class="text-accent-soft transition-transform group-hover/suggest:translate-x-0.5"
                aria-hidden="true">&rarr;</span
              >
            </a>
          </div>
        </span> schema,
      </span>
      <span class="block">in the Zod you already know.</span>
    </h1>

    <!-- subhead -->
    <p class="mt-6 max-w-2xl text-lg text-ink-2 text-pretty sm:text-xl">
      Define your schema with <code
        class="rounded-md bg-surface-2 px-1.5 py-0.5 font-mono text-[0.9em] text-code-keyword"
        >s.*</code
      > — a drop-in for Zod. Schemic generates your database's native DDL,
      validates at runtime, and runs your migrations.
    </p>

    <!-- CTAs -->
    <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
      <a
        href={cta.primary.href}
        class="rounded-full bg-gradient-to-r from-accent to-accent-2 px-7 py-3.5 text-[15px] font-semibold text-white shadow-[0_8px_26px_0_color-mix(in_oklab,var(--color-accent)_33%,transparent)] transition-transform hover:scale-[1.03]"
      >
        {cta.primary.label}
      </a>
      <a
        href="https://github.com/schemichq/schemic"
        class="inline-flex items-center gap-2 rounded-full px-3 py-3.5 text-[15px] font-medium text-ink transition-colors hover:text-white"
      >
        <svg
          class="size-4"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.54-3.88-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.41-5.25 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"
          ></path>
        </svg>
        View on GitHub
      </a>
    </div>

    <!-- meta line -->
    <p
      class="mt-10 flex items-center gap-2 font-mono text-xs tracking-wide text-ink-3"
    >
      {
        meta.map((item, i) => (
          <>
            {i > 0 && <span class="text-border" aria-hidden="true">·</span>}
            <span>{item}</span>
          </>
        ))
      }
    </p>
  </div>
</section>

<script>
  // Database-switcher dropdown — the sole DB picker. Selecting a driver updates
  // the headline label and broadcasts `schemic:driver` so the Demo reflects it.
  const picker = document.getElementById("db-picker");
  const menu = document.getElementById("db-menu");
  const label = document.getElementById("db-label");

  if (picker && menu && label) {
    const options = Array.from(
      menu.querySelectorAll<HTMLElement>('[role="option"]'),
    );
    const suggest = menu.querySelector<HTMLAnchorElement>("#db-suggest");
    // Navigable sequence = driver options + the "suggest a database" link.
    const items: HTMLElement[] = suggest ? [...options, suggest] : options;
    let open = false;
    let active = Math.max(
      0,
      options.findIndex((o) => o.getAttribute("aria-selected") === "true"),
    );

    const setActive = (i: number) => {
      active = (i + items.length) % items.length;
      items.forEach((o, idx) =>
        o.setAttribute("tabindex", idx === active ? "0" : "-1"),
      );
      items[active].focus();
    };

    const openMenu = () => {
      open = true;
      menu.hidden = false;
      picker.setAttribute("aria-expanded", "true");
      setActive(active);
    };

    const closeMenu = (focusTrigger = true) => {
      open = false;
      menu.hidden = true;
      picker.setAttribute("aria-expanded", "false");
      if (focusTrigger) picker.focus();
    };

    // Honour prefers-reduced-motion: skip the cross-fade entirely (site drivers
    // redirect at once; non-site drivers just set state). Read live so a
    // mid-session OS toggle is respected.
    const reduceMotion = () =>
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const root = document.documentElement;
    const TRANSITION_MS = 600;

    // Cross-fade the themeable :root color tokens toward `vars`. Registered as
    // typed <color> @property (see landing.css), so assigning them animates
    // every dependent var() — body canvas, accents, gradients, ink — at once.
    const applyTheme = (
      vars: Record<string, string>,
      animate: boolean,
    ): void => {
      if (animate) {
        root.setAttribute("data-theme-shift", "");
        // Flush a style recalc so the transition is armed BEFORE the values
        // change — guaranteeing the cross-fade fires rather than snapping.
        void root.offsetWidth;
      } else {
        root.removeAttribute("data-theme-shift");
      }
      for (const [prop, value] of Object.entries(vars)) {
        if (value) root.style.setProperty(prop, value);
      }
    };

    const themeVars = (opt: HTMLElement): Record<string, string> => ({
      "--color-accent": opt.getAttribute("data-theme-accent") || "",
      "--color-accent-2": opt.getAttribute("data-theme-accent2") || "",
      "--color-canvas": opt.getAttribute("data-theme-canvas") || "",
      "--color-canvas-2": opt.getAttribute("data-theme-canvas2") || "",
      "--color-surface": opt.getAttribute("data-theme-surface") || "",
      "--color-ink": opt.getAttribute("data-theme-ink") || "",
    });

    const select = (opt: HTMLElement) => {
      const hasSite = opt.getAttribute("data-site") === "true";
      const available = opt.getAttribute("data-available") === "true";
      const href = opt.getAttribute("data-href") || "";
      const name = opt.getAttribute("data-driver") || "SurrealDB";

      options.forEach((o) =>
        o.setAttribute("aria-selected", String(o === opt)),
      );
      label.textContent = name;

      // Driver WITH its own subdomain -> shift the page toward that driver's
      // palette, then navigate so the destination (already in-theme) feels
      // continuous. Reduced motion: redirect immediately.
      if (hasSite && href) {
        closeMenu(false);
        if (reduceMotion()) {
          window.location.href = href;
          return;
        }
        applyTheme(themeVars(opt), true);
        window.setTimeout(() => {
          window.location.href = href;
        }, TRANSITION_MS);
        return;
      }

      // Driver WITHOUT a site (no page yet) -> stay in-page: animate the accent
      // toward its brand color and surface the Demo's coming-soon overlay so the
      // selection clearly does something. The shift persists (no redirect).
      const animate = !reduceMotion();
      applyTheme(
        {
          "--color-accent": opt.getAttribute("data-theme-accent") || "",
          "--color-accent-2": opt.getAttribute("data-theme-accent2") || "",
        },
        animate,
      );
      if (animate)
        window.setTimeout(
          () => root.removeAttribute("data-theme-shift"),
          TRANSITION_MS,
        );
      document.dispatchEvent(
        new CustomEvent("schemic:driver", {
          detail: {
            name,
            available,
            accent: opt.getAttribute("data-accent") || "",
          },
        }),
      );
      closeMenu();
    };

    picker.addEventListener("click", () => (open ? closeMenu() : openMenu()));
    picker.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown" || e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        openMenu();
      }
    });

    menu.addEventListener("keydown", (e) => {
      switch (e.key) {
        case "Escape":
          e.preventDefault();
          closeMenu();
          break;
        case "ArrowDown":
          e.preventDefault();
          setActive(active + 1);
          break;
        case "ArrowUp":
          e.preventDefault();
          setActive(active - 1);
          break;
        case "Home":
          e.preventDefault();
          setActive(0);
          break;
        case "End":
          e.preventDefault();
          setActive(items.length - 1);
          break;
        case "Enter":
        case " ":
          e.preventDefault();
          if (items[active] instanceof HTMLAnchorElement)
            items[active].click();
          else select(items[active]);
          break;
        case "Tab":
          closeMenu(false);
          break;
      }
    });

    options.forEach((o, i) => {
      o.addEventListener("click", () => select(o));
      o.addEventListener("mousemove", () => {
        if (active !== i) setActive(i);
      });
    });

    // The suggest link navigates natively on click; sync hover-active state.
    if (suggest) {
      suggest.addEventListener("mousemove", () => {
        const i = items.indexOf(suggest);
        if (active !== i) setActive(i);
      });
    }

    document.addEventListener("click", (e) => {
      if (
        open &&
        e.target instanceof Node &&
        !menu.contains(e.target) &&
        !picker.contains(e.target)
      )
        closeMenu(false);
    });
  }
</script>
