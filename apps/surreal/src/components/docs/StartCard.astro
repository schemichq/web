---
/**
 * StartCard - a linked CTA card. The "primary" variant is tinted with an accent
 * border (an arrow-right), "secondary" is a plain surface card (arrow-up-right).
 * Matches the "Start here" row in the Introduction frame.
 */
interface Props {
  title: string;
  href: string;
  variant?: "primary" | "secondary";
}
const { title, href, variant = "secondary" } = Astro.props;

const arrows = {
  primary: '<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>',
  secondary: '<path d="M7 7h10v10"/><path d="M7 17 17 7"/>',
};
const arrow = variant === "primary" ? arrows.primary : arrows.secondary;
---

<a class:list={["start-card", variant]} href={href}>
  <span class="sc-head">
    <span class="sc-title">{title}</span>
    <svg
      class="sc-arrow"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      set:html={arrow}
    />
  </span>
  <span class="sc-desc"><slot /></span>
</a>

<style>
  .start-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    border-radius: 12px;
    text-decoration: none;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    transition:
      border-color 0.15s ease,
      transform 0.15s ease;
  }
  .start-card.primary {
    background: color-mix(in oklab, var(--color-purple) 9%, transparent);
    border-color: var(--color-purple);
  }
  .start-card:hover {
    transform: translateY(-1px);
    border-color: var(--color-soft);
  }
  .sc-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .sc-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-ink);
  }
  .sc-arrow {
    width: 16px;
    height: 16px;
    color: var(--color-soft);
  }
  .sc-desc {
    font-size: 0.84rem;
    line-height: 1.5;
    color: var(--color-ink-2);
  }
</style>
