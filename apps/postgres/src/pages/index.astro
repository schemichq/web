---
// postgres.schemic.dev — the PostgreSQL driver site. The driver is in the works,
// so the site renders the shared @schemic/landing themed for Postgres (blue)
// with activeDriver="postgres": the hero's database picker shows PostgreSQL
// selected, the demo opens in its COMING-SOON state (overlay pointing at the
// shipped flagship driver), and the picker still offers cross-subdomain nav.
import HubLanding from "@schemic/landing/HubLanding.astro";
import Landing from "../layouts/Landing.astro";
---

<Landing>
  <HubLanding activeDriver="postgres" />
</Landing>
