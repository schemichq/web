---
import {
  drivers as driverList,
  driverUrl,
  findDriver,
  paneStates,
  paneKeyFor,
  SUGGEST_DRIVER_URL,
} from "../config/drivers";
import DbMenu from "./DbMenu.astro";

interface Props {
  /** Slug of the driver this site represents; null = agnostic hub. */
  activeDriver?: string | null;
}
const { activeDriver = null } = Astro.props;

// Compact nav picker — persistent while scrolling (the nav is sticky). On the
// agnostic hub no driver is selected: it shows a "Select database" prompt; on a
// driver subdomain it shows that driver's name + brand dot. Shares the roster +
// select behavior with the hero picker (config/picker.ts wires both).
const isHub = activeDriver == null;
const navDriver = findDriver(activeDriver);

// Driver-specific nav links resolve to the ACTIVE driver. Each is rendered as a
// `[data-driver-pane]` variant (like the hero CTAs) so the client-side picker
// switch keeps it pointed at the current driver with NO reload. On the agnostic
// hub (no driver) they OPEN the hero picker (`data-open-picker`) instead of
// pointing at a wrong/dead driver link. Non-driver links (the brand, and
// "Drivers" → the hub home) stay static.
const activeKey = paneKeyFor(activeDriver);
const linkStates = paneStates.map((s) => ({
  key: s.key,
  hidden: s.key !== activeKey,
  docs: s.slug ? `${driverUrl(s.slug)}/docs/introduction` : null,
  start: s.slug ? driverUrl(s.slug) : null,
}));
---

<header
  class="sticky top-0 z-50 bg-canvas/70 backdrop-blur-md"
>
  <nav
    class="mx-auto grid h-16 max-w-6xl grid-cols-[1fr_auto_1fr] items-center px-6"
    aria-label="Primary"
  >
    <!-- left: brand -->
    <a href="/" class="mr-3 flex items-center gap-2.5 justify-self-start sm:mr-0">
      <span
        class="grid size-8 place-items-center rounded-xl bg-gradient-to-br from-accent to-accent-2 text-[13px] font-bold text-on-accent shadow-[0_0_20px_-4px_var(--color-accent)]"
        aria-hidden="true">S</span
      >
      <span class="font-mono text-[15px] font-medium tracking-tight text-ink"
        >Schemic</span
      >
    </a>

    <!-- center: nav links -->
    <div class="hidden items-center gap-8 justify-self-center md:flex">
      {/* Docs — resolves to the ACTIVE driver's docs; on the hub it opens the
          hero picker so the visitor chooses a database first. */}
      {
        linkStates.map((st) =>
          st.docs ? (
            <a
              href={st.docs}
              data-driver-pane={st.key}
              hidden={st.hidden}
              class="text-sm text-ink-2 transition-colors hover:text-ink"
            >
              Docs
            </a>
          ) : (
            <button
              type="button"
              data-open-picker
              data-driver-pane={st.key}
              hidden={st.hidden}
              class="text-sm text-ink-2 transition-colors hover:text-ink"
            >
              Docs
            </button>
          ),
        )
      }
      {/* Neutral, not driver-specific: the agnostic hub home. */}
      <a
        href="/"
        class="text-sm text-ink-2 transition-colors hover:text-ink"
      >
        Drivers
      </a>
    </div>

    <!-- right: actions -->
    <div class="flex items-center gap-3 justify-self-end sm:gap-5">
      <!--
        Compact database picker — sticky/persistent while scrolling. Shares the
        roster + select/theme/redirect behavior with the hero picker.
      -->
      <div data-db-picker="nav" class="relative">
        <button
          type="button"
          data-db-trigger
          data-db-prompt={isHub ? "" : null}
          aria-haspopup="listbox"
          aria-expanded="false"
          aria-label="Choose your database"
          class:list={[
            "group inline-flex items-center gap-2 rounded-full border bg-surface px-3 py-1.5 text-sm transition-colors",
            isHub
              ? "border-dashed border-accent/60 text-accent-soft hover:border-accent hover:text-ink"
              : "border-border text-ink-2 hover:border-accent/50 hover:text-ink",
          ]}
        >
          <span
            data-db-dot
            hidden={isHub || !navDriver}
            class="size-2.5 rounded-full"
            style={navDriver ? `background:${navDriver.color}` : ""}
            aria-hidden="true"
          />
          <span data-db-label data-db-prompt-label="Select database"
            >{navDriver?.name ?? "Select database"}</span
          >
          <svg
            class="size-3.5 text-accent-soft transition-transform group-aria-expanded:rotate-180"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg
          >
        </button>

        <DbMenu
          drivers={driverList}
          selectedSlug={navDriver?.slug ?? null}
          suggestHref={SUGGEST_DRIVER_URL}
          align="right"
        />
      </div>
      <!-- Get started — driver-dynamic (resolves to the ACTIVE driver's site);
           on the hub it opens the hero picker. Rendered as `[data-driver-pane]`
           variants so the client-side switch keeps it on the current driver. -->
      {
        linkStates.map((st) =>
          st.start ? (
            <a
              href={st.start}
              data-driver-pane={st.key}
              hidden={st.hidden}
              class="rounded-full bg-ink px-4 py-2 text-sm font-semibold text-canvas transition-colors hover:bg-white"
            >
              Get started
            </a>
          ) : (
            <button
              type="button"
              data-open-picker
              data-driver-pane={st.key}
              hidden={st.hidden}
              class="rounded-full bg-ink px-4 py-2 text-sm font-semibold text-canvas transition-colors hover:bg-white"
            >
              Get started
            </button>
          ),
        )
      }
    </div>
  </nav>
</header>

<script>
  // Single star-count island for the whole page. Fetches the cached worker once
  // on load and, ONLY if it returns a finite numeric `stars`, fills every
  // [data-gh-count] slot (Nav + Hero) and reveals their [data-gh-star-count]
  // chips. On any failure (network, non-OK, null, non-numeric) it does nothing —
  // the buttons stay plain "GitHub" with no count and no reserved gap. SSR-safe
  // and no-JS-safe: the markup is a plain repo link until this runs.
  import { GITHUB_STARS_ENDPOINT } from "../config/github";

  const formatStars = (n: number): string => {
    if (n < 1000) return String(n);
    const k = n / 1000;
    const rounded = k >= 100 ? Math.round(k) : Math.round(k * 10) / 10;
    return `${rounded}k`;
  };

  const loadStars = async (): Promise<void> => {
    const slots = document.querySelectorAll<HTMLElement>("[data-gh-count]");
    if (slots.length === 0) return;
    try {
      const res = await fetch(GITHUB_STARS_ENDPOINT, {
        headers: { accept: "application/json" },
      });
      if (!res.ok) return;
      const data = (await res.json()) as { stars?: number | null };
      const stars = data?.stars;
      if (typeof stars !== "number" || !Number.isFinite(stars)) return;

      const text = formatStars(stars);
      slots.forEach((slot) => {
        slot.textContent = text;
      });
      document
        .querySelectorAll<HTMLElement>("[data-gh-star-count]")
        .forEach((chip) => {
          chip.hidden = false;
        });
    } catch {
      // Graceful: leave the buttons as plain GitHub links.
    }
  };

  void loadStars();
</script>
