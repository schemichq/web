---
/**
 * Step - a numbered step (accent circle) with a title and slotted body.
 * Matches the Getting started flow in design/website.pen.
 */
interface Props {
  n: number;
  id: string;
  title: string;
}
const { n, id, title } = Astro.props;
---

<div class="step">
  <div class="num" aria-hidden="true">{n}</div>
  <div class="body">
    <h2 id={id} class="step-title">{title}</h2>
    <slot />
  </div>
</div>

<style>
  .step {
    display: flex;
    gap: 18px;
    align-items: flex-start;
  }
  .num {
    flex-shrink: 0;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: color-mix(in oklab, var(--color-purple) 15%, transparent);
    border: 1px solid var(--color-purple);
    color: var(--color-soft);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 700;
  }
  .body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .step-title {
    margin: 3px 0 0;
    font-size: 1.1875rem;
    font-weight: 600;
    color: var(--color-ink);
    scroll-margin-top: 5rem;
  }
  .body :global(p) {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-ink-2);
  }
</style>
