---
// schemic.dev/examples — the agnostic verified cookbook gallery.
//
// Mirrors the landing's single-origin model: this is the agnostic entry (neutral
// theme, picker shows the "Database" prompt) and shows the FLAGSHIP examples as
// reference content. Selecting a driver in the nav picker switches CLIENT-SIDE to
// /examples/<driver> (no reload); the themed driver routes are emitted by
// examples/[driver].astro. See components/ExamplesGallery.astro.
import Landing from "../layouts/Landing.astro";
import ExamplesGallery from "../components/ExamplesGallery.astro";
---

<Landing
  title="Examples — Schemic"
  description="A verified cookbook of Schemic examples: TypeScript schema authoring and the native DDL it generates, for SurrealDB and PostgreSQL."
>
  <ExamplesGallery activeDriver={null} />
</Landing>
