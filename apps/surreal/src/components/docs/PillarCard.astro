---
/**
 * PillarCard - a surface card with a tinted icon chip, title and body.
 * Matches the "Introduction" pillar grid in design/website.pen.
 * Icons are inline Lucide paths (stroke = currentColor).
 */
interface Props {
  icon: string;
  title: string;
}
const { icon, title } = Astro.props;

const icons: Record<string, string> = {
  layers:
    '<path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>',
  database:
    '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/>',
  "shield-check":
    '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/>',
  terminal: '<path d="m4 17 6-6-6-6"/><path d="M12 19h8"/>',
  puzzle:
    '<path d="M15.39 4.39a1 1 0 0 0 1.68-.474 2.5 2.5 0 1 1 3.014 3.015 1 1 0 0 0-.474 1.68l1.683 1.682a2.414 2.414 0 0 1 0 3.414L19.61 15.39a1 1 0 0 1-1.68-.474 2.5 2.5 0 1 0-3.014 3.015 1 1 0 0 1 .474 1.68l-1.683 1.682a2.414 2.414 0 0 1-3.414 0L8.61 19.61a1 1 0 0 0-1.68.474 2.5 2.5 0 1 1-3.014-3.015 1 1 0 0 0 .474-1.68l-1.683-1.682a2.414 2.414 0 0 1 0-3.414L4.39 8.61a1 1 0 0 1 1.68.474 2.5 2.5 0 1 0 3.014-3.015 1 1 0 0 1-.474-1.68l1.683-1.682a2.414 2.414 0 0 1 3.414 0z"/>',
  "git-compare":
    '<circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 0 1 2 2v7"/><path d="M11 18H8a2 2 0 0 1-2-2V9"/>',
};
const svg = icons[icon] ?? "";
---

<div class="pillar">
  <span class="chip">
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      set:html={svg}
    />
  </span>
  <h3>{title}</h3>
  <p><slot /></p>
</div>

<style>
  .pillar {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 1.125rem;
    border-radius: 12px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }
  .chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background: color-mix(in oklab, var(--color-purple) 12%, transparent);
  }
  .chip svg {
    width: 17px;
    height: 17px;
    color: var(--color-soft);
  }
  .pillar h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ink);
  }
  .pillar p {
    margin: 0;
    font-size: 0.84rem;
    line-height: 1.55;
    color: var(--color-ink-3);
  }
  .pillar :global(code) {
    font-size: 0.8em;
    color: var(--color-ink-2);
    background: var(--color-surface-2);
    padding: 0.1em 0.35em;
    border-radius: 5px;
  }
</style>
