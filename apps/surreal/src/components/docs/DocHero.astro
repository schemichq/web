---
/**
 * DocHero - branded page header matching the Pencil "Introduction" frame:
 * an accent kicker, a large headline, and a muted lead. Hides Starlight's
 * default page title (rendered as h1#_top) on pages where this is used, so the
 * headline reads as the single dominant title.
 */
interface Props {
  kicker?: string;
}
const { kicker } = Astro.props;
---

<header class="doc-hero">
  {kicker && <p class="kicker">{kicker}</p>}
  <h1 class="hero-title"><slot /></h1>
  <p class="hero-lead"><slot name="lead" /></p>
</header>

<style>
  .doc-hero {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-block-end: 2.25rem;
  }
  .kicker {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-soft);
  }
  .hero-title {
    margin: 0;
    font-size: clamp(2rem, 1.4rem + 2vw, 2.75rem);
    line-height: 1.1;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }
  .hero-lead {
    margin: 0;
    max-width: 46ch;
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-ink-2);
  }
</style>
