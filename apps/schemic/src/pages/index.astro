---
// schemic.dev — the agnostic library hub. Renders the shared @schemic/landing
// with no active driver (activeDriver={null}): the hero's database picker
// defaults to the flagship driver and offers cross-subdomain navigation, and
// the demo shows the live schema -> DDL flow. The hub wears the Neutral theme
// (imported by its Landing layout's stylesheet).
import HubLanding from "@schemic/landing/HubLanding.astro";
import Landing from "../layouts/Landing.astro";
---

<Landing>
  <HubLanding activeDriver={null} />
</Landing>
