---
/** MappingTable - s.* to SurrealQL TYPE with a support status dot + notes. */
type Status = "ok" | "partial" | "gap";
interface Row {
  sz: string;
  type: string;
  status: Status;
  notes?: string;
}
interface Props {
  rows: Row[];
}
const { rows } = Astro.props;
const label: Record<Status, string> = {
  ok: "OK",
  partial: "Partial",
  gap: "Gap",
};
---

<div class="legend">
  <span class="leg"><span class="dot ok"></span>Supported</span>
  <span class="leg"><span class="dot partial"></span>Partial / lossy</span>
  <span class="leg"><span class="dot gap"></span>Schema-layer gap</span>
</div>

<div class="table">
  <div class="row is-head">
    <span class="c1">s.*</span>
    <span class="c2">SurrealQL TYPE</span>
    <span class="c3">STATUS</span>
    <span class="c4">NOTES</span>
  </div>
  {
    rows.map((r) => (
      <div class="row">
        <span class="c1 mono sz">{r.sz}</span>
        <span class="c2 mono type">{r.type}</span>
        <span class="c3">
          <span class:list={["dot", r.status]} />
          {label[r.status]}
        </span>
        <span class="c4">{r.notes}</span>
      </div>
    ))
  }
</div>

<style>
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin: 0.5rem 0 1.25rem;
  }
  .leg {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 0.8rem;
    color: var(--color-ink-2);
  }
  .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot.ok {
    background: var(--color-success);
  }
  .dot.partial {
    background: #f5c14e;
  }
  .dot.gap {
    background: var(--color-danger);
  }
  .table {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: clip;
  }
  .row {
    display: grid;
    grid-template-columns: 230px 200px 110px 1fr;
    align-items: center;
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .row:last-child {
    border-bottom: 0;
  }
  .row > span {
    padding: 8px 16px;
  }
  .row.is-head {
    background: var(--color-surface);
  }
  .row.is-head span {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-ink-3);
  }
  .c3 {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 0.8rem;
    color: var(--color-ink-2);
  }
  .mono {
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .sz {
    color: var(--color-pink);
  }
  .type {
    color: var(--color-code-type);
  }
  .c4 {
    font-size: 0.8rem;
    color: var(--color-ink-3);
  }
  @media (max-width: 50rem) {
    .row {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
