---
const href = "/docs/reference/cli";
---

<a
  href={href}
  class="group block border-b border-border-subtle bg-canvas-2/60"
>
  <div
    class="mx-auto flex max-w-6xl items-center justify-center gap-3 px-6 py-2.5 text-center text-sm"
  >
    <span
      class="rounded-full bg-gradient-to-r from-purple to-hot px-2 py-0.5 text-[11px] font-bold tracking-wide text-white"
      >NEW</span
    >
    <span class="text-ink-2">
      the schemic CLI — generate &amp; apply SurrealQL migrations straight from your
      Zod schema
    </span>
    <span
      class="text-pink transition-transform group-hover:translate-x-0.5"
      aria-hidden="true">&rarr;</span
    >
  </div>
</a>
