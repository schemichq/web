---
const meta = ["v1.0.0", "MIT", "TypeScript-first"];
---

<section class="relative overflow-hidden">
  <!-- ambient glow -->
  <div
    class="pointer-events-none absolute inset-x-0 -top-40 mx-auto h-[640px] max-w-5xl opacity-70 blur-3xl"
    style="background: radial-gradient(closest-side, color-mix(in oklab, var(--color-purple) 26%, transparent), transparent 70%);"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative mx-auto flex max-w-4xl flex-col items-center px-6 pt-24 pb-20 text-center sm:pt-32 sm:pb-28"
  >
    <!-- eyebrow pill -->
    <a
      href="https://github.com/schemichq/schemic"
      class="group inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3.5 py-[7px] font-mono text-xs text-ink-2 backdrop-blur transition-colors hover:border-purple/50 hover:text-ink"
    >
      <span
        class="size-[7px] rounded-full bg-pink"
        aria-hidden="true"></span>
      Zod for SurrealDB
    </a>

    <!-- headline -->
    <h1
      class="mt-7 font-display text-5xl font-semibold leading-[1.05] tracking-tight text-balance text-ink sm:text-6xl lg:text-[4rem]"
    >
      <span class="block"
        >Your <span
          class="bg-gradient-to-r from-purple to-pink bg-clip-text text-transparent"
          >SurrealDB</span
        > schema,</span
      >
      <span class="block">in the Zod you already know.</span>
    </h1>

    <!-- subhead -->
    <p class="mt-6 max-w-2xl text-lg text-ink-2 text-pretty sm:text-xl">
      Define your schema with <code
        class="rounded-md bg-surface-2 px-1.5 py-0.5 font-mono text-[0.9em] text-code-keyword"
        >s.*</code
      > — Schemic generates the SurrealQL DDL and runs your migrations.
    </p>

    <!-- CTAs -->
    <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
      <a
        href="/docs/quickstart"
        class="rounded-full bg-gradient-to-r from-purple to-pink px-7 py-3.5 text-[15px] font-semibold text-white shadow-[0_8px_26px_0_#9600ff55] transition-transform hover:scale-[1.03]"
      >
        Get started
      </a>
      <a
        href="https://github.com/schemichq/schemic"
        class="inline-flex items-center gap-2 rounded-full px-3 py-3.5 text-[15px] font-medium text-ink transition-colors hover:text-white"
      >
        <svg
          class="size-4"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.54-3.88-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.41-5.25 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"
          ></path>
        </svg>
        GitHub
      </a>
    </div>

    <!-- meta line -->
    <p
      class="mt-10 flex items-center gap-2 font-mono text-xs tracking-wide text-ink-3"
    >
      {
        meta.map((item, i) => (
          <>
            {i > 0 && <span class="text-border" aria-hidden="true">·</span>}
            <span>{item}</span>
          </>
        ))
      }
    </p>
  </div>
</section>
