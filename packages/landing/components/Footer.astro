---
import { drivers, driverUrl, flagshipDriver } from "../config/drivers";
import BrandMark from "./BrandMark.astro";

interface Props {
  /** Slug of the driver this site represents; null = agnostic hub. */
  activeDriver?: string | null;
}
const { activeDriver = null } = Astro.props;
// The Ambassador credit ties to one driver, so it only shows on that driver's
// site; the agnostic hub (and other drivers) drop it.
const showAmbassador = activeDriver === "surrealdb";

const repo = "https://github.com/schemichq/schemic";
// NOTE (IA TBD): docs live on the per-driver subdomains, not the hub; pointing
// at the shipped flagship driver for now.
const surreal = driverUrl(flagshipDriver.slug);

const columns: { heading: string; links: { label: string; href: string }[] }[] = [
  {
    heading: "Product",
    links: [
      { label: "Docs", href: `${surreal}/docs/introduction` },
      { label: "Changelog", href: `${surreal}/docs/resources/changelog` },
      { label: "GitHub", href: repo },
    ],
  },
  {
    heading: "Databases",
    // Derived from the shared roster so the footer stays in lockstep with the
    // picker; a driver links to its subdomain once it ships a site.
    links: drivers.map((d) => ({
      label: d.name,
      href: d.site ? driverUrl(d.slug) : "#",
    })),
  },
  {
    heading: "Community",
    links: [
      { label: "GitHub", href: repo },
      { label: "Discord", href: "https://surrealdb.com/discord" },
      { label: "Issues", href: `${repo}/issues` },
      { label: "Sponsor", href: `${repo}?sponsor=1` },
    ],
  },
];

const award =
  '<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>';
---

<footer class="bg-canvas-2">
  <!-- columns -->
  <div
    class="mx-auto flex max-w-6xl flex-col gap-10 px-6 py-12 md:flex-row md:justify-between"
  >
    <!-- brand -->
    <div class="max-w-xs">
      <a href="/" class="flex items-center gap-2.5">
        <BrandMark class="size-8" />
        <span class="font-mono lowercase text-[15px] font-medium tracking-tight text-ink"
          >schemic</span
        >
      </a>
      <p class="mt-3.5 max-w-[260px] text-[13px] leading-relaxed text-ink-3">
        Schema as code, for any database. One typed source of truth — native
        DDL, migrations, and types.
      </p>
    </div>

    <!-- link columns -->
    <div class="grid grid-cols-2 gap-8 sm:grid-cols-3 sm:gap-14">
      {
        columns.map((col) => (
          <nav class="flex flex-col gap-3">
            <p class="font-display text-[13px] font-semibold text-ink">
              {col.heading}
            </p>
            {col.links.map((link) => (
              <a
                href={link.href}
                class="text-sm text-ink-2 transition-colors hover:text-ink"
              >
                {link.label}
              </a>
            ))}
          </nav>
        ))
      }
    </div>
  </div>

  <!-- meta bar -->
  <div class="border-t border-border-subtle">
    <div
      class="mx-auto flex max-w-6xl flex-col items-center gap-3 px-6 py-4 text-center sm:flex-row sm:justify-between sm:text-left"
    >
      <span class="text-[13px] text-ink-3">MIT License © 2026 Schemic</span>
      {
        showAmbassador && (
          <span class="flex items-center gap-1.5 text-[13px] text-ink-3">
            <svg
              class="size-3.5 text-accent-2"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={award}
            />
            Built by a SurrealDB Ambassador
          </span>
        )
      }
      <span class="font-mono text-xs text-ink-3">SurrealDB live · Postgres live · Zod 4</span>
    </div>
  </div>
</footer>
