---
import "@fontsource-variable/geist";
import "@fontsource-variable/jetbrains-mono";
import "../styles/landing.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Schemic — Schema as code, for any database",
  description =
    "Define your database schema once in TypeScript with s.* — a drop-in for Zod. Schemic generates your database's native DDL, validates at runtime, and manages migrations. SurrealDB today; Postgres, MySQL & more on the way.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body class="min-h-screen bg-canvas text-ink antialiased">
    <slot />
  </body>
</html>
