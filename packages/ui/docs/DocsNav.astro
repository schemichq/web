---
import type { NavItem } from "@schemic/content/nav";

interface Props {
  topNav: NavItem[];
  topActive?: string;
}
const { topNav, topActive } = Astro.props;
const repo = "https://github.com/schemichq/schemic";
---

<header class="nav">
  <div class="nav-inner">
    <div class="nav-left">
      <a class="logo" href="/">Schemic</a>
      <nav class="links" aria-label="Primary">
        {
          topNav.map((item) => (
            <a
              href={item.href}
              class:list={["link", { active: item.label === topActive }]}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>
    <div class="nav-right">
      <button class="search" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
        <span>Search docs</span>
        <kbd>/</kbd>
      </button>
      <a class="icon-link" href={repo} aria-label="GitHub">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49l-.01-1.9c-2.78.62-3.37-1.22-3.37-1.22-.46-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.57 2.34 1.12 2.91.85.09-.66.35-1.12.63-1.38-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05a9.4 9.4 0 0 1 2.5-.34c.85 0 1.71.12 2.5.34 1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9l-.01 2.82c0 .27.18.6.69.49A10.26 10.26 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"></path></svg>
      </a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 30;
    background: color-mix(in oklab, var(--color-canvas) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
  }
  .nav-inner {
    max-width: 1320px;
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 13px 28px;
  }
  .nav-left {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .logo {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-ink);
    text-decoration: none;
  }
  .links {
    display: flex;
    align-items: center;
    gap: 22px;
  }
  .link {
    font-size: 0.85rem;
    color: var(--color-ink-2);
    text-decoration: none;
  }
  .link:hover {
    color: var(--color-ink);
  }
  .link.active {
    color: var(--color-ink);
    font-weight: 500;
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .search {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: 210px;
    padding: 7px 12px;
    border-radius: 8px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-ink-3);
    font: inherit;
    font-size: 0.82rem;
    cursor: pointer;
  }
  .search:hover {
    border-color: var(--color-border);
    color: var(--color-ink-2);
  }
  .search svg {
    width: 14px;
    height: 14px;
  }
  .search span {
    flex: 1;
    text-align: left;
  }
  .search kbd {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0 5px;
  }
  .icon-link {
    color: var(--color-ink-2);
    display: inline-flex;
  }
  .icon-link:hover {
    color: var(--color-ink);
  }
  .icon-link svg {
    width: 18px;
    height: 18px;
  }
  @media (max-width: 50rem) {
    .links,
    .search span,
    .search kbd {
      display: none;
    }
    .search {
      width: auto;
    }
  }
</style>
