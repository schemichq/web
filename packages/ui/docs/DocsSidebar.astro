---
import type { NavGroup, NavItem } from "@schemic/content/nav";

interface Props {
  sidebarNav: NavGroup[];
  activeHref?: string;
  topNav?: NavItem[];
  topActive?: string;
}
const { sidebarNav, activeHref, topNav = [], topActive } = Astro.props;
---

<aside class="sidebar" id="docs-drawer" data-docs-drawer data-pagefind-ignore>
  <nav aria-label="Docs">
    {
      topNav.length > 0 && (
        <div class="drawer-top">
          {topNav.map((item) => (
            <a
              href={item.href}
              class:list={["drawer-top-link", { active: item.label === topActive }]}
            >
              {item.label}
            </a>
          ))}
        </div>
      )
    }
    {
      sidebarNav.map((group) => (
        <div class="group">
          <p class="group-label">{group.label}</p>
          <ul>
            {group.items.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={["item", { active: item.href === activeHref }]}
                  aria-current={item.href === activeHref ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </nav>
</aside>

<!-- Backdrop scrim for the mobile drawer. Rendered OUTSIDE the sticky header
     (it lives in .shell, which has no transform/backdrop-filter) so this fixed
     element resolves against the viewport, not a clipped containing block. -->
<div class="scrim" data-docs-scrim></div>

<style>
  .sidebar {
    width: 248px;
    flex-shrink: 0;
    border-right: 1px solid var(--color-border);
    align-self: stretch;
  }
  .sidebar nav {
    position: sticky;
    top: 54px;
    display: flex;
    flex-direction: column;
    gap: 22px;
    padding: 32px 20px;
    max-height: calc(100vh - 54px);
    overflow-y: auto;
  }
  .group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .group-label {
    margin: 0 0 4px;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-3);
  }
  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .item {
    display: block;
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 0.85rem;
    color: var(--color-ink-2);
    text-decoration: none;
  }
  .item:hover {
    color: var(--color-ink);
    background: color-mix(in oklab, var(--color-ink) 5%, transparent);
  }
  .item.active {
    color: var(--color-soft);
    font-weight: 600;
    background: color-mix(in oklab, var(--color-purple) 14%, transparent);
  }

  /* Top-nav (Docs/Guides/Reference/Blog) surfaced inside the drawer — these
     links live in the header on desktop, where they're hidden on mobile, so the
     drawer is the only way to switch sections on a phone. Desktop: hidden. */
  .drawer-top {
    display: none;
  }
  .scrim {
    display: none;
  }

  @media (max-width: 60rem) {
    /* Off-canvas drawer: the sidebar becomes a fixed left panel that slides in
       from behind the sticky header. Desktop layout (>=60rem) is untouched. */
    .sidebar {
      position: fixed;
      top: 54px;
      left: 0;
      bottom: 0;
      width: 290px;
      max-width: 86vw;
      border-right: 1px solid var(--color-border);
      background: var(--color-canvas);
      transform: translateX(-100%);
      transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
      z-index: 45;
      overflow-y: auto;
    }
    .sidebar.is-open {
      transform: translateX(0);
    }
    .sidebar nav {
      position: static;
      top: auto;
      max-height: none;
      padding: 20px 18px 32px;
    }
    .drawer-top {
      display: flex;
      flex-direction: column;
      gap: 2px;
      padding-bottom: 18px;
      margin-bottom: 4px;
      border-bottom: 1px solid var(--color-border);
    }
    .drawer-top-link {
      display: block;
      padding: 7px 10px;
      border-radius: 6px;
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--color-ink-2);
      text-decoration: none;
    }
    .drawer-top-link:hover {
      color: var(--color-ink);
      background: color-mix(in oklab, var(--color-ink) 5%, transparent);
    }
    .drawer-top-link.active {
      color: var(--color-ink);
    }
    .scrim {
      display: block;
      position: fixed;
      top: 54px;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 40;
      background: rgba(0, 0, 0, 0.5);
      backdrop-filter: blur(2px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s ease;
    }
    .scrim.is-open {
      opacity: 1;
      pointer-events: auto;
    }
  }
</style>

<script is:inline>
  (function () {
    var toggle = document.querySelector("[data-docs-nav-toggle]");
    var drawer = document.querySelector("[data-docs-drawer]");
    var scrim = document.querySelector("[data-docs-scrim]");
    if (!toggle || !drawer) return;

    function setOpen(open) {
      drawer.classList.toggle("is-open", open);
      if (scrim) scrim.classList.toggle("is-open", open);
      toggle.setAttribute("aria-expanded", String(open));
      document.body.style.overflow = open ? "hidden" : "";
    }

    toggle.addEventListener("click", function (e) {
      e.stopPropagation();
      setOpen(!drawer.classList.contains("is-open"));
    });
    if (scrim) {
      scrim.addEventListener("click", function () {
        setOpen(false);
      });
    }
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && drawer.classList.contains("is-open")) {
        setOpen(false);
      }
    });
    // Close on any in-drawer link activation (section switch or page nav).
    drawer.addEventListener("click", function (e) {
      if (e.target instanceof Element && e.target.closest("a")) {
        setOpen(false);
      }
    });
  })();
</script>
