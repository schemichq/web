---
// surrealdb.schemic.dev — the SurrealDB driver site. Its landing is now the
// shared @schemic/landing, themed for SurrealDB (purple/pink). activeDriver
// seeds the hero's database picker on SurrealDB and the demo on SurrealQL; the
// picker still offers cross-subdomain navigation to the other drivers. The
// docs + blog routes are untouched and keep their own chrome/tokens.
import HubLanding from "@schemic/landing/HubLanding.astro";
import Landing from "../layouts/Landing.astro";
---

<Landing>
  <HubLanding activeDriver="surrealdb" />
</Landing>
