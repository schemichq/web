---
// schemic.dev hub hero. The database word in the headline is the SOLE database
// picker (a dropdown). It is CROSS-SUBDOMAIN: choosing an AVAILABLE driver
// navigates to that driver's subdomain; a COMING-SOON driver stays in-page and
// surfaces the demo's coming-soon overlay. Per-driver dots use the FIXED brand
// color (independent of the page's active theme); the picker label + glow use
// the theme accent (the hub wears Amber).
import {
  drivers as driverList,
  findDriver,
  ctaFor,
  SUGGEST_DRIVER_URL,
  REPO_URL,
} from "../config/drivers";
import DbMenu from "./DbMenu.astro";

// Feather "star" — filled, accent-tinted; shown only once the star island
// confirms a numeric count (see Nav's island).
const starIcon =
  '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>';

interface Props {
  /** Slug of the driver this site represents; null = agnostic hub. */
  activeDriver?: string | null;
}

const { activeDriver = null } = Astro.props;

// The picker's selected driver. On the agnostic hub (activeDriver = null) NO
// driver is selected: the label shows an unselected prompt ("Database") instead
// of falling back to the flagship, inviting the visitor to choose.
const isHub = activeDriver == null;
const selected = findDriver(activeDriver);
const pickerLabel = selected?.name ?? "Database";

const meta = ["TypeScript-first", "Zod-compatible", "MIT"];

// Primary CTA — driver-aware: derived from the site's active driver (flagship
// on the hub). Available drivers get "Start with <name>"; coming-soon drivers
// get an honest, driver-centric CTA pointing at their own subdomain.
const cta = ctaFor(activeDriver);
const chevron = '<path d="m6 9 6 6 6-6"/>';
---

<section class="relative overflow-hidden">
  <!-- ambient glow -->
  <div
    class="pointer-events-none absolute inset-x-0 -top-40 mx-auto h-[640px] max-w-5xl opacity-70 blur-3xl"
    style="background: radial-gradient(closest-side, color-mix(in oklab, var(--color-accent) 26%, transparent), transparent 70%);"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative mx-auto flex max-w-4xl flex-col items-center px-6 pt-24 pb-20 text-center sm:pt-32 sm:pb-28"
  >
    <!-- eyebrow pill -->
    <a
      href="https://github.com/schemichq/schemic"
      class="group inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3.5 py-[7px] font-mono text-xs text-ink-2 backdrop-blur transition-colors hover:border-accent/50 hover:text-ink"
    >
      <span class="size-[7px] rounded-full bg-accent-2" aria-hidden="true"></span>
      Schema as code · any database
    </a>

    <!-- headline (the database name is a dropdown picker) -->
    <h1
      class="mt-7 font-display text-5xl font-semibold leading-[1.12] tracking-tight text-balance text-ink sm:text-6xl lg:text-[4rem]"
    >
      <span class="block">
        Your <span
          data-db-picker={isHub ? "hub" : "driver"}
          class="relative inline-block align-middle"
        >
          <button
            type="button"
            data-db-trigger
            aria-haspopup="listbox"
            aria-expanded="false"
            aria-label="Choose your database"
            class:list={[
              "group inline-flex items-center gap-2 rounded-2xl border bg-surface/70 px-3 py-0.5 align-middle shadow-[0_0_24px_-6px_var(--color-accent)] transition-colors",
              isHub
                ? "border-dashed border-accent/60 hover:border-accent"
                : "border-accent/40 hover:border-accent/70",
            ]}
          >
            <span
              data-db-label
              class="bg-gradient-to-r from-accent to-accent-2 bg-clip-text text-transparent"
              >{pickerLabel}</span
            >
            <svg
              class="size-[0.6em] text-accent-soft transition-transform group-aria-expanded:rotate-180"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={chevron}
            />
          </button>

          <!-- roster menu (shared with the nav picker; opened by config/picker.ts) -->
          <DbMenu
            drivers={driverList}
            selectedSlug={selected?.slug ?? null}
            suggestHref={SUGGEST_DRIVER_URL}
            align="center"
          />
        </span> schema,
      </span>
      <span class="block">in the Zod you already know.</span>
    </h1>

    <!-- subhead -->
    <p class="mt-6 max-w-2xl text-lg text-ink-2 text-pretty sm:text-xl">
      Define your schema with <code
        class="rounded-md bg-surface-2 px-1.5 py-0.5 font-mono text-[0.9em] text-code-keyword"
        >s.*</code
      > — a drop-in for Zod. Schemic generates your database's native DDL,
      validates at runtime, and runs your migrations.
    </p>

    <!-- CTAs -->
    <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
      <a
        href={cta.primary.href}
        class="rounded-full bg-gradient-to-r from-accent to-accent-2 px-7 py-3.5 text-[15px] font-semibold text-white shadow-[0_8px_26px_0_color-mix(in_oklab,var(--color-accent)_33%,transparent)] transition-transform hover:scale-[1.03]"
      >
        {cta.primary.label}
      </a>
      <a
        href={REPO_URL}
        class="inline-flex items-center gap-2 rounded-full px-3 py-3.5 text-[15px] font-medium text-ink transition-colors hover:text-white"
      >
        <!--
          Star count — hidden until the island confirms a numeric count, so the
          CTA reads as a plain "View on GitHub" with no empty gap when the count
          is unavailable. Becomes "★ 1.2k · View on GitHub" when available.
        -->
        <span
          data-gh-star-count
          hidden
          class="inline-flex items-center gap-1.5 font-semibold"
        >
          <svg
            class="size-4 text-accent"
            viewBox="0 0 24 24"
            fill="currentColor"
            stroke="none"
            aria-hidden="true"
            set:html={starIcon}
          />
          <span data-gh-count></span>
          <span class="text-border" aria-hidden="true">·</span>
        </span>
        <svg
          class="size-4"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.54-3.88-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.41-5.25 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"
          ></path>
        </svg>
        View on GitHub
      </a>
    </div>

    <!-- meta line -->
    <p
      class="mt-10 flex items-center gap-2 font-mono text-xs tracking-wide text-ink-3"
    >
      {
        meta.map((item, i) => (
          <>
            {i > 0 && <span class="text-border" aria-hidden="true">·</span>}
            <span>{item}</span>
          </>
        ))
      }
    </p>
  </div>
</section>

<script>
  // The hero picker shares ALL behavior with the nav picker via initPickers(),
  // which wires every [data-db-picker] on the page from one place (select /
  // theme cross-fade / redirect), so the two pickers stay in sync.
  import { initPickers } from "../config/picker";
  initPickers();
</script>
