---
// NOTE (IA TBD): the hub (schemic.dev) has no /docs of its own — docs live on
// the per-driver subdomains. Pointing at the shipped flagship driver for now;
// revisit once the hub IA is settled.
import { driverUrl, flagshipDriver, REPO_URL } from "../config/drivers";

const flagship = driverUrl(flagshipDriver.slug);

const links = [
  { label: "Docs", href: `${flagship}/docs/introduction` },
  { label: "Drivers", href: flagship },
];

// Feather "star" — filled, tinted with the theme accent in the count chip.
const starIcon =
  '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>';
const githubMark =
  '<path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.54-3.88-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.41-5.25 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"></path>';
---

<header
  class="sticky top-0 z-50 bg-canvas/70 backdrop-blur-md"
>
  <nav
    class="mx-auto grid h-16 max-w-6xl grid-cols-[1fr_auto_1fr] items-center px-6"
    aria-label="Primary"
  >
    <!-- left: brand -->
    <a href="/" class="flex items-center gap-2.5 justify-self-start">
      <span
        class="grid size-8 place-items-center rounded-xl bg-gradient-to-br from-accent to-accent-2 text-[13px] font-bold text-white shadow-[0_0_20px_-4px_var(--color-accent)]"
        aria-hidden="true">S</span
      >
      <span class="font-mono text-[15px] font-medium tracking-tight text-ink"
        >Schemic</span
      >
    </a>

    <!-- center: nav links -->
    <div class="hidden items-center gap-8 justify-self-center md:flex">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-sm text-ink-2 transition-colors hover:text-ink"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <!-- right: actions -->
    <div class="flex items-center gap-5 justify-self-end">
      <!--
        GitHub star button. Plain "GitHub" link by default; the star-count chip
        is hidden until the island confirms a numeric count, so when the count
        is unavailable there's NO empty gap / no "0" flash (graceful).
      -->
      <a
        href={REPO_URL}
        aria-label="Schemic on GitHub"
        class="hidden items-center gap-2 rounded-full border border-border bg-surface px-3 py-1.5 text-sm text-ink-2 transition-colors hover:border-accent/50 hover:text-ink sm:inline-flex"
      >
        <svg
          class="size-4"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
          set:html={githubMark}
        />
        <span>GitHub</span>
        <span
          data-gh-star-count
          hidden
          class="inline-flex items-center gap-1 border-l border-border pl-2 font-medium text-ink"
        >
          <svg
            class="size-3.5 text-accent"
            viewBox="0 0 24 24"
            fill="currentColor"
            stroke="none"
            aria-hidden="true"
            set:html={starIcon}
          />
          <span data-gh-count></span>
        </span>
      </a>
      <a
        href={flagship}
        class="rounded-full bg-ink px-4 py-2 text-sm font-semibold text-canvas transition-colors hover:bg-white"
      >
        Get started
      </a>
    </div>
  </nav>
</header>

<script>
  // Single star-count island for the whole page. Fetches the cached worker once
  // on load and, ONLY if it returns a finite numeric `stars`, fills every
  // [data-gh-count] slot (Nav + Hero) and reveals their [data-gh-star-count]
  // chips. On any failure (network, non-OK, null, non-numeric) it does nothing —
  // the buttons stay plain "GitHub" with no count and no reserved gap. SSR-safe
  // and no-JS-safe: the markup is a plain repo link until this runs.
  import { GITHUB_STARS_ENDPOINT } from "../config/github";

  const formatStars = (n: number): string => {
    if (n < 1000) return String(n);
    const k = n / 1000;
    const rounded = k >= 100 ? Math.round(k) : Math.round(k * 10) / 10;
    return `${rounded}k`;
  };

  const loadStars = async (): Promise<void> => {
    const slots = document.querySelectorAll<HTMLElement>("[data-gh-count]");
    if (slots.length === 0) return;
    try {
      const res = await fetch(GITHUB_STARS_ENDPOINT, {
        headers: { accept: "application/json" },
      });
      if (!res.ok) return;
      const data = (await res.json()) as { stars?: number | null };
      const stars = data?.stars;
      if (typeof stars !== "number" || !Number.isFinite(stars)) return;

      const text = formatStars(stars);
      slots.forEach((slot) => {
        slot.textContent = text;
      });
      document
        .querySelectorAll<HTMLElement>("[data-gh-star-count]")
        .forEach((chip) => {
          chip.hidden = false;
        });
    } catch {
      // Graceful: leave the buttons as plain GitHub links.
    }
  };

  void loadStars();
</script>
