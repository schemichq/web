---
// The Schemic brand mark — the block-"S" (gradient face over a darker depth
// shadow). It wears the active THEME brand color: the face is the theme accent
// gradient (var(--color-accent) -> var(--color-accent-2)) and the depth is a
// derived dark shade of it, so the mark recolors — and cross-fades — with the
// rest of the page when the driver switches (amber hub, purple SurrealDB, blue
// Postgres). Pair it with the "Schemic" wordmark; the svg is aria-hidden since
// the lockups carry the visible wordmark text.
//
// The <linearGradient> needs a DOM-unique id: several brand marks render on one
// page (nav + footer), and a shared id would make them all resolve to the first
// gradient. crypto.randomUUID() gives each instance its own.
interface Props {
  /** Sizing class for the <svg> box (default size-8 = 32px). */
  class?: string;
}
const { class: className = "size-8" } = Astro.props;
const gid = `schemic-mark-${crypto.randomUUID()}`;
---

<svg
  class={className}
  viewBox="0 0 126 136"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    <linearGradient id={gid} x1="0" y1="0" x2="126" y2="136" gradientUnits="userSpaceOnUse">
      <stop offset="0" style="stop-color: var(--color-accent)"></stop>
      <stop offset="1" style="stop-color: var(--color-accent-2)"></stop>
    </linearGradient>
  </defs>
  <path
    d="M96 28l-62 0 0 38 52 0 0 38-62 0"
    transform="translate(6 8)"
    fill="none"
    style="stroke: color-mix(in oklab, var(--color-accent) 42%, #000)"
    stroke-width="24"
    stroke-linecap="square"></path>
  <path
    d="M96 28l-62 0 0 38 52 0 0 38-62 0"
    fill="none"
    stroke={`url(#${gid})`}
    stroke-width="24"
    stroke-linecap="square"></path>
</svg>
