---
import { driverUrl, hubUrl } from "../config/drivers";

interface Props {
  /** Slug of the driver this site represents; null = agnostic hub. */
  activeDriver?: string | null;
}
const { activeDriver = null } = Astro.props;

// The short, ready-to-paste agent prompt. Display + copy come from the SAME
// string (rendered as text + carried on data-prompt), so they never drift; the
// Copy button writes the EXACT raw string — backticks and all — to the
// clipboard. Kept verbatim from marketing copy.
const PROMPT = `Set up Schemic in my project to manage my database schema as code. Before changing anything, read the reference at https://schemic.dev/llms.txt so you use the current API. Then:
1. Ask me which database I'm using, then install \`@schemic/cli\` and the matching driver (the reference lists each driver's exact packages) and run \`npx schemic init\` to scaffold the config, the \`database/\` layout, and a sample schema.
2. Configure the connection in \`schemic.config.ts\` with the driver's connection factory (e.g. \`surrealConnection({ url, namespace, database })\`) read from environment variables. Reuse my app's existing connection or env vars if it already has them; otherwise ask me how I want the connection defined.
3. Verify it works: run \`npx schemic doctor\` (it tests the connection) and \`npx schemic status\`, and confirm both succeed before continuing.
4. Ask me whether I already have an existing database. If I do **and my driver supports introspection** (the reference notes which do — \`pull\` is SurrealDB today), run \`npx schemic pull\` to preview it, then \`npx schemic pull --write\` to adopt it into my TypeScript files; otherwise ask me which tables and fields I need and define them with the \`s.*\` builder (a superset of Zod, where \`$\`-prefixed methods emit DDL).
5. Generate a migration with \`npx schemic gen <name>\`, then show it to me — let me review it and run \`npx schemic migrate\` myself when I'm ready. Don't apply it to my database; that's my call.
6. Show me how to read and write rows type-safely with \`App<typeof Table>\` and \`encode\` / \`decode\`.

Walk me through each step as you go.`;

// "Read the full guide" is driver-aware: the agnostic hub points at the database
// picker (/drivers — its docs would otherwise be the flagship driver's, wrong on
// an agnostic page), while a driver site points at its OWN docs quickstart.
const quickstartUrl =
  activeDriver == null
    ? `${hubUrl}/drivers`
    : `${driverUrl(activeDriver)}/docs/quickstart`;
const arrow = '<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>';
const copyIcon =
  '<rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/>';
---

<section class="border-t border-border-subtle bg-canvas-2 px-6 py-24 sm:py-28">
  <div class="mx-auto flex max-w-[820px] flex-col items-center text-center">
    <p class="font-mono text-xs uppercase tracking-[0.08em] text-accent-2">
      // set up with ai
    </p>
    <h2
      class="mt-3 font-display text-4xl font-semibold leading-[1.06] tracking-tight text-ink sm:text-[42px]"
    >
      Let your agent wire it up.
    </h2>
    <p class="mx-auto mt-3 max-w-[600px] text-[17px] leading-[1.5] text-ink-2">
      Let your AI coding agent set up Schemic for you. Paste this prompt into
      Claude Code, Cursor, or any agent — it installs and configures the right
      driver for your database, brings your schema into TypeScript (new or
      existing), and prepares your first migration for you to review and run,
      explaining each step.
    </p>

    <!-- Teaser display: the copy button carries the FULL 6-step prompt
         (data-prompt); the band itself stays light. The full prompt is shown +
         pasteable on the docs quickstart. -->
    <div data-aiprompt class="mt-9 flex flex-col items-center gap-3">
      <button
        type="button"
        data-copy
        data-prompt={PROMPT}
        aria-label="Copy the setup prompt"
        class="ap-copy group inline-flex items-center gap-2.5 rounded-full bg-gradient-to-r from-accent to-accent-2 px-6 py-3.5 text-[15px] font-semibold text-on-accent shadow-[0_8px_30px_-6px_var(--color-accent)] transition-transform hover:scale-[1.03]"
      >
        <svg
          class="size-[18px]"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          set:html={copyIcon}
        />
        <span data-copy-label>Copy the setup prompt</span>
      </button>
      <span class="font-mono text-[11px] tracking-[0.06em] text-ink-3">
        one prompt · full setup
      </span>
    </div>

    <a
      href={quickstartUrl}
      class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-ink-2 transition-colors hover:text-ink"
    >
      Read the full guide
      <svg
        class="size-3.5 text-accent-2"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        set:html={arrow}
      />
    </a>
  </div>
</section>

<style>
  /* "Copied!" feedback — the label flips; keep the pill's on-accent text and
     add a success ring (a text-color override would clash on the gradient). */
  .ap-copy.is-copied {
    box-shadow: 0 0 0 2px color-mix(in oklab, var(--color-success) 70%, transparent);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>("[data-aiprompt]").forEach((root) => {
    const copyBtn = root.querySelector<HTMLButtonElement>("[data-copy]");
    const copyLabel = root.querySelector<HTMLElement>("[data-copy-label]");
    copyBtn?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(copyBtn.dataset.prompt ?? "");
        if (copyLabel) copyLabel.textContent = "Copied!";
        copyBtn.classList.add("is-copied");
        setTimeout(() => {
          if (copyLabel) copyLabel.textContent = "Copy";
          copyBtn.classList.remove("is-copied");
        }, 2000);
      } catch {
        /* clipboard unavailable */
      }
    });
  });
</script>
