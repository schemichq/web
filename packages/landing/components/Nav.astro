---
import {
  driverUrl,
  findDriver,
  hubUrl,
  paneStates,
  paneKeyFor,
} from "../config/drivers";
import NavDbPicker from "./NavDbPicker.astro";

interface Props {
  /** Slug of the driver this site represents; null = agnostic hub. */
  activeDriver?: string | null;
}
const { activeDriver = null } = Astro.props;

// Progressive-disclosure nav (Manuel's spec). The database picker is the primary
// control: on the agnostic hub (no driver) it sits CENTERED as a prominent
// "Select database" prompt and the Docs/Examples links are hidden. Once a driver
// is selected — on a driver route OR via a client-side switch — the picker
// SLIDES to the right beside Get started and the Docs/Examples links reveal. The
// resting state is SSR'd via [data-db-selected]; a FLIP (below) animates live
// transitions. The picker element is rendered into exactly one slot (center on
// the hub, right when selected) and reparented between them on switch.
const isHub = activeDriver == null;
const navDriver = findDriver(activeDriver);

// Driver-specific nav links resolve to the ACTIVE driver. Each is rendered as a
// `[data-driver-pane]` variant (like the hero CTAs) so the client-side picker
// switch keeps it pointed at the current driver with NO reload. On the agnostic
// hub the whole links row is hidden, so the hub variants never show — but we
// still render them so config/picker.ts's pane machinery stays uniform.
const activeKey = paneKeyFor(activeDriver);
const linkStates = paneStates.map((s) => ({
  key: s.key,
  hidden: s.key !== activeKey,
  docs: s.slug ? `${driverUrl(s.slug)}/docs/introduction` : null,
  start: s.slug ? driverUrl(s.slug) : null,
  // Examples live on the hub origin, one route per driver (+ the agnostic
  // /examples). Driver-aware like Docs/Get-started: a [data-driver-pane] variant
  // per pane so the client-side switch keeps it on the current driver — from the
  // hub it's /examples, from /surrealdb it's /examples/surrealdb.
  examples: s.slug ? `${hubUrl}/examples/${s.slug}` : `${hubUrl}/examples`,
}));
---

<header
  data-db-selected={String(!isHub)}
  class="sticky top-0 z-50 bg-canvas/70 backdrop-blur-md"
>
  <nav
    class="mx-auto grid h-16 max-w-6xl grid-cols-[1fr_auto_1fr] items-center px-4 md:px-6"
    aria-label="Primary"
  >
    <!-- left: brand -->
    <a href="/" class="mr-3 flex items-center gap-2.5 justify-self-start sm:mr-0">
      <span
        class="grid size-8 place-items-center rounded-xl bg-gradient-to-br from-accent to-accent-2 text-[13px] font-bold text-on-accent shadow-[0_0_20px_-4px_var(--color-accent)]"
        aria-hidden="true">S</span
      >
      <span class="font-mono text-[15px] font-medium tracking-tight text-ink"
        >Schemic</span
      >
    </a>

    <!-- center: the Docs/Examples links (revealed once a database is selected)
         sit beside the centered picker slot. The links row is desktop-only and
         hidden until selected; the center slot holds the picker on the hub. -->
    <div class="flex items-center justify-self-center">
      <div data-nav-links class="items-center gap-8">
        {/* Docs — resolves to the ACTIVE driver's docs. */}
        {
          linkStates.map((st) =>
            st.docs ? (
              <a
                href={st.docs}
                data-driver-pane={st.key}
                hidden={st.hidden}
                class="text-sm text-ink-2 transition-colors hover:text-ink"
              >
                Docs
              </a>
            ) : (
              <button
                type="button"
                data-open-picker
                data-driver-pane={st.key}
                hidden={st.hidden}
                class="text-sm text-ink-2 transition-colors hover:text-ink"
              >
                Docs
              </button>
            ),
          )
        }
        {/* The verified cookbook gallery — driver+section-aware. */}
        {
          linkStates.map((st) => (
            <a
              href={st.examples}
              data-driver-pane={st.key}
              hidden={st.hidden}
              class="text-sm text-ink-2 transition-colors hover:text-ink"
            >
              Examples
            </a>
          ))
        }
      </div>
      <!-- picker home on the agnostic hub (centered) -->
      <div data-picker-slot="center" class="flex items-center">
        {isHub && <NavDbPicker navDriver={navDriver} isHub={isHub} />}
      </div>
    </div>

    <!-- right: actions -->
    <div class="flex items-center gap-3 justify-self-end sm:gap-5">
      <!-- picker home once a database is selected (beside Get started) -->
      <div data-picker-slot="right" class="flex items-center">
        {!isHub && <NavDbPicker navDriver={navDriver} isHub={isHub} />}
      </div>
      <!-- Get started — driver-dynamic; on the hub it opens the picker. -->
      {
        linkStates.map((st) =>
          st.start ? (
            <a
              href={st.start}
              data-driver-pane={st.key}
              hidden={st.hidden}
              class="rounded-full bg-ink px-4 py-2 text-sm font-semibold text-canvas transition-colors hover:bg-white"
            >
              Get started
            </a>
          ) : (
            <button
              type="button"
              data-open-picker
              data-driver-pane={st.key}
              hidden={st.hidden}
              class="rounded-full bg-ink px-4 py-2 text-sm font-semibold text-canvas transition-colors hover:bg-white"
            >
              Get started
            </button>
          ),
        )
      }
    </div>
  </nav>
</header>

<style is:global>
  /* The Docs/Examples links stay hidden until a database is selected, and only
     on desktop (md+). Driven by the header attribute so a client-side switch
     reveals/hides them with no reload. */
  [data-nav-links] {
    display: none;
  }
  @media (min-width: 768px) {
    header[data-db-selected="true"] [data-nav-links] {
      display: flex;
    }
  }

  /* Picker trigger appearance reacts to the selection state (SSR + live switch).
     Unselected = a dashed accent "Select database" prompt; selected = a compact
     solid pill. Mirrors the prior SSR-only Tailwind variants. */
  header[data-db-selected="false"] [data-db-trigger] {
    border-style: dashed;
    border-color: color-mix(in oklab, var(--color-accent) 60%, transparent);
    color: var(--color-accent-soft);
  }
  header[data-db-selected="false"] [data-db-trigger]:hover {
    border-color: var(--color-accent);
    color: var(--color-ink);
  }
  header[data-db-selected="true"] [data-db-trigger] {
    border-style: solid;
    border-color: var(--color-border);
    color: var(--color-ink-2);
  }
  header[data-db-selected="true"] [data-db-trigger]:hover {
    border-color: color-mix(in oklab, var(--color-accent) 50%, transparent);
    color: var(--color-ink);
  }
</style>

<script>
  // Progressive-disclosure FLIP: when the active database changes, slide the nav
  // picker between its centered (hub) slot and its right-hand (selected) slot,
  // and reveal/hide the Docs/Examples links. The single source of truth is the
  // `schemic:driverswitch` CustomEvent that config/picker.ts dispatches on BOTH
  // an in-page select AND back/forward (popstate) — so this one listener covers
  // every transition. The SSR'd first paint already matches the route, so we
  // animate ONLY on events, never on load.
  import { HUB_PANE } from "../config/drivers";

  const header = document.querySelector<HTMLElement>("header[data-db-selected]");
  const picker = document.querySelector<HTMLElement>('[data-db-picker="nav"]');
  const centerSlot = document.querySelector<HTMLElement>(
    '[data-picker-slot="center"]',
  );
  const rightSlot = document.querySelector<HTMLElement>(
    '[data-picker-slot="right"]',
  );
  const links = document.querySelector<HTMLElement>("[data-nav-links]");

  if (header && picker && centerSlot && rightSlot) {
    const reduce = (): boolean =>
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const setSelected = (selected: boolean): void => {
      // No-op when already in the requested state.
      if ((header.dataset.dbSelected === "true") === selected) return;

      const target = selected ? rightSlot : centerSlot;
      if (picker.parentElement === target) {
        header.dataset.dbSelected = String(selected);
        return;
      }

      // FLIP: measure, reparent + flip the state attribute (which restyles the
      // trigger + reveals the links), measure again, then play the inverse.
      const first = picker.getBoundingClientRect();
      target.appendChild(picker);
      header.dataset.dbSelected = String(selected);
      const last = picker.getBoundingClientRect();
      const dx = first.left - last.left;
      const dy = first.top - last.top;

      if (!reduce() && typeof picker.animate === "function" && (dx || dy)) {
        picker.animate(
          [
            { transform: `translate(${dx}px, ${dy}px)` },
            { transform: "none" },
          ],
          { duration: 420, easing: "cubic-bezier(.4, 0, .2, 1)" },
        );
      }

      // Subtle reveal of the links when entering the selected state.
      if (
        selected &&
        links &&
        !reduce() &&
        typeof links.animate === "function"
      ) {
        links.animate([{ opacity: 0 }, { opacity: 1 }], {
          duration: 300,
          delay: 120,
          easing: "ease-out",
        });
      }
    };

    document.addEventListener("schemic:driverswitch", (e) => {
      const key = (e as CustomEvent<{ key: string }>).detail?.key;
      if (typeof key === "string") setSelected(key !== HUB_PANE);
    });
  }
</script>

<script>
  // Single star-count island for the whole page. Fetches the cached worker once
  // on load and, ONLY if it returns a finite numeric `stars`, fills every
  // [data-gh-count] slot (Nav + Hero) and reveals their [data-gh-star-count]
  // chips. On any failure (network, non-OK, null, non-numeric) it does nothing —
  // the buttons stay plain "GitHub" with no count and no reserved gap. SSR-safe
  // and no-JS-safe: the markup is a plain repo link until this runs.
  import { GITHUB_STARS_ENDPOINT } from "../config/github";

  const formatStars = (n: number): string => {
    if (n < 1000) return String(n);
    const k = n / 1000;
    const rounded = k >= 100 ? Math.round(k) : Math.round(k * 10) / 10;
    return `${rounded}k`;
  };

  const loadStars = async (): Promise<void> => {
    const slots = document.querySelectorAll<HTMLElement>("[data-gh-count]");
    if (slots.length === 0) return;
    try {
      const res = await fetch(GITHUB_STARS_ENDPOINT, {
        headers: { accept: "application/json" },
      });
      if (!res.ok) return;
      const data = (await res.json()) as { stars?: number | null };
      const stars = data?.stars;
      if (typeof stars !== "number" || !Number.isFinite(stars)) return;

      const text = formatStars(stars);
      slots.forEach((slot) => {
        slot.textContent = text;
      });
      document
        .querySelectorAll<HTMLElement>("[data-gh-star-count]")
        .forEach((chip) => {
          chip.hidden = false;
        });
    } catch {
      // Graceful: leave the buttons as plain GitHub links.
    }
  };

  void loadStars();
</script>
