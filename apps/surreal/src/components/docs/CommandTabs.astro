---
/**
 * CommandTabs - a package-manager switcher for shell install commands
 * (npm / pnpm / yarn / bun) on a terminal surface, with Copy. The chosen
 * manager is remembered and synced across every CommandTabs on the site.
 *
 * Usage (MDX): <CommandTabs npm="npm install @schemic/core" pnpm="pnpm add @schemic/core" yarn="yarn add @schemic/core" bun="bun add @schemic/core" />
 *
 * Shell commands are flush-left, so plain string props are safe here (the MDX
 * indentation-stripping that affects code only bites indented samples).
 */
interface Props {
  npm: string;
  pnpm?: string;
  yarn?: string;
  bun?: string;
}
const { npm, pnpm, yarn, bun } = Astro.props;
const managers = [
  { id: "npm", label: "npm", code: npm },
  { id: "pnpm", label: "pnpm", code: pnpm },
  { id: "yarn", label: "yarn", code: yarn },
  { id: "bun", label: "bun", code: bun },
].filter((m): m is { id: string; label: string; code: string } => !!m.code);
---

<div class="cmd-tabs" data-cmd-tabs>
  <div class="ct-bar">
    <div class="ct-seg" role="tablist" aria-label="Package manager">
      {
        managers.map((m, i) => (
          <button
            type="button"
            class:list={["ct-tab", { "is-active": i === 0 }]}
            data-pm={m.id}
            role="tab"
            aria-selected={i === 0 ? "true" : "false"}
          >
            {m.label}
          </button>
        ))
      }
    </div>
    <button type="button" class="ct-copy" data-copy aria-label="Copy command">
      <span data-copy-label>Copy</span>
    </button>
  </div>
  {
    managers.map((m, i) => (
      <div
        class:list={["ct-panel", { "is-active": i === 0 }]}
        data-panel={m.id}
        data-code={m.code}
        hidden={i !== 0}
      >
        {m.code
          .split("\n")
          .filter((l) => l.trim())
          .map((line) => (
            <div class="ct-line">
              <span class="ct-prompt" aria-hidden="true">
                $
              </span>
              <span class="ct-cmd">{line}</span>
            </div>
          ))}
      </div>
    ))
  }
</div>

<style>
  .cmd-tabs {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: clip;
    background: var(--color-code-bg);
    margin: 1.25rem 0;
  }
  .ct-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.5rem 0.625rem;
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .ct-seg {
    display: inline-flex;
    gap: 0.25rem;
    padding: 0.1875rem;
    border-radius: 8px;
    background: var(--color-canvas);
    border: 1px solid var(--color-border-subtle);
  }
  .ct-tab {
    border: 0;
    border-radius: 6px;
    background: transparent;
    color: var(--color-ink-3);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1;
    padding: 0.3rem 0.7rem;
    cursor: pointer;
    transition:
      color 0.12s ease,
      background 0.12s ease;
  }
  .ct-tab:hover {
    color: var(--color-ink-2);
  }
  .ct-tab.is-active {
    background: var(--color-canvas-2);
    color: var(--color-ink);
    box-shadow: inset 0 0 0 1px var(--color-border);
  }
  .ct-copy {
    border: 1px solid var(--color-border-subtle);
    border-radius: 6px;
    background: transparent;
    color: var(--color-ink-3);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.25rem 0.55rem;
    cursor: pointer;
    transition:
      color 0.12s ease,
      border-color 0.12s ease;
  }
  .ct-copy:hover {
    color: var(--color-ink);
    border-color: var(--color-border);
  }
  .ct-copy.is-copied {
    color: var(--color-success);
    border-color: color-mix(in oklab, var(--color-success) 50%, transparent);
  }
  .ct-panel {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 0.875rem 1rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.5;
  }
  .ct-panel[hidden] {
    display: none;
  }
  .ct-line {
    display: flex;
    gap: 0.6rem;
  }
  .ct-prompt {
    color: var(--color-soft);
    flex-shrink: 0;
  }
  .ct-cmd {
    color: var(--color-code-plain);
    white-space: pre-wrap;
  }
</style>

<script>
  const KEY = "sz-pm";

  function applyPreference(root: HTMLElement, pm: string) {
    const tabs = root.querySelectorAll<HTMLButtonElement>(".ct-tab");
    const panels = root.querySelectorAll<HTMLElement>(".ct-panel");
    // Only switch if this instance actually offers that manager.
    if (![...tabs].some((t) => t.dataset.pm === pm)) return;
    tabs.forEach((t) => {
      const active = t.dataset.pm === pm;
      t.classList.toggle("is-active", active);
      t.setAttribute("aria-selected", active ? "true" : "false");
    });
    panels.forEach((p) => {
      const active = p.dataset.panel === pm;
      p.classList.toggle("is-active", active);
      p.hidden = !active;
    });
  }

  function initCommandTabs(root: HTMLElement) {
    const tabs = root.querySelectorAll<HTMLButtonElement>(".ct-tab");
    const copyBtn = root.querySelector<HTMLButtonElement>("[data-copy]");
    const copyLabel = root.querySelector<HTMLElement>("[data-copy-label]");

    tabs.forEach((t) => {
      t.addEventListener("click", () => {
        const pm = t.dataset.pm ?? "npm";
        try {
          localStorage.setItem(KEY, pm);
        } catch {
          /* storage unavailable */
        }
        // Update every CommandTabs on the page (cross-instance sync).
        document
          .querySelectorAll<HTMLElement>("[data-cmd-tabs]")
          .forEach((el) => applyPreference(el, pm));
      });
    });

    copyBtn?.addEventListener("click", async () => {
      const active = root.querySelector<HTMLElement>(".ct-panel.is-active");
      try {
        await navigator.clipboard.writeText(active?.dataset.code ?? "");
        if (copyLabel) copyLabel.textContent = "Copied";
        copyBtn.classList.add("is-copied");
        setTimeout(() => {
          if (copyLabel) copyLabel.textContent = "Copy";
          copyBtn.classList.remove("is-copied");
        }, 1400);
      } catch {
        /* clipboard unavailable */
      }
    });
  }

  const all = document.querySelectorAll<HTMLElement>("[data-cmd-tabs]");
  all.forEach((el) => initCommandTabs(el));
  // Restore the remembered manager on load.
  let pref = "npm";
  try {
    pref = localStorage.getItem(KEY) || "npm";
  } catch {
    /* storage unavailable */
  }
  all.forEach((el) => applyPreference(el, pref));
</script>
