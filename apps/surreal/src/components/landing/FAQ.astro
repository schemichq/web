---
const code = (s: string) => `<code class="font-mono text-soft">${s}</code>`;

const faqs: { q: string; a: string; chips?: string[] }[] = [
  {
    q: "Is it really just Zod?",
    a: `Yes — ${code("s.*")} is a 1:1 drop-in for ${code("z.*")}. Migrate an existing schema by find-replacing ${code("z.")} → ${code("s.")} If you know Zod, there's nothing new to learn.`,
  },
  {
    q: "Why not write SurrealQL by hand?",
    a: `Hand-written DDL drifts from your types. Schemic keeps schema, SurrealQL, and TypeScript types as one source of truth — generated, never out of sync.`,
  },
  {
    q: "How do migrations run?",
    a: `Three commands cover the whole loop — one writes a migration from the schema diff, one applies it, one checks for drift.`,
    chips: ["sc generate", "sc migrate", "sc diff --live"],
  },
  {
    q: "Which SurrealDB version?",
    a: `Built for SurrealDB 3.x and the full ${code("define*")} vocabulary — tables, fields, indexes, events, functions, and access. MIT licensed.`,
  },
  {
    q: "Can I adopt it on an existing database?",
    a: `Yes. One command introspects the live database and generates the matching ${code("s.*")} schema files, so you start from the database you already have and migrate forward.`,
    chips: ["sc pull"],
  },
  {
    q: "Does it replace the surrealdb SDK?",
    a: `No — it sits on top of it. You keep the official SDK for queries; Schemic owns the schema, the generated DDL, the migrations, and the row types.`,
  },
  {
    q: "How is it different from surqlize?",
    a: `surqlize is a query builder. Schemic is complementary — it owns the schema, the generated DDL, and the migrations. Pair it with surqlize or the official SDK for queries.`,
  },
  {
    q: "Can I drop to raw SurrealQL?",
    a: `Always. The ${code("surql")} tag composes raw SurrealQL into any default, event, permission, or function — and for ad-hoc queries you use the SDK directly.`,
  },
];
---

<section
  id="faq"
  class="border-y border-border-subtle bg-canvas-2 px-6 py-24 sm:py-28"
>
  <div class="mx-auto max-w-[1040px]">
    <div class="text-center">
      <p class="font-mono text-xs uppercase tracking-[0.12em] text-pink">
        // common questions
      </p>
      <h2
        class="mt-3 font-display text-[2.5rem] font-semibold leading-[1.06] tracking-tight text-ink"
      >
        Questions, answered.
      </h2>
    </div>

    <div class="mt-9 grid gap-5 md:grid-cols-2">
      {
        faqs.map((f) => (
          <div class="flex flex-col gap-2.5 rounded-2xl border border-border bg-surface p-6">
            <div class="flex items-start gap-2.5">
              <span class="font-mono text-base font-semibold leading-[1.3] text-pink">+</span>
              <h3 class="font-display text-[17px] font-semibold leading-[1.3] text-ink">
                {f.q}
              </h3>
            </div>
            <p class="text-[14.5px] leading-[1.55] text-ink-2" set:html={f.a} />
            {f.chips && (
              <div class="mt-1 flex flex-wrap gap-2">
                {f.chips.map((c) => (
                  <span class="rounded-md border border-border-subtle bg-code-bg px-2.5 py-[5px] font-mono text-xs text-code-plain">
                    {c}
                  </span>
                ))}
              </div>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>
