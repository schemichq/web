---
// NOTE (PASS 1, IA TBD): the hub (schemic.dev) has no /docs of its own — docs
// live on the per-driver subdomains. Pointing at the shipped SurrealDB driver
// for now; revisit once the hub IA is settled.
const links = [
  { label: "Docs", href: "https://surreal.schemic.dev/docs/introduction" },
  { label: "Drivers", href: "https://surreal.schemic.dev" },
  { label: "GitHub", href: "https://github.com/schemichq/schemic" },
];
---

<header
  class="sticky top-0 z-50 bg-canvas/70 backdrop-blur-md"
>
  <nav
    class="mx-auto grid h-16 max-w-6xl grid-cols-[1fr_auto_1fr] items-center px-6"
    aria-label="Primary"
  >
    <!-- left: brand -->
    <a href="/" class="flex items-center gap-2.5 justify-self-start">
      <span
        class="grid size-8 place-items-center rounded-xl bg-gradient-to-br from-purple to-pink text-[13px] font-bold text-white shadow-[0_0_20px_-4px_var(--color-purple)]"
        aria-hidden="true">S</span
      >
      <span class="font-mono text-[15px] font-medium tracking-tight text-ink"
        >Schemic</span
      >
    </a>

    <!-- center: nav links -->
    <div class="hidden items-center gap-8 justify-self-center md:flex">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-sm text-ink-2 transition-colors hover:text-ink"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <!-- right: actions -->
    <div class="flex items-center gap-5 justify-self-end">
      <a
        href="https://github.com/schemichq/schemic"
        class="hidden text-sm text-ink-2 transition-colors hover:text-ink sm:inline"
        >GitHub</a
      >
      <a
        href="https://surreal.schemic.dev"
        class="rounded-full bg-ink px-4 py-2 text-sm font-semibold text-canvas transition-colors hover:bg-white"
      >
        Get started
      </a>
    </div>
  </nav>
</header>
