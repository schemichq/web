---
// The "problem" beat (blend section 2): your schema lives in four places that
// drift. Chips sit scattered/rotated at rest so a drift -> settle ANIMATION can
// be wired in PASS 2 (each chip is .drift-chip with a data-rest rotation). The
// turn line resolves downward into the Demo.
const chips = [
  { name: "DDL", tag: "hand-written", rot: "-2.5deg" },
  { name: "Migrations", tag: "by hand", rot: "2deg" },
  { name: "Types", tag: "drifts", rot: "-1.5deg" },
  { name: "Validation", tag: "bolted on", rot: "2.5deg" },
];

const x = '<path d="M18 6 6 18"/><path d="m6 6 12 12"/>';
const down = '<path d="M12 5v14"/><path d="m19 12-7 7-7-7"/>';
---

<section
  data-drift-section
  class="border-y border-border-subtle bg-canvas-2 px-6 py-24 sm:py-28"
>
  <div class="mx-auto flex max-w-4xl flex-col items-center text-center">
    <h2
      class="font-display text-[34px] font-semibold leading-[1.1] tracking-tight text-balance sm:text-5xl"
    >
      <span class="text-ink">Your schema lives in four places.</span><br />
      <span class="text-ink-3">None of them agree.</span>
    </h2>

    <!-- four drifting artifacts -->
    <div
      class="mt-12 flex flex-wrap items-center justify-center gap-x-3 gap-y-5"
    >
      {
        chips.map((c, i) => (
          <>
            {i > 0 && (
              <span
                class="font-mono text-2xl text-ink-3/70 select-none"
                aria-hidden="true"
              >
                ≠
              </span>
            )}
            <div
              class="drift-chip rounded-xl border border-border bg-surface px-5 py-3.5 shadow-[0_10px_30px_-12px_#00000080]"
              data-rest-rotate={c.rot}
              style={`transform: rotate(${c.rot})`}
            >
              <div class="font-mono text-[15px] font-medium text-ink">
                {c.name}
              </div>
              <div
                class="mt-1.5 flex items-center justify-center gap-1.5 font-mono text-[11px] text-danger"
              >
                <svg
                  class="size-3"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={x}
                />
                {c.tag}
              </div>
            </div>
          </>
        ))
      }
    </div>

    <!-- the turn -->
    <p class="mt-14 max-w-xl text-lg text-ink-2 text-pretty sm:text-xl">
      But you already describe your data in <span class="text-ink"
        >TypeScript</span
      >.
    </p>
    <svg
      class="mt-5 size-6 text-soft"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      set:html={down}
    />
  </div>
</section>

<script>
  // Drift -> settle: chips start scattered/over-rotated and ease into their
  // resting rotation when the section scrolls into view. Reduced-motion: skip
  // (chips already render at rest via their inline transform).
  const section = document.querySelector<HTMLElement>("[data-drift-section]");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (section && !reduce && "IntersectionObserver" in window) {
    const chips = Array.from(
      section.querySelectorAll<HTMLElement>(".drift-chip"),
    );

    // Arm the drifted (pre-settle) state.
    chips.forEach((chip, i) => {
      const rest = chip.dataset.restRotate || "0deg";
      const dir = i % 2 === 0 ? -1 : 1;
      const dx = dir * (22 + i * 7);
      const dy = -18 - i * 5;
      const spin = dir * (9 + i * 2);
      chip.style.transition = "none";
      chip.style.transform = `translate(${dx}px, ${dy}px) rotate(calc(${rest} + ${spin}deg))`;
      chip.style.opacity = "0";
    });
    // Force a reflow so the armed state is committed before transitioning.
    void section.offsetHeight;

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          chips.forEach((chip, i) => {
            const rest = chip.dataset.restRotate || "0deg";
            chip.style.transition = `transform 0.62s cubic-bezier(0.22, 1, 0.36, 1) ${i * 90}ms, opacity 0.5s ease ${i * 90}ms`;
            chip.style.transform = `rotate(${rest})`;
            chip.style.opacity = "1";
          });
          io.disconnect();
        }
      },
      { threshold: 0.35, rootMargin: "0px 0px -10% 0px" },
    );
    io.observe(section);
  }
</script>
