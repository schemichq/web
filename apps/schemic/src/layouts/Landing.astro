---
import "@fontsource-variable/geist";
import "@fontsource-variable/jetbrains-mono";
import "../styles/landing.css";

import { driverTheme, findDriver } from "@schemic/landing/config/drivers";

interface Props {
  title?: string;
  description?: string;
  /**
   * Slug of the driver this route represents (null on the agnostic hub). On a
   * driver route we keep the app's NEUTRAL base CSS but inline that driver's
   * theme @property color vars on :root, so the very first server render is
   * already in the driver's palette (purple / blue) with NO flash. The agnostic
   * "/" route stays neutral; the picker cross-fades between them client-side.
   */
  activeDriver?: string | null;
}

const {
  title = "Schemic — Schema as code, for any database",
  description = "Define your database schema once in the Zod you already know — Schemic turns it into native DDL, types, and migrations for any database.",
  activeDriver = null,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);

// Social card: the hub origin emits one card per driver key (/og/<key>.png);
// pick the one matching this route (the agnostic hub -> the amber Schemic card).
const ogKey = activeDriver && findDriver(activeDriver) ? activeDriver : "hub";
const ogImage = new URL(`/og/${ogKey}.png`, Astro.site);

// Inline the driver's FULL theme on the driver routes only (hub stays neutral).
// We set the COMPLETE per-driver token set (every --color-* the standalone
// theme-<slug>.css overrides — borders, ink-2/3, surface-2, accent-soft/hot,
// code-token hues, on-accent, …), not just the 6 @property cross-fade vars, so a
// driver route's first server render fully matches its standalone theme with no
// flash and no half-dressed look. The hub "/" stays the neutral base CSS.
const t = findDriver(activeDriver) ? driverTheme(activeDriver) : null;
const themeStyle = t
  ? `:root{${Object.entries(t)
      .map(([k, v]) => `${k}:${v}`)
      .join(";")}}`
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Favicon follows the active driver (gray hub / purple SurrealDB / blue
        Postgres). SSR'd per route; swapped client-side on a driver switch by the
        script below. */}
    <link
      rel="icon"
      id="favicon"
      href={ogKey === "hub" ? "/favicon.svg" : `/favicon-${ogKey}.svg`}
      type="image/svg+xml"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Schemic" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* Per-path driver theme — last in <head> so it wins over the neutral base. */}
    {themeStyle && <style set:html={themeStyle} />}
  </head>
  <body class="min-h-screen bg-canvas text-ink antialiased">
    <slot />
    <script is:inline>
      // Keep the favicon in sync with the active driver on a client-side switch
      // (the picker dispatches `schemic:driverswitch` with the pane key). hub ->
      // gray, surrealdb -> purple, postgres -> blue. SSR already sets the right
      // one per route; this only updates it on the no-reload switch + back/forward.
      document.addEventListener("schemic:driverswitch", function (e) {
        var key = e && e.detail && e.detail.key;
        var link = document.getElementById("favicon");
        if (!link || !key) return;
        link.href = key === "hub" ? "/favicon.svg" : "/favicon-" + key + ".svg";
      });
    </script>
  </body>
</html>
