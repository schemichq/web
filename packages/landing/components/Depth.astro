---
const kw = "text-code-keyword";
const fn = "text-code-fn";
const ty = "text-code-type";
const st = "text-code-string";
const pl = "text-code-plain";
const vr = "text-accent-2";
const cm = "text-code-comment";

type Tok = { t: string; c: string };
type Line = { num: number; tokens: Tok[] };
const blank = (n: number): Line => ({ num: n, tokens: [{ t: " ", c: pl }] });

// access.ts — event + function + access, one typed source
const tsLines: Line[] = [
  { num: 1, tokens: [{ t: "// events, functions & access — one file", c: cm }] },
  { num: 2, tokens: [{ t: "User", c: ty }, { t: ".", c: pl }, { t: "event", c: fn }, { t: "(", c: pl }, { t: '"welcome"', c: st }, { t: ", {", c: pl }] },
  { num: 3, tokens: [{ t: "  when", c: pl }, { t: ": ", c: pl }, { t: "surql", c: fn }, { t: "`", c: st }, { t: "$event", c: vr }, { t: " = ", c: pl }, { t: "'CREATE'", c: st }, { t: "`", c: st }, { t: ",", c: pl }] },
  { num: 4, tokens: [{ t: "  then", c: pl }, { t: ": ", c: pl }, { t: "surql", c: fn }, { t: "`", c: st }, { t: "fn::welcome", c: fn }, { t: "(", c: pl }, { t: "$after.id", c: vr }, { t: ")", c: pl }, { t: "`", c: st }, { t: ",", c: pl }] },
  { num: 5, tokens: [{ t: "})", c: pl }] },
  blank(6),
  { num: 7, tokens: [{ t: "export ", c: kw }, { t: "const ", c: kw }, { t: "welcome", c: pl }, { t: " = ", c: pl }, { t: "defineFunction", c: fn }, { t: "(", c: pl }, { t: '"welcome"', c: st }, { t: ", {", c: pl }] },
  { num: 8, tokens: [{ t: "  user", c: pl }, { t: ": ", c: pl }, { t: "s", c: pl }, { t: ".", c: pl }, { t: "recordId", c: fn }, { t: "(", c: pl }, { t: '"user"', c: st }, { t: "),", c: pl }] },
  { num: 9, tokens: [{ t: "}).", c: pl }, { t: "body", c: fn }, { t: "(", c: pl }, { t: "surql", c: fn }, { t: "`", c: st }, { t: "CREATE ", c: kw }, { t: "log", c: ty }, { t: " ", c: pl }, { t: "SET ", c: kw }, { t: "user", c: pl }, { t: " = ", c: pl }, { t: "$user", c: vr }, { t: "`", c: st }, { t: ")", c: pl }] },
  blank(10),
  { num: 11, tokens: [{ t: "export ", c: kw }, { t: "const ", c: kw }, { t: "account", c: pl }, { t: " = ", c: pl }, { t: "defineAccess", c: fn }, { t: "(", c: pl }, { t: '"account"', c: st }, { t: ")", c: pl }] },
  { num: 12, tokens: [{ t: "  .", c: pl }, { t: "record", c: fn }, { t: "().", c: pl }, { t: "signup", c: fn }, { t: "(", c: pl }, { t: "surql", c: fn }, { t: "`", c: st }, { t: "CREATE ", c: kw }, { t: "user", c: ty }, { t: " ", c: pl }, { t: "SET ", c: kw }, { t: "email", c: pl }, { t: " = ", c: pl }, { t: "$email", c: vr }, { t: "`", c: st }, { t: ")", c: pl }] },
  { num: 13, tokens: [{ t: "  .", c: pl }, { t: "duration", c: fn }, { t: "({ ", c: pl }, { t: "session", c: pl }, { t: ": ", c: pl }, { t: '"12h"', c: st }, { t: " })", c: pl }] },
];

// access.surql — the generated DDL
const surqlLines: Line[] = [
  { num: 1, tokens: [{ t: "DEFINE EVENT ", c: kw }, { t: "welcome ", c: pl }, { t: "ON TABLE ", c: kw }, { t: "user", c: ty }] },
  { num: 2, tokens: [{ t: "  WHEN ", c: kw }, { t: "$event", c: vr }, { t: " = ", c: pl }, { t: "'CREATE'", c: st }] },
  { num: 3, tokens: [{ t: "  THEN ", c: kw }, { t: "fn::welcome", c: fn }, { t: "(", c: pl }, { t: "$after.id", c: vr }, { t: ");", c: pl }] },
  blank(4),
  { num: 5, tokens: [{ t: "DEFINE FUNCTION ", c: kw }, { t: "fn::welcome", c: fn }, { t: "(", c: pl }, { t: "$user", c: vr }, { t: ": ", c: pl }, { t: "record", c: kw }, { t: "<", c: pl }, { t: "user", c: ty }, { t: ">", c: pl }, { t: ") {", c: pl }] },
  { num: 6, tokens: [{ t: "  CREATE ", c: kw }, { t: "log ", c: ty }, { t: "SET ", c: kw }, { t: "user", c: pl }, { t: " = ", c: pl }, { t: "$user", c: vr }] },
  { num: 7, tokens: [{ t: "};", c: pl }] },
  blank(8),
  { num: 9, tokens: [{ t: "DEFINE ACCESS ", c: kw }, { t: "account ", c: pl }, { t: "ON DATABASE", c: kw }] },
  { num: 10, tokens: [{ t: "  TYPE RECORD", c: kw }] },
  { num: 11, tokens: [{ t: "  SIGNUP ", c: kw }, { t: "(", c: pl }, { t: "CREATE ", c: kw }, { t: "user ", c: ty }, { t: "SET ", c: kw }, { t: "email", c: pl }, { t: " = ", c: pl }, { t: "$email", c: vr }, { t: ")", c: pl }] },
  { num: 12, tokens: [{ t: "  DURATION FOR SESSION ", c: kw }, { t: "12h", c: ty }, { t: ";", c: pl }] },
];

---

<section id="depth" class="border-t border-border-subtle px-6 py-24 sm:py-28">
  <div class="mx-auto max-w-6xl">
    <!-- head (left-aligned) -->
    <div class="max-w-3xl">
      <p class="font-mono text-xs text-accent-2">
        // if you know Zod, you already know this
      </p>
      <h2
        class="mt-3 font-display text-[32px] font-semibold tracking-tight text-ink sm:text-[36px]"
      >
        Schema, DDL, and migrations — one file.
      </h2>
      <p class="mt-4 max-w-2xl text-base leading-relaxed text-ink-2">
        Go past tables and fields. Events, functions, and access rules all
        live in the same typed source — and generate real DDL.
      </p>
    </div>

    <!-- window -->
    <div
      class="mt-10 overflow-hidden rounded-2xl border border-border bg-code-bg shadow-[0_30px_70px_-30px_rgba(0,0,0,0.7),0_0_70px_-26px_color-mix(in_oklab,var(--color-accent)_28%,transparent)]"
    >
      <!-- title bar -->
      <div class="relative flex items-center bg-surface px-4.5 py-3.5">
        <div class="flex items-center gap-2">
          <span class="size-3 rounded-full bg-[#ff5f57]"></span>
          <span class="size-3 rounded-full bg-[#febc2e]"></span>
          <span class="size-3 rounded-full bg-[#28c840]"></span>
        </div>
        <span
          class="absolute left-1/2 -translate-x-1/2 font-mono text-xs text-ink-3"
          >access.ts → access.surql</span
        >
      </div>

      <!-- panes: side-by-side w/ bare seam arrow on desktop, stacked on mobile -->
      <div class="relative grid font-mono text-[12.5px] leading-6 lg:grid-cols-2">
        <!-- left pane (access.ts) -->
        <div
          class="flex min-w-0 flex-col border-b border-border-subtle bg-white/[0.02] lg:border-b-0"
        >
          <div
            class="flex items-center justify-between border-b border-border-subtle px-4.5 py-2.5"
          >
            <span class="font-mono text-xs text-ink">access.ts</span>
            <span class="font-mono text-[11px] text-ink-3">TypeScript</span>
          </div>
          <div class="min-w-0 overflow-x-auto py-4 lg:pr-5">
            {
              tsLines.map((line) => (
                <div class="flex">
                  <span class="w-9 shrink-0 select-none pr-3 text-right text-ink-3">{line.num}</span>
                  <code class="whitespace-pre">{line.tokens.map((tk) => <span class={tk.c}>{tk.t}</span>)}</code>
                </div>
              ))
            }
          </div>
        </div>

        <!-- right pane (access.surql) -->
        <div class="flex min-w-0 flex-col bg-accent-2/[0.04]">
          <div
            class="flex items-center justify-between border-b border-border-subtle px-4.5 py-2.5"
          >
            <span class="font-mono text-xs text-ink">access.surql</span>
            <span class="font-mono text-[11px] text-ink-3">SurrealQL</span>
          </div>
          <div class="min-w-0 overflow-x-auto py-4 lg:pl-5">
            {
              surqlLines.map((line) => (
                <div class="flex">
                  <span class="w-9 shrink-0 select-none pr-3 text-right text-ink-3">{line.num}</span>
                  <code class="whitespace-pre">{line.tokens.map((tk) => <span class={tk.c}>{tk.t}</span>)}</code>
                </div>
              ))
            }
          </div>
        </div>

        <!-- bare gradient seam arrow (desktop only) -->
        <div
          class="absolute left-1/2 top-5 hidden -translate-x-1/2 -translate-y-1/2 lg:block"
        >
          <svg
            class="size-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="url(#depthSeamArrowGrad)"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <defs>
              <linearGradient
                id="depthSeamArrowGrad"
                x1="0"
                y1="24"
                x2="24"
                y2="0"
                gradientUnits="userSpaceOnUse"
              >
                <stop offset="0" stop-color="var(--color-accent)"></stop>
                <stop offset="1" stop-color="var(--color-accent-2)"></stop>
              </linearGradient>
            </defs>
            <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>
