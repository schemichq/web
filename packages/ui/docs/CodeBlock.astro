---
/**
 * CodeBlock - a single brand-styled code panel: filename header + optional
 * language badge + Copy. It WRAPS a Markdown fence (slot), not a `code` prop,
 * because MDX strips leading indentation from multi-line expression-attribute
 * template literals. The fenced child is rendered by Astro's Markdown Shiki
 * (brand theme, indentation preserved); this just adds the chrome.
 *
 * Usage (MDX) - note the blank lines around the fence:
 *   <CodeBlock title="schema.ts">
 *
 *   ```ts
 *   export const User = defineTable("user", { ... });
 *   ```
 *
 *   </CodeBlock>
 */
interface Props {
  title?: string;
  lang?: string;
}
const { title, lang } = Astro.props;
const labels: Record<string, string> = {
  ts: "TypeScript",
  typescript: "TypeScript",
  js: "JavaScript",
  surql: "SurrealQL",
  surrealql: "SurrealQL",
  sql: "SQL",
  postgresql: "PostgreSQL",
  pgsql: "PostgreSQL",
  postgres: "PostgreSQL",
  bash: "Shell",
  sh: "Shell",
  json: "JSON",
};
const langLabel = lang ? (labels[lang] ?? lang) : undefined;
---

<div class="code-block" data-code-block>
  <div class="cb-bar">
    <span class="cb-name">{title}</span>
    <span class="cb-right">
      {langLabel && <span class="cb-lang">{langLabel}</span>}
      <button type="button" class="cb-copy" data-copy aria-label="Copy code">
        <span data-copy-label>Copy</span>
      </button>
    </span>
  </div>
  <div class="cb-body"><slot /></div>
</div>

<style>
  .code-block {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: clip;
    background: var(--color-code-bg);
    margin: 1.25rem 0;
  }
  .cb-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.5rem 0.875rem;
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .cb-name {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.02em;
    color: var(--color-ink-2);
  }
  .cb-right {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }
  .cb-lang {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-ink-3);
  }
  .cb-copy {
    border: 1px solid var(--color-border-subtle);
    border-radius: 6px;
    background: transparent;
    color: var(--color-ink-3);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.25rem 0.55rem;
    cursor: pointer;
    transition:
      color 0.12s ease,
      border-color 0.12s ease;
  }
  .cb-copy:hover {
    color: var(--color-ink);
    border-color: var(--color-border);
  }
  .cb-copy.is-copied {
    color: var(--color-success);
    border-color: color-mix(in oklab, var(--color-success) 50%, transparent);
  }
  /* The slotted Markdown fence sits flush inside the frame. */
  .cb-body :global(pre) {
    margin: 0 !important;
    border: 0 !important;
    border-radius: 0 !important;
    background: var(--color-code-bg) !important;
    padding: 0.875rem 1rem 1rem !important;
    overflow-x: auto;
  }
</style>

<script>
  function initCodeBlock(root: HTMLElement) {
    const pre = root.querySelector<HTMLElement>(".cb-body pre");
    const copyBtn = root.querySelector<HTMLButtonElement>("[data-copy]");
    const copyLabel = root.querySelector<HTMLElement>("[data-copy-label]");
    copyBtn?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(pre?.innerText ?? "");
        if (copyLabel) copyLabel.textContent = "Copied";
        copyBtn.classList.add("is-copied");
        setTimeout(() => {
          if (copyLabel) copyLabel.textContent = "Copy";
          copyBtn.classList.remove("is-copied");
        }, 1400);
      } catch {
        /* clipboard unavailable */
      }
    });
  }
  document
    .querySelectorAll<HTMLElement>("[data-code-block]")
    .forEach((el) => initCodeBlock(el));
</script>
