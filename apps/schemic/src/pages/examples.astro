---
// schemic.dev/examples — the verified cookbook gallery.
//
// A hub-level (database-agnostic) page: it wears the same neutral hub chrome as
// "/" (Landing layout + shared Nav + Footer), and lets the visitor filter the
// gallery by driver. Every example pairs a TS authoring source with the DDL it
// generates; both are highlighted at BUILD time with Astro's Shiki <Code> using
// the brand theme, so the colors match the rest of the site.
//
// Data comes from a STUB catalog (config/examples-catalog.ts) seeded from the
// driver-verified landing examples — to be swapped for the vendored verified
// manifest from schemic (core-dev) without touching this page (it depends only
// on the CatalogExample shape + the examplesCatalog export).
import { Code } from "astro:components";
import { brandShikiTheme } from "@schemic/content/code-theme";
import Landing from "../layouts/Landing.astro";
import Nav from "@schemic/landing/components/Nav.astro";
import Footer from "@schemic/landing/components/Footer.astro";
import { drivers } from "@schemic/landing/config/drivers";
import {
  examplesCatalog,
  type CatalogExample,
} from "../config/examples-catalog";

const DEFAULT_DRIVER = "surrealdb";

// Only the drivers that actually have catalog examples, ordered by the roster.
const driverTabs = drivers.filter((d) =>
  examplesCatalog.some((e) => e.driver === d.slug),
);

// Group a driver's examples by `group`, preserving first-seen order.
function groupsFor(slug: string): { group: string; items: CatalogExample[] }[] {
  const out: { group: string; items: CatalogExample[] }[] = [];
  for (const ex of examplesCatalog) {
    if (ex.driver !== slug) continue;
    let g = out.find((x) => x.group === ex.group);
    if (!g) {
      g = { group: ex.group, items: [] };
      out.push(g);
    }
    g.items.push(ex);
  }
  return out;
}

// Shiki has no surql/postgres-specific grammar here; highlight every DDL block
// as plain SQL (matches the surreal site's surql -> sql langAlias).
const DDL_LANG = "sql";

// Shared <Code> options so TS + DDL blocks render with identical brand colors.
const codeAttrs = { theme: brandShikiTheme, wrap: false } as const;
---

<Landing
  title="Examples — Schemic"
  description="A verified cookbook of Schemic examples: TypeScript schema authoring and the native DDL it generates, for SurrealDB and PostgreSQL."
>
  <Nav activeDriver={null} />
  <main class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
    <!-- header -->
    <header class="max-w-2xl">
      <p
        class="font-mono text-xs font-medium uppercase tracking-[0.18em] text-accent-soft"
      >
        Cookbook
      </p>
      <h1
        class="mt-3 text-4xl font-semibold tracking-tight text-ink sm:text-5xl"
      >
        Examples
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-ink-2">
        Every example is generated and verified against the live driver — the
        TypeScript you author on the left, the native DDL Schemic emits on the
        right.
      </p>
    </header>

    <!-- driver filter -->
    <div
      role="tablist"
      aria-label="Filter examples by database"
      class="mt-10 inline-flex items-center gap-1 rounded-full border border-border bg-surface p-1"
    >
      {
        driverTabs.map((d) => (
          <button
            type="button"
            role="tab"
            data-ex-tab={d.slug}
            aria-selected={d.slug === DEFAULT_DRIVER ? "true" : "false"}
            class="rounded-full px-4 py-1.5 text-sm font-medium text-ink-2 transition-colors hover:text-ink aria-selected:bg-ink aria-selected:text-canvas"
          >
            <span class="flex items-center gap-2">
              <span
                class="size-2 rounded-full"
                style={`background:${d.color}`}
                aria-hidden="true"
              />
              {d.name}
            </span>
          </button>
        ))
      }
    </div>

    <!-- per-driver galleries -->
    {
      driverTabs.map((d) => (
        <section
          data-ex-driver={d.slug}
          hidden={d.slug !== DEFAULT_DRIVER}
          class="mt-12 space-y-14"
        >
          {groupsFor(d.slug).map((grp) => (
            <div>
              <h2 class="text-sm font-semibold uppercase tracking-[0.12em] text-ink-3">
                {grp.group}
              </h2>
              <div class="mt-5 space-y-8">
                {grp.items.map((ex) => (
                  <article class="overflow-hidden rounded-2xl border border-border bg-surface">
                    <div class="border-b border-border-subtle px-5 py-4">
                      <h3 class="text-base font-semibold text-ink">
                        {ex.title}
                      </h3>
                      {ex.note && (
                        <p class="mt-1 text-sm leading-relaxed text-ink-2">
                          {ex.note}
                        </p>
                      )}
                    </div>
                    <div class="grid grid-cols-1 divide-y divide-border-subtle md:grid-cols-2 md:divide-x md:divide-y-0">
                      {/* TS authoring source */}
                      <div class="min-w-0">
                        <div class="flex items-center gap-2 border-b border-border-subtle px-4 py-2.5">
                          <span class="font-mono text-[11px] font-medium uppercase tracking-wide text-ink-3">
                            schema.ts
                          </span>
                          <span class="rounded-full bg-canvas-2 px-2 py-0.5 font-mono text-[10px] text-ink-3">
                            TypeScript
                          </span>
                        </div>
                        <div class="overflow-x-auto p-4 text-sm [&_pre]:!bg-transparent">
                          <Code code={ex.code} lang="ts" {...codeAttrs} />
                        </div>
                      </div>
                      {/* generated DDL */}
                      <div class="min-w-0">
                        <div class="flex items-center gap-2 border-b border-border-subtle px-4 py-2.5">
                          <span class="font-mono text-[11px] font-medium uppercase tracking-wide text-ink-3">
                            Generated
                          </span>
                          <span class="rounded-full bg-canvas-2 px-2 py-0.5 font-mono text-[10px] text-accent-soft">
                            {ex.lang}
                          </span>
                        </div>
                        <div class="overflow-x-auto p-4 text-sm [&_pre]:!bg-transparent">
                          <Code code={ex.ddl} lang={DDL_LANG} {...codeAttrs} />
                        </div>
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          ))}
        </section>
      ))
    }
  </main>
  <Footer activeDriver={null} />
</Landing>

<script>
  // Driver filter — toggles which [data-ex-driver] gallery is visible and keeps
  // the tab's selected state in sync. No reload; pure visibility switch.
  const tabs = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-ex-tab]"),
  );
  const panels = Array.from(
    document.querySelectorAll<HTMLElement>("[data-ex-driver]"),
  );

  function select(slug: string): void {
    tabs.forEach((t) =>
      t.setAttribute(
        "aria-selected",
        t.dataset.exTab === slug ? "true" : "false",
      ),
    );
    panels.forEach((p) => {
      p.hidden = p.dataset.exDriver !== slug;
    });
  }

  tabs.forEach((t) =>
    t.addEventListener("click", () => {
      if (t.dataset.exTab) select(t.dataset.exTab);
    }),
  );
</script>
