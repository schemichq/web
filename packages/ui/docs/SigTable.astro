---
/** SigTable - a grouped API table: signature, mapped type, description. */
interface Row {
  sig: string;
  type: string;
  desc: string;
}
interface Props {
  id: string;
  title: string;
  rows: Row[];
  /** Dialect column header, e.g. "SurrealQL" (default) or "Postgres". */
  targetLabel?: string;
}
const { id, title, rows, targetLabel = "SurrealQL" } = Astro.props;
---

<section class="sig">
  <h2 id={id} class="grp">{title}</h2>
  <div class="table">
    <div class="row is-head">
      <span class="c1">s.*</span>
      <span class="c2">{targetLabel} TYPE</span>
      <span class="c3">DESCRIPTION</span>
    </div>
    {
      rows.map((r) => (
        <div class="row">
          <span class="c1 mono sig-cell">{r.sig}</span>
          <span class="c2 mono type-cell">{r.type}</span>
          <span class="c3">{r.desc}</span>
        </div>
      ))
    }
  </div>
</section>

<style>
  .sig {
    margin-top: 1.75rem;
  }
  .grp {
    margin: 0 0 0.75rem;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-soft);
    scroll-margin-top: 5rem;
  }
  .table {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: clip;
  }
  .row {
    display: grid;
    grid-template-columns: 280px 170px 1fr;
    align-items: center;
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .row:last-child {
    border-bottom: 0;
  }
  .row span {
    padding: 8px 16px;
  }
  .row.is-head {
    background: var(--color-surface);
  }
  .row.is-head span {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-ink-3);
  }
  .mono {
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .sig-cell {
    color: var(--color-pink);
  }
  .type-cell {
    color: var(--color-code-type);
  }
  .c3 {
    font-size: 0.82rem;
    color: var(--color-ink-2);
  }
  @media (max-width: 45rem) {
    .row {
      grid-template-columns: 1fr;
    }
    .row span {
      padding: 6px 14px;
    }
  }
</style>
