---
const kw = "text-code-keyword"; // after-card TS keywords (export/const)
const kwS = "text-[#9d8ec4]"; // before-card SurrealQL keywords (muted "old way")
const fn = "text-code-fn";
const ty = "text-code-type";
const st = "text-code-string";
const pl = "text-code-plain";
const vr = "text-pink"; // $value placeholder
const cm = "text-[#ff7a86]"; // before-card comments

type Tok = { t: string; c: string };
type Line = { num: number; tokens: Tok[] };

// Before: hand-written SurrealQL with warning comments + TODOs (muted palette)
const beforeLines: Line[] = [
  { num: 1, tokens: [{ t: "-- keep in sync with src/types.ts  (!)", c: cm }] },
  { num: 2, tokens: [{ t: "DEFINE TABLE ", c: kwS }, { t: "user ", c: pl }, { t: "TYPE NORMAL SCHEMAFULL;", c: kwS }] },
  { num: 3, tokens: [{ t: "DEFINE FIELD ", c: kwS }, { t: "id ", c: pl }, { t: "ON TABLE ", c: kwS }, { t: "user ", c: pl }, { t: "TYPE ", c: kwS }, { t: "string;", c: ty }] },
  { num: 4, tokens: [{ t: "DEFINE FIELD ", c: kwS }, { t: "email ", c: pl }, { t: "ON TABLE ", c: kwS }, { t: "user ", c: pl }, { t: "TYPE ", c: kwS }, { t: "string", c: ty }] },
  { num: 5, tokens: [{ t: "  ASSERT ", c: kwS }, { t: "string::is_email", c: fn }, { t: "(", c: pl }, { t: "$value", c: vr }, { t: ");", c: pl }] },
  { num: 6, tokens: [{ t: "DEFINE INDEX ", c: kwS }, { t: "user_email_idx ", c: pl }, { t: "ON TABLE ", c: kwS }, { t: "user", c: pl }] },
  { num: 7, tokens: [{ t: "  FIELDS ", c: kwS }, { t: "email ", c: pl }, { t: "UNIQUE;", c: kwS }] },
  { num: 8, tokens: [{ t: "DEFINE FIELD ", c: kwS }, { t: "name ", c: pl }, { t: "ON TABLE ", c: kwS }, { t: "user ", c: pl }, { t: "TYPE ", c: kwS }, { t: "option<string>;", c: ty }] },
  { num: 9, tokens: [{ t: "DEFINE FIELD ", c: kwS }, { t: "createdAt ", c: pl }, { t: "ON TABLE ", c: kwS }, { t: "user ", c: pl }, { t: "TYPE ", c: kwS }, { t: "datetime", c: ty }] },
  { num: 10, tokens: [{ t: "  DEFAULT ", c: kwS }, { t: "time::now", c: fn }, { t: "() ", c: pl }, { t: "READONLY;", c: kwS }] },
  { num: 11, tokens: [{ t: "-- TODO: update TS types to match", c: cm }] },
  { num: 12, tokens: [{ t: "-- TODO: hand-write up + down migration", c: cm }] },
];

// After: the s.* schema (same source as the Demo left pane)
const afterLines: Line[] = [
  { num: 1, tokens: [{ t: "export ", c: kw }, { t: "const ", c: kw }, { t: "User", c: ty }, { t: " = ", c: pl }, { t: "defineTable", c: fn }, { t: "(", c: pl }, { t: '"user"', c: st }, { t: ", {", c: pl }] },
  { num: 2, tokens: [{ t: "  id", c: pl }, { t: ": ", c: pl }, { t: "s", c: fn }, { t: ".", c: pl }, { t: "string", c: fn }, { t: "(),", c: pl }] },
  { num: 3, tokens: [{ t: "  email", c: pl }, { t: ": ", c: pl }, { t: "s", c: fn }, { t: ".", c: pl }, { t: "email", c: fn }, { t: "().", c: pl }, { t: "unique", c: fn }, { t: "(),", c: pl }] },
  { num: 4, tokens: [{ t: "  name", c: pl }, { t: ": ", c: pl }, { t: "s", c: fn }, { t: ".", c: pl }, { t: "string", c: fn }, { t: "().", c: pl }, { t: "optional", c: fn }, { t: "(),", c: pl }] },
  { num: 5, tokens: [{ t: "  createdAt", c: pl }, { t: ": ", c: pl }, { t: "s", c: fn }, { t: ".", c: pl }, { t: "datetime", c: fn }, { t: "()", c: pl }] },
  { num: 6, tokens: [{ t: "    .", c: pl }, { t: "$default", c: fn }, { t: "(", c: pl }, { t: "surql", c: fn }, { t: "`", c: st }, { t: "time::now", c: fn }, { t: "()", c: pl }, { t: "`", c: st }, { t: ")", c: pl }] },
  { num: 7, tokens: [{ t: "    .", c: pl }, { t: "$readonly", c: fn }, { t: "(),", c: pl }] },
  { num: 8, tokens: [{ t: "});", c: pl }] },
];

const xIcon = '<path d="M18 6 6 18"/><path d="M6 6l12 12"/>';
const checkIcon = '<path d="M20 6 9 17l-5-5"/>';
const sparklesIcon =
  '<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0z"/>';
---

<section id="compare" class="border-y border-border-subtle bg-canvas-2 px-6 py-20 sm:py-24">
  <div class="mx-auto max-w-6xl">
    <!-- head -->
    <div class="flex flex-col items-center gap-3 text-center">
      <p class="font-mono text-xs uppercase tracking-[0.083em] text-hot">
        // the old way
      </p>
      <h2
        class="font-display text-4xl font-semibold tracking-tight text-ink sm:text-[2.75rem]"
      >
        Stop <span class="text-danger">hand-writing</span> SurrealQL.
      </h2>
    </div>

    <!-- compare -->
    <div class="mt-[30px] grid items-start gap-6 lg:grid-cols-2">
      <!-- before -->
      <div class="overflow-hidden rounded-[14px] border border-danger/[0.23] bg-code-bg">
        <div
          class="flex items-center justify-between border-b border-border-subtle bg-danger/[0.07] px-4 py-3"
        >
          <div class="flex items-center gap-2.5">
            <span
              class="grid size-5 place-items-center rounded-md bg-danger text-white"
            >
              <svg
                class="size-3"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={xIcon}
              />
            </span>
            <span class="font-display text-sm font-semibold text-ink">By hand</span>
          </div>
          <span class="font-mono text-[11px] text-ink-3">schema.surql · 12 lines</span>
        </div>
        <div class="space-y-1 overflow-x-auto px-[18px] pb-[18px] pt-4 font-mono text-[11.5px] leading-[1.6]">
          {
            beforeLines.map((line) => (
              <div class="flex gap-[14px]">
                <span class="w-[18px] shrink-0 select-none text-right text-code-comment">{line.num}</span>
                <code class="whitespace-pre">{line.tokens.map((tk) => <span class={tk.c}>{tk.t}</span>)}</code>
              </div>
            ))
          }
        </div>
      </div>

      <!-- after -->
      <div
        class="overflow-hidden rounded-[14px] border border-success/25 bg-code-bg shadow-[0_24px_50px_-20px_rgba(0,0,0,0.55),0_0_70px_-24px_rgba(150,0,255,0.35)]"
      >
        <div
          class="flex items-center justify-between border-b border-border-subtle bg-success/[0.07] px-4 py-3"
        >
          <div class="flex items-center gap-2.5">
            <span
              class="grid size-5 place-items-center rounded-md bg-success text-white"
            >
              <svg
                class="size-3"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={checkIcon}
              />
            </span>
            <span class="font-display text-sm font-semibold text-ink"
              >With Schemic</span
            >
          </div>
          <span class="font-mono text-[11px] text-ink-3">schema.ts · 7 lines</span>
        </div>
        <div class="space-y-1 overflow-x-auto px-[18px] pb-[18px] pt-4 font-mono text-[12.5px] leading-[1.6]">
          {
            afterLines.map((line) => (
              <div class="flex gap-[14px]">
                <span class="w-[18px] shrink-0 select-none text-right text-code-comment">{line.num}</span>
                <code class="whitespace-pre">{line.tokens.map((tk) => <span class={tk.c}>{tk.t}</span>)}</code>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- caption -->
    <div class="mt-[30px] flex justify-center">
      <div
        class="inline-flex items-center gap-2.5 rounded-full border border-border bg-surface px-[18px] py-2.5"
      >
        <svg
          class="size-[15px] shrink-0 text-pink"
          viewBox="0 0 24 24"
          fill="currentColor"
          set:html={sparklesIcon}
        />
        <span class="font-display text-sm text-ink-2">
          Same schema. The DDL, types, and migrations are generated — and can
          never drift.
        </span>
      </div>
    </div>
  </div>
</section>
