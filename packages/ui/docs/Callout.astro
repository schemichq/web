---
/**
 * Callout - an admonition with a tinted left border and icon.
 * variant: note (purple) | tip (success) | caution (amber) | danger (red).
 */
interface Props {
  variant?: "note" | "tip" | "caution" | "danger";
  title?: string;
}
const { variant = "note", title } = Astro.props;

const icons: Record<string, string> = {
  note: '<path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3z"/>',
  tip: '<path d="M20 6 9 17l-5-5"/>',
  caution:
    '<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/>',
  danger:
    '<path d="M7.86 2h8.28L22 7.86v8.28L16.14 22H7.86L2 16.14V7.86z"/><path d="M12 8v4"/><path d="M12 16h.01"/>',
};
const svg = icons[variant];
---

<aside class:list={["callout", variant]}>
  <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={svg} />
  <div class="body">
    {title && <p class="title">{title}</p>}
    <div class="content"><slot /></div>
  </div>
</aside>

<style>
  .callout {
    display: flex;
    gap: 12px;
    padding: 16px;
    border-radius: 10px;
    border-left: 3px solid var(--accent);
    background: color-mix(in oklab, var(--accent) 9%, transparent);
    margin: 1.25rem 0;
  }
  .callout.note {
    --accent: var(--color-purple);
    --icon: var(--color-soft);
  }
  .callout.tip {
    --accent: var(--color-success);
    --icon: var(--color-success);
  }
  .callout.caution {
    --accent: #f5c14e;
    --icon: #f5c14e;
  }
  .callout.danger {
    --accent: var(--color-danger);
    --icon: var(--color-danger);
  }
  .ic {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    margin-top: 1px;
    color: var(--icon);
  }
  .body {
    min-width: 0;
  }
  .title {
    margin: 0 0 4px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-ink);
  }
  .content {
    font-size: 0.84rem;
    line-height: 1.6;
    color: var(--color-ink-2);
  }
  .content :global(p) {
    margin: 0;
  }
  .content :global(p + p) {
    margin-top: 0.5rem;
  }
  .content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--color-ink);
    background: var(--color-surface-2);
    padding: 0.1em 0.35em;
    border-radius: 5px;
  }
</style>
