---
import "@fontsource-variable/geist";
import "@fontsource-variable/jetbrains-mono";
import "./docs.css";
import type { NavGroup, NavItem, TocItem } from "@schemic/content/nav";
import DocsNav from "./DocsNav.astro";
import DocsSearch from "./DocsSearch.astro";
import DocsSidebar from "./DocsSidebar.astro";
import DocsTOC from "./DocsTOC.astro";

interface Props {
  title: string;
  description?: string;
  sidebarNav: NavGroup[];
  topNav: NavItem[];
  activeHref?: string;
  topActive?: string;
  headings?: TocItem[];
}
const {
  title,
  description = "Author your database schema in TypeScript with Zod — generate native DDL, infer end-to-end types, and run safe migrations.",
  sidebarNav,
  topNav,
  activeHref,
  topActive = "Docs",
  headings = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const fullTitle = `${title} | Schemic`;
const hasToc = headings.length > 0;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Schemic" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <DocsNav topNav={topNav} topActive={topActive} />
    <div class="shell">
      <DocsSidebar
        sidebarNav={sidebarNav}
        activeHref={activeHref}
        topNav={topNav}
        topActive={topActive}
      />
      <main class="content">
        {/* data-pagefind-body scopes Pagefind to docs pages only: the landing
            (/) and blog don't render DocsLayout, so they stay out of the index.
            The doc <h1> inside the slot becomes each result's title. */}
        <article
          class:list={["content-inner", { wide: !hasToc }]}
          data-pagefind-body
        >
          <slot />
        </article>
      </main>
      {hasToc && <DocsTOC headings={headings} />}
    </div>
    <DocsSearch />
  </body>
</html>

<style>
  .shell {
    max-width: 1320px;
    margin-inline: auto;
    display: flex;
    align-items: flex-start;
  }
  .content {
    flex: 1;
    min-width: 0;
  }
  .content-inner {
    max-width: 768px;
    padding: 44px 56px 96px;
  }
  .content-inner.wide {
    max-width: 880px;
  }
  @media (max-width: 60rem) {
    .content-inner {
      padding: 32px 28px 72px;
    }
  }
</style>
